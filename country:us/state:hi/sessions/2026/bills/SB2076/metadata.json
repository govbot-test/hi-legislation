  ],
  "subject": [
    "Digital Replica",
    "Likeness",
    "Publicity Rights"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Protects a person's right to publicity from digital replicas by including \"digital replica\" in the definition of \"likeness\" that is protected under state law that governs publicity rights.  Effective 1/1/2077.  (SD1)"
    }
  ],
