  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning January 1, 2027, bans the manufacture, sale, offer of sale, or distribution in the State of any food for human consumption that contains petroleum-based synthetic food dyes and synthetic chemical additives.  (SD1)"
    }
