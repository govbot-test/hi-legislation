  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an exemption from mediation in parentage proceedings where there are allegations of domestic abuse.  Clarifies the exemption from mediation in divorce proceedings as it relates to domestic abuse.  (SD1)"
    }
  ],
