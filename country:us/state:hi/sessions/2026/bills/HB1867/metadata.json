  "identifier": "HB1867",
  "title": "RELATING TO SAFETY AT HOME.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Deadly Force",
    "Duty to Retreat",
    "Safe at Home Law",
    "Self-Defense"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that a person who uses deadly force in self-defense does not have a duty to retreat if they are in their dwelling or on their property, unless they are the initial aggressor.  Repeals statutory language that permits a person to use deadly force at their place of work."
    }
  ],
