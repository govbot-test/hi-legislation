  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a cooperative working group to address state projects that require county permitting and to explore, research, and make recommendations on streamlining processes.  Requires a report to the Legislature.  Appropriates funds.  Effective 4/19/2042.  (SD1)"
    }
