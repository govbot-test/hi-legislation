{
  "legislative_session": "2026",
  "identifier": "SB2115",
  "title": "RELATING TO COLLECTIVE BARGAINING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Arbitration",
    "Collective Bargaining in Public Employment",
    "Impasse Procedures",
    "Negotiations",
    "Repricing of Classes"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the collective bargaining negotiation procedure on the repricing of classes within a bargaining unit for public employees.  Establishes an impasse procedure to be applied when an employer fails to initiate the negotiation or the parties fail to reach an agreement within 90 days.  Repeals existing law that requires a different impasse procedure to apply in those situations.  Sunsets 6/30/2029.  Effective 7/1/3000.  (HD1)"
    }
  ],
