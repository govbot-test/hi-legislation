  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a temporary Parkinson's Patient Air Transport Feasibility Committee to examine recommendations for improving access to movement disorder care for neighbor island residents, including the feasibility of a state-administered air transport assistance fund.  Requires a report to the Legislature.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
