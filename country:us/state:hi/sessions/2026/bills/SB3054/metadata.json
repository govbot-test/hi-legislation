  "abstracts": [
    {
      "note": "description",
      "abstract": "For purposes of permissible uses in agricultural districts, establishes minimum requirements for income received from agricultural activity for a family occupying a farm dwelling.  Provides that the definition of a \"farm dwelling\" includes agricultural activity that is considered a farming operation under section 165-2, HRS, and is conducted on more than 50 per cent of the entire lot."
    }
  ],
