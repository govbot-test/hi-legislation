{
  "legislative_session": "2026",
  "identifier": "SB2698",
  "title": "RELATING TO TRANSPORTATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation",
    "Cruise Ship Special Fund",
    "Cruise Ships",
    "DOT",
    "Passenger Head Fee",
    "TAT"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Transportation to assess a per passenger head fee against cruise ships docking in the State's commercial harbors in addition to existing port user fees.  Establishes the Cruise Ship Special Fund.  Repeals existing law imposing the Transient Accommodations Tax on cruise ships, effective retroactive to 1/1/2026.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
