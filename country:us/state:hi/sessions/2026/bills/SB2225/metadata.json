  ],
  "subject": [
    "Adoption",
    "DCCA",
    "Psychology Interjurisdictional Compact",
    "Rules"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Adopts the Psychology Interjurisdictional Compact to regulate the practice of telepsychology and the temporary in-person, face-to-face practice of psychologists when patients are located in compact states other than the state where the psychologist is licensed.  Requires the Department of Commerce and Consumer Affairs to adopt rules to implement and administer the compact."
    }
  ],
