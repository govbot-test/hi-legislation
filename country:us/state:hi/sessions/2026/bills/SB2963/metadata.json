{
  "legislative_session": "2026",
  "identifier": "SB2963",
  "title": "RELATING TO INSURANCE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Automatic Payment",
    "Contents Coverage",
    "Insurance",
    "Notice to Policyholders",
    "Personal Property Coverage",
    "State of Emergency"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the automatic payment of 100% of the personal property or contents coverage limit stated in an insurance policy in the event of a total loss of a dwelling caused by certain perils that occurred pursuant to a state of emergency.  Prohibits an insurer from requiring the submission of an itemized inventory of damaged or destroyed personal property.  Requires notice to policyholders of the right to an automatic payment."
    }
  ],
