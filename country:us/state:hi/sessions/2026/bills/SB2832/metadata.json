  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides elective officers with the choice to be members of the Employees' Retirement System after each election.  Repeals the condition that a choice to be excluded from the Employees' Retirement System is irrevocable and such choice may only be made once."
    }
