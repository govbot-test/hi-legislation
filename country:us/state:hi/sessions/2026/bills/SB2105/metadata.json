  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals provisions requiring all deposit beverage distributors to send monthly or semi-annual distribution reports and supporting records to the Department of Health; develop and submit to the program for approval, an internal control process to ensure accurate data reporting and adequate record maintenance; and obtain biennial independent audits."
    }
