  "identifier": "SB2339",
  "title": "RELATING TO THE STATE BUILDING CODE COUNCIL.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Building Industry Association of Hawaii",
    "Department of Accounting and General Services",
    "General Contractors Association of Hawaii",
