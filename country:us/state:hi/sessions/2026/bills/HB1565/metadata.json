  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a working group within the Judiciary to improve family court processes, including access to legal representation for youth in the child welfare system.  Appropriates funds for the working group.  Effective 3/22/2075.  (SD1)"
    }
  ],
