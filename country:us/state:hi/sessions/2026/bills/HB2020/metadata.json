{
  "legislative_session": "2026",
  "identifier": "HB2020",
  "title": "RELATING TO RENEWAL OF DRIVER'S LICENSES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOT",
    "Driver's License",
    "Motor Vehicle Drivers",
    "Renewal",
    "Traffic Safety"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires certain applicants for driver's license renewal to complete an educational course that includes a road safety video developed by the Department of Transportation and a written examination.  Authorizes the Department to develop and implement a system to randomly require applicants for renewal of a driver's license to complete a written examination.  Requires a report to the Legislature.  Effective 3/22/2075.  (SD1)"
    }
  ],
