  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a process by which any political party continuously listed on the general election ballot for two consecutive general election cycles shall be deemed continuously qualified for ballot placement.  Effective 3/22/2075.  (SD1)"
    }
  ],
