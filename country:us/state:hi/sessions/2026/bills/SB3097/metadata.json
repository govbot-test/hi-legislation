{
  "legislative_session": "2026",
  "identifier": "SB3097",
  "title": "RELATING TO THE EXEMPTION FROM CIVIL SERVICE OF EXECUTIVE PERSONNEL OF THE EMPLOYEES' RETIREMENT SYSTEM.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Service Exemption",
    "ERS",
    "Executive Personnel"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows the Board of Trustees of the Employees' Retirement System, through its Executive Director, to appoint specified executive personnel positions of the Employees' Retirement System and exempts these positions from the State's civil service requirements.  (CD1)"
    }
  ],
