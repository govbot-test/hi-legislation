  "abstracts": [
    {
      "note": "description",
      "abstract": "Adjusts the applicability of Act 134, SLH 2025, to clarify the threshold for Department of Education procurement of local edible produce and packaged food products.  Prohibits the artificial division and parceling of DOE procurements of local edible produce and packaged food products.  Sunsets 6/30/2028.  (CD1)"
    }
  ],
