  "identifier": "SB3249",
  "title": "RELATING TO PROCUREMENT PROTESTS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Proceedings",
    "Cash or Protest Bonds",
