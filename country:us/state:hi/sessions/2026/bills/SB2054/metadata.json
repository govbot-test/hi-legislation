  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits the Hawaii National Guard from deploying to assist federal troops, federal law enforcement, or the national guard of any other state operating in Hawaii when the Governor has objected to the deployments.  Effective 7/1/3000.  (HD2)"
    }
  ],
