  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands the authority of the State and counties to develop adaptation pathways plans to modify and relocate infrastructure away from critically threatened areas to locations outside sea level rise and coastal flooding exposure areas.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
