  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that the prohibition on the mining or taking of beach or marine deposits, including sand, seaward from the shoreline applies to licensed and unlicensed contractors.  Effective 7/1/3000.  (HD2)"
    }
  ],
