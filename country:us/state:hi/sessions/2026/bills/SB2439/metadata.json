  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires quarterly rather than annual reporting of all use of restricted use pesticides.  Amends the contents of reports to include specific geospatial data and information and increased detail on the amount of restricted use pesticides used.  Requires the Department of Agriculture and Biosecurity to develop an online reporting tool for restricted use pesticides.  Appropriates funds."
    }
  ],
