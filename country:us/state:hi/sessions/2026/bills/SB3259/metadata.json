  "legislative_session": "2026",
  "identifier": "SB3259",
  "title": "RELATING TO SOLID WASTE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Disposal",
    "Municipal Waste Combustor Ash",
    "Prohibition on Reuse",
    "Solid Waste Control"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires municipal solid waste combustor ash to be disposed of only in a double-lined landfill, except for in Waimanalo Gulch Sanitary Landfill cells constructed and in use by 12/31/2025.  Beginning 12/31/2026, prohibits the reuse of municipal solid waste incinerator ash for use as daily landfill cover material, roadbuilding, fill, or construction material."
    }
  ],
