  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates funds to the Department of Hawaiian Home Lands for certain geothermal resource exploration and development activities and the hiring of consultants.  Requires the Department of Hawaiian Home Lands to engage in consultation with beneficiaries of Hawaiian home lands regarding activities funded and to comply with the environmental impact statements law.  Effective 7/1/3000.  (HD2)"
    }
  ],
