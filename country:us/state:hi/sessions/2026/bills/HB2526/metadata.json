  "title": "RELATING TO TAXATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Department of Taxation",
    "General Excise Tax",
    "Hurricane Resistance Retrofit",
    "Income Tax Credit",
    "Rate Reduction"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a nonrefundable individual income tax credit for a certain percentage of expenses paid to retrofit a residence with wind resistive devices or to purchase, install, or construct, a hurricane shelter on the taxpayer's property.  Reduces the general excise tax rate on the gross proceeds or income from the sale of a concrete certified hurricane-resistant residential project or certain hurricane-resistant components of a high-rise condominium.  Applies to taxable years beginning after 12/31/2026.  Sunsets 12/31/2030."
    }
  ],
