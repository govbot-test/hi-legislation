  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an Early Learning Apprenticeship Grant Program to be administered by the University of Hawaii to provide financial support for early learning program service providers in the State to participate in state- or federally-approved early learning apprenticeship programs.  Requires an annual report to the Legislature.  Appropriates funds."
    }
  ],
