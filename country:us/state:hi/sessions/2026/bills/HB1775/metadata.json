{
  "legislative_session": "2026",
  "identifier": "HB1775",
  "title": "RELATING TO FORECLOSURES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Eligible Bidders",
    "Judicial Foreclosures",
    "Subsequent Bids"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Specifies that a judicial foreclosure sale is not final until the earliest of either fifteen days after the public sale, unless an eligible bidder submits a subsequent bid or written notice of intent to submit a subsequent bid, or forty-five days after the public sale.  Requires subsequent successful bidders to make a downpayment."
    }
  ],
