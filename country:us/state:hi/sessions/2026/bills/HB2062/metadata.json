  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates funds to the Judiciary for the efficient processing of temporary restraining orders and gun violence protective orders.  Appropriates funds to the Department of Law Enforcement to conduct public awareness campaigns on gun violence protective orders.  Effective 7/1/2055.  (SD2)"
    }
  ],
