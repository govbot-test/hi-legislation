  "identifier": "SB2758",
  "title": "RELATING TO PUBLIC LAND DISPOSITIONS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "BLNR",
    "Bombing",
    "Extension",
    "Live-Fire Training",
    "Military Leases",
