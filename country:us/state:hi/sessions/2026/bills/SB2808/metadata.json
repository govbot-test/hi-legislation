  "identifier": "SB2808",
  "title": "RELATING TO THE BUDGET.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "B&F",
    "Defeasement Trust Fund",
    "Private Use",
    "State Facilities",
    "Tax-Exempt Bonds"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Defeasement Trust Fund within the Department of Budget and Finance for the defeasement of tax-exempt bonds to allow private use of state facilities financed by tax-exempt bonds.  Requires the Department to consult with bond counsel before defeasement.  Appropriates moneys in and out of the Defeasement Trust Fund for defeasement of certain tax-exempt bonds.  Effective 7/1/3000.  (HD1)"
    }
  ],
