  "title": "RELATING TO RENTAL ASSISTANCE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriations ($)",
    "Bureau of Conveyances",
    "DLNR",
