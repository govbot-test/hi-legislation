  "abstracts": [
    {
      "note": "description",
      "abstract": "Includes the Chief Energy Officer of the Hawaii State Energy Office as a member of the Hawaii Climate Change Mitigation and Adaptation Commission.  Ensures that the State's zero emissions clean economy aspirational target encourages both local and global sequestration.  Requires each state agency to review the impacts of its internal plans as they relate to the purpose and goals of the Commission.  Requires HSEO to submit summary reports to the Governor and Legislature.  Appropriates funds."
    }
  ],
