  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that a person or entity shall be liable for all or a portion of search and rescue expenses when the search and rescue results from the person or entity's violation of applicable laws.  Requires the State Fire Council to adopt rules, and the counties to adopt ordinances, as necessary to pursue reimbursements."
    }
  ],
