{
  "legislative_session": "2026",
  "identifier": "HB2067",
  "title": "RELATING TO TOBACCO PRODUCTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Hawaii State Association of Counties",
    "Package",
    "Tobacco Products"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals law that provides that all local ordinances or regulations that regulate the sale of cigarettes, tobacco products, and electronic smoking devices are preempted and that existing local laws and regulations conflicting with the state law on smoking are null and void.  Clarifies that counties retain the authority to adopt ordinances that regulate the sale of cigarettes, tobacco products, and electronic smoking devices, as long as the ordinances do not conflict with and are more stringent than the state law on smoking."
    }
  ],
