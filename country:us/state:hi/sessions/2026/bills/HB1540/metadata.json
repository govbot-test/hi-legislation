  "identifier": "HB1540",
  "title": "RELATING TO HOME HEALTH LICENSING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Accreditation",
    "Certification",
    "Department of Health",
    "Home Health Agencies",
    "Licensing Inspections",
