  "identifier": "SB3202",
  "title": "RELATING TO HEALTH CARE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Healthcare Preceptor Tax Credit",
    "Licensed Dietitians",
    "Physician Assistants",
    "Preceptor Credit Assurance Committee",
    "Residency Programs",
    "Social Workers"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the Healthcare Preceptor Tax Credit to remove language limiting access only to those practicing in primary care, to add licensed dietitians, physician assistants, and social workers as eligible preceptors and students, and to include residency and followship programs.  Adds the Director of Health and a representative of residency programs with eligible students to the Preceptor Credit Assurance Committee.  Applies to taxable years beginning after 12/31/2026.  Effective 7/1/2050.  (SD1)"
    }
  ],
