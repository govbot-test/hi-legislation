  "legislative_session": "2026",
  "identifier": "SB2014",
  "title": "RELATING TO PUBLIC EMPLOYMENT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Abolishment",
    "DHRD",
    "Lapsing of Funds",
    "Reclassification",
    "Report",
    "Vacant Positions"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Director of Human Resources Development to abolish vacant positions within state departments and agencies under its jurisdiction that have been vacant for more than 5 years with certain exceptions. Requires funds for abolished positions to immediately lapse to the credit of the appropriate fund.  Requires a list of positions abolished to be included in the Director's annual report to the Legislature.  Effective 7/1/3000.  (HD1)"
    }
  ],
