  "identifier": "HB2537",
  "title": "RELATING TO THE PATIENTS' BILL OF RIGHTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Artificial Intelligence",
    "Automated Decision Support Tools",
    "Data Protection",
    "Insurance Commissioner",
    "Offshoring",
    "Patients' Bill of Rights and Responsibilities",
    "Prior Authorization",
