{
  "legislative_session": "2026",
  "identifier": "SB2925",
  "title": "RELATING TO COCONUT TREES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation",
    "DAB",
    "Natural Management of Coconut Rhinoceros Beetle Tax Credit",
    "Taxation"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an income tax credit for qualified costs to implement natural management of coconut rhinoceros beetles that result in consumable coconut trees.  Applies to taxable years beginning after 12/31/2026.  Appropriates funds.  Effective 7/1/3000.  (HD2)"
    }
  ],
