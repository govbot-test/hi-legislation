  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies state and local authority during a state or local state of emergency.  Adds a definition of \"severe weather warning\".  Allows the Legislature to terminate a state of emergency and city councils to terminate a local state of emergency.  Effective 7/1/3000.  (HD1)"
    }
  ],
