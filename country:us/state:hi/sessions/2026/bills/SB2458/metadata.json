  "identifier": "SB2458",
  "title": "RELATING TO SUGAR-SWEETENED BEVERAGES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advisory Committee",
    "Appropriation ($)",
    "Department of Health",
