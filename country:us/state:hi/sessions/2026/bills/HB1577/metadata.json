  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the 911 Board to establish a Statewide Emergency Safety Profile System Pilot Program and convene a working group.  Requires report to the Legislature.  Repeals on 6/30/2031.  Effective 7/1/3000.  (HD1)"
    }
  ],
