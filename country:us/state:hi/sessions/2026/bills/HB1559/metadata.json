{
  "legislative_session": "2026",
  "identifier": "HB1559",
  "title": "RELATING TO EDUCATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Department of Education",
    "Prohibited",
    "Telecommunication Devices"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits a student from using a telecommunication device on school grounds during the instructional day, with certain exceptions.  Requires a confiscated telecommunication device to be released only to the student's parent or legal guardian, who has three months to retrieve the device before it is subject to forfeiture.  Effective 7/1/3000.  (HD2)"
    }
  ],
