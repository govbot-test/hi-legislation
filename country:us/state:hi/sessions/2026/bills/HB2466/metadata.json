  "legislative_session": "2026",
  "identifier": "HB2466",
  "title": "RELATING TO EDUCATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Artificial Intelligence Literacy",
    "Cell Phone Use",
    "DOE",
    "Public Schools",
    "Social Media Education"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the department of education to prohibit electronic telecommunication device usage during the instructional day and implement a social media and artificial intelligence literacy education campaign.  Creates exemptions for students requiring accommodations, emergency situations, and teacher authorizations.  Requires the department of education to submit a report three years after the initial effective date, and then every five years thereafter."
    }
  ],
