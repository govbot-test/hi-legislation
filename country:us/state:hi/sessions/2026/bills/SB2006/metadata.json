  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that a \"farm dwelling\" permitted in an agricultural district includes a single-family farm dwelling with an accessory employee housing structure, subject to certain restrictions.  Effective 3/22/2075.  (SD2)"
    }
  ],
