  "legislative_session": "2026",
  "identifier": "HB2186",
  "title": "RELATING TO PEDESTRIAN SAFETY.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Crosswalks",
    "Pedestrian Safety"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies driver's obligations at crosswalks.  Requires drivers to stop and remain stopped for pedestrians in crosswalks.  Strengthens penalties for traffic violations, particularly in school zones.  Creates additional criminal penalties when pedestrians suffer bodily injury.  Provides heightened protections for blind and visually impaired pedestrians.  Effective 7/1/3000.  (HD1)"
    }
  ],
