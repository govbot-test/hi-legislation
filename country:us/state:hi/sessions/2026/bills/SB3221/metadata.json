  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Local Agriculture Transportation Cost Reimbursement Program within the Department of Transportation to reimburse eligible ranchers and farmers a portion of their costs to transport livestock, livestock products, agricultural commodities, and certain supplies, under certain conditions.  Establishes a position to administer the Program.  Appropriates funds."
    }
  ],
