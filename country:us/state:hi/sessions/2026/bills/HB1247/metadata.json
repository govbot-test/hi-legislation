{
  "legislative_session": "2026",
  "identifier": "HB1247",
  "title": "RELATING TO CRIMINAL PROCEEDINGS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriations ($)",
    "Judicial Review",
    "Minimum Terms"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows a party aggrieved by the judgment of a circuit court on a minimum term order to appeal to the Intermediate Appellate Court.  Requires prisoners to be represented by counsel in any petition challenging the minimum term proceedings.  Requires the Supreme Court to establish rules.  Establishes grounds for challenging a minimum term order.  Appropriates funds.  Effective 3/22/2075.  (SD1)"
    }
  ],
