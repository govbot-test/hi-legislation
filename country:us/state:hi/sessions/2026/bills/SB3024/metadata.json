{
  "legislative_session": "2026",
  "identifier": "SB3024",
  "title": "RELATING TO SEX-BASED DISCRIMINATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AG",
    "Comprehensive Legal Review",
    "Protections",
    "Retaliation",
    "Sex Discrimination",
    "Sex-Based Harassment",
    "Title IX"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies and strengthens the State's protections against sex-based harassment, sex discrimination, and retaliation that occur in public schools, public charter schools, or at the University of Hawaii, including discrimination based on gender identity or expression, sexual orientation, pregnancy, and pregnancy-related conditions.  Establishes procedures for investigations and decision-making.  Requires mandatory reporting by certain employees.  Requires the Department of the Attorney General to conduct a comprehensive legal review.  Effective 7/1/2050.  (SD1)"
    }
  ],
