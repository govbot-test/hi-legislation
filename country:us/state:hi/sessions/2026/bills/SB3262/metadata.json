  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires that the Hawaii Teacher Standards Board submit three nominees for its Executive Director to the Board of Education.  Requires the Board of Education to appoint an Executive Director from the nominees on the list, subject to advice and consent of the Senate.  (CD1)"
    }
