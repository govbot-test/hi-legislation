  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Hawaii Public Housing Authority to develop and implement a comprehensive safety plan that includes the use of safety technologies for all public housing statewide.  Requires the Authority to adopt policies that protect civil liberties and safeguard data and engage with public housing residents regarding the use of safety technologies.  Appropriates funds."
    }
  ],
