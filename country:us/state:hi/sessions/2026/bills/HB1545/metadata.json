  "identifier": "HB1545",
  "title": "RELATING TO HEALTH CARE PLANS FOR WORKERS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Catastrophic Health Plan",
    "DLIR",
    "Health Savings Account",
