  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Labor and Industrial Relations, in consultation with the Insurance Commissioner, to establish and implement a five-year voluntary Nontraditional Workforce Portable Health Care Benefit Plan Pilot Program that offers high deductible health plans or catastrophic health plans to nontraditional workers who are ineligible for health benefits provided by the Hawaii Employer-Union Health Benefits Trust Fund or prepaid health care plans under the Prepaid Health Care Act.  Requires reports to the Legislature.  Appropriates funds."
    }
  ],
