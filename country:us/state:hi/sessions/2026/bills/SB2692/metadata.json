  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Land and Natural Resources to acquire, through eminent domain or otherwise, the leasehold interest in the parcel identified as tax map key:  (3) 2-1-001:012 and currently used as the Grand Naniloa Golf Course.  Authorizes the Board of Land and Natural Resources to approve a new use for the parcel after providing an opportunity for public testimony.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
