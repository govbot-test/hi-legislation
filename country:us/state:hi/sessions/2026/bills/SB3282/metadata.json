  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a statewide framework for the implementation of the federal Workforce Pell Grant Program to provide financial aid for certain short-term workforce education and training programs.  Establishes a Workforce Pell Grant Program Approval Committee within the Workforce Development Council.  Authorizes the Department of Labor and Industrial Relations to adopt rules.  Effective 1/1/2077.  (SD1)"
    }
  ],
