  "identifier": "SB2245",
  "title": "RELATING TO REVOLVING DOOR RESTRICTIONS FOR STATE EMPLOYEES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Ethics Commission Package",
    "Post-Employment Restrictions",
    "Pre-Employment Restrictions",
    "State Employees"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits new state employees from taking official action on matters they worked on before state employment.  Prohibits former permanent employees of the Office of the Governor and Office of the Lieutenant Governor from representing persons or businesses for a period of 12 months after termination from state employment.  Effective 7/1/3000.  (HD1)"
    }
  ],
