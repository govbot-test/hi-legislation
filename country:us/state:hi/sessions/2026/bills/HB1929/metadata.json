  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Molokai Biosecurity Advisory Board.  Requires the Department of Agriculture and Biosecurity, with the advice of the Advisory Board, to develop a Molokai Biosecurity Plan to prevent the spread of invasive species found elsewhere in the State to the island of Molokai.  Appropriates moneys.  Effective 7/1/2050.  (SD2)"
    }
  ],
