  ],
  "subject": [
    "Appropriations ($)",
    "DOT",
    "Fare-Free Youth Transit Program",
    "Keiki Ride Free",
    "Public Transit",
    "Special Fund"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes within the Department of Transportation a fare-free youth transit program, to be coordinated with the counties.  Establishes a fare-free youth transit program special fund.  Requires biannual evaluations of the new program and special fund.  Allocates moneys from the environmental response, energy, and food security tax to the fare-free youth transit program special fund.  Appropriates moneys into and out of the fare-free youth transit program special fund.  Requires reports to the Legislature."
    }
  ],
