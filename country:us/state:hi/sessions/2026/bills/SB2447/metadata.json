  "identifier": "SB2447",
  "title": "RELATING TO CAMPAIGN FINANCE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CSC",
    "Campaign Finance",
    "Criminal Prosecution",
    "Period of Limitations"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides that the period of limitations for criminal prosecutions under campaign finance laws commences upon discovery of the offense by the Campaign Spending Commission, rather than being limited to five years from the violation date or report filing date.  Effective 7/1/3000.  (HD1)"
    }
  ],
