{
  "legislative_session": "2026",
  "identifier": "SB2970",
  "title": "RELATING TO STANDARDS OF CONDUCT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Code of Ethics",
    "Principal State Department",
    "Prohibited Contracts",
    "Relatives and Household Members",
    "Responsibility",
    "Violations"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals the $10,000 value threshold for certain prohibited contracts involving legislators or employees.  Prohibits state agencies from contracting to procure or dispose of goods or services, or for construction, with businesses owned, operated, or controlled by relatives or household members of department heads or deputy directors.  Requires department heads, acting department heads, and deputy directors of principal state departments to ensure compliance with the Code of Ethics provision governing contracts and provides for liability for violations.  Effective 7/1/3000.  (HD1)"
    }
  ],
