  "identifier": "SB3197",
  "title": "RELATING TO TAXATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Exemptions",
    "GET",
    "Groceries",
