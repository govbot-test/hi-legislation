{
  "legislative_session": "2026",
  "identifier": "HB1768",
  "title": "RELATING TO IMMIGRATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Immigration Enforcement Actions",
    "Prohibition",
    "State and County Law Enforcement"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits any law enforcement agency or law enforcement official from entering into an agreement under federal law that permits state or county agencies to engage in immigration enforcement.  Prohibits law enforcement agencies and law enforcement officials from engaging in certain immigration-related actions, except under limited circumstances.  Effective 7/1/2055.  (SD2)"
    }
  ],
