  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a five-year pilot program allowing retirants to be rehired for exempt service for one-year terms under certain circumstances.  Provides that retirants employed under the program are excluded from the Hawaii Employer-Union Health Benefits Trust Fund and will not experience an interruption of pension benefits.  Requires an employer of a retirant under the program to contribute to the Employees' Retirement System.  Requires the Department of Human Resources Development to submit a report to the Legislature.  Sunsets 6/30/2031.  Effective 1/1/2077.  (SD1)"
    }
  ],
