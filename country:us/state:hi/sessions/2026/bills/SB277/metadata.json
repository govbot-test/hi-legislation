  "legislative_session": "2026",
  "identifier": "SB277",
  "title": "RELATING TO SEXUAL OFFENSES AGAINST MINORS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Criminal Offenses",
    "Honolulu Prosecuting Attorney Package",
    "Penal Code",
    "Sexual Offenses Against Minors"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases the penalty for promoting minor-produced sexual images to a felony if the person is more than 3 years older than the minor.  Extends the probationary term for felony obscenity offenses.  Tolls the statute of limitations for obscenity offenses during a victim's minority.  Requires sex offender registration for felony obscenity offenses involving minors.  (SD1)"
    }
  ],
