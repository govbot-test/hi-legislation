  "legislative_session": "2026",
  "identifier": "HB1668",
  "title": "RELATING TO MEDICAID.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Department of Human Services",
    "Full Earned Income Disregard",
    "Medicaid"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Human Services to allow a full earned income disregard for individuals with disabilities who are between the ages of sixteen and sixty-four years when determining eligibility for Medicaid.  Takes effect upon approval by the Centers for Medicare and Medicaid Services.  Effective 7/1/3000.  (HD1)"
    }
  ],
