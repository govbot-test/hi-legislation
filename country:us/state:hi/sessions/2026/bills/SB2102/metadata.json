  "legislative_session": "2026",
  "identifier": "SB2102",
  "title": "RELATING TO INDUSTRIAL HEMP.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Commercial Feed",
    "DAB",
    "Hemp",
    "Hemp-Derived Feed Ingredient",
    "Rules"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 7/1/2026, authorizes the use of hemp or hemp-derived feed ingredients in commercial feed in the State, subject to certain conditions.  Requires the Department of Agriculture and Biosecurity to adopt rules.  Effective 7/1/3000.  (HD2)"
    }
  ],
