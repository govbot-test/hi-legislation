{
  "legislative_session": "2026",
  "identifier": "HB1892",
  "title": "RELATING TO THE BOARD OF EDUCATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Board of Education",
    "Public School Teacher Representative"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the exclusive representative for bargaining unit (5) to appoint to the Board of Education a nonvoting public school teacher representative.  Authorizes the nonvoting public school teacher representative to participate in all Board of Education meetings and enter into executive sessions, except in certain matters related to collective bargaining negotiations or personnel matters that may pose a conflict of interest.  Effective 7/1/3000.  (HD3)"
    }
  ],
