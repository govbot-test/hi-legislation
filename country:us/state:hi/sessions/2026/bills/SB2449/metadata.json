  ],
  "subject": [
    "Board Packets",
    "Business Days",
    "Public Inspection",
    "Public Meetings",
    "Regular Business Hours"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Defines \"business day\" as used in Part I of Chapter 92, HRS, governing public meetings.  Clarifies that board packets, if created, shall be made available for public inspection in the board's office during regular business hours, no later than three full business days before the public meeting.  Defines \"regular business hours\"."
    }
  ],
