  "identifier": "SB2478",
  "title": "PROPOSING AN AMENDMENT TO ARTICLE I OF THE HAWAII STATE CONSTITUTION TO RECOGNIZE AND PROTECT THE INHERENT AND INALIENABLE RIGHT OF ALL PEOPLE TO CLEAN WATER AND AIR, A HEALTHFUL ENVIRONMENT AND CLIMATE AND HEALTHY NATIVE ECOSYSTEMS AND BEACHES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Constitutional Amendment",
    "Environmental Protection (ConAm)",
    "Green Amendment"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Proposes a constitutional amendment to ensure that the inherent and inalienable right of the people, including future generations, to clean water and air, a healthful environment and climate and healthy native ecosystems and beaches, shall be protected and shall not be infringed.  Effective 7/1/2050.  (SD1)"
    }
  ],
