{
  "legislative_session": "2026",
  "identifier": "HB1672",
  "title": "RELATING TO HOUSING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Department of Education",
    "Employee Housing",
    "Public School Facilities"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Education to give reasonable consideration to making all or portions of the facilities of a public school available to housing development for certain employees of the Department when closing the public school.  Requires the Department of Education to identify unused public school facilities that may be appropriate for employee housing and inventory suitable grounds available upon public school closure for potential development of employee housing."
    }
  ],
