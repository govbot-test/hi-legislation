  "subject": [
    "DLNR",
    "Mauna \u02bbAla",
    "Reports",
    "Royal Mausoleum Commission",
    "Rules"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Royal Mausoleum Commission within the Department of Land and Natural Resources to develop and implement policy for the preservation, operation, and outreach of Mauna \u02bbAla.  Allows the Royal Mausoleum Commission to make rules as necessary, employ staff, and receive private or federal funds.  Requires the Royal Mausoleum Commission to report annually to the Legislature.  Requires the Legislature to appropriate sufficient funds to support the Royal Mausoleum Commission."
    }
  ],
