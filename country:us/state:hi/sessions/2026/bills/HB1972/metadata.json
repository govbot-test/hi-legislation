  "subject": [
    "Appropriation ($)",
    "DOTAX",
    "Family Caregiver Tax Credit",
    "Kupuna Caucus",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a family caregiver tax credit for nonpaid family caregivers.  Requires the Department of Taxation to submit annual reports to the Legislature.  Appropriates funds.  Applies to taxable years beginning after 12/31/2026.  Effective 1/1/2050.  (SD1)"
    }
  ],
