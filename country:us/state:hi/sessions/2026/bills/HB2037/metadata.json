{
  "legislative_session": "2026",
  "identifier": "HB2037",
  "title": "RELATING TO TAXATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Aggregate Cap",
    "Digital Media",
    "Motion Picture",
    "Sunset Date",
    "and Film Production Income Tax Credit"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases the aggregate cap on credits allowed in any given year for the Motion Picture, Digital Media, and Film Production Income Tax Credit from $50,000,000 to $60,000,000.  Extends the sunset of the tax credit to 1/1/2038.  Applies to taxable years beginning after 12/31/2026.  Repeals 1/1/2038.  Effective 7/1/3000.  (HD1)"
    }
  ],
