  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes and appropriates funds for an Alzheimer's Disease and Related Dementias Research Center at the University of Hawaii, to be administratively affiliated with the University of Hawaii John A. Burns School of Medicine, including the establishment of full-time positions.  Effective 7/1/3000.  (HD1)"
    }
  ],
