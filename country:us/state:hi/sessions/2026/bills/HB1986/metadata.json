  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Transportation to adopt rules by 1/1/2028 governing a clean fuel standard for alternative fuels in the State.  Requires reporting and public informational session requirements.  Effective 7/1/3000.  (HD2)"
    }
  ],
