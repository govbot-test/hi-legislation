  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows the Department of Hawaiian Home Lands to assume historic preservation review of the effect of any proposed project for lands under its jurisdiction, except under certain circumstances.  Appropriates funds.  Effective 7/1/2026.  (SD1)"
    }
  ],
