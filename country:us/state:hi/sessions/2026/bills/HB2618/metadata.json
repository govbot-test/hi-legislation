  ],
  "subject": [
    "Climate Change and Tourism Destination Management",
    "Expenditure Request",
    "Governor",
    "Projects"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Green Fee Special Fund to receive an allocation of green fee revenues.  Establishes various special funds to receive allocations of green fee revenues.  Requires the Governor to request, through a bill separate from the budget or supplemental budget, an amount that approximates green fee revenues subtracted from the amounts allocated to the various funds to be expended for certain climate change and tourism destination management projects.  Effective 7/1/3000.  (HD1)"
    }
  ],
