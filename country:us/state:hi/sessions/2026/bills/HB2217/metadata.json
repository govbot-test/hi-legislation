  "identifier": "HB2217",
  "title": "RELATING TO IDENTIFICATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Identification Card",
    "DOT",
    "Disability Notation",
    "Driver's License",
    "Permit"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows applicants for driver's permit, driver's license, or civil identification cards to request a disability notation on their permit, license, or identification card.  Requires the Department of Transportation to establish public outreach efforts and coordinate with state and county law enforcement agencies regarding the disability notation.  Effective 7/1/3000.  (HD2)"
    }
  ],
