  "identifier": "SB2094",
  "title": "RELATED TO TOXIC CHEMICALS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "EALs",
    "Pollutants",
