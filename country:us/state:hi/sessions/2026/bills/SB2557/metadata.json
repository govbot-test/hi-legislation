{
  "legislative_session": "2026",
  "identifier": "SB2557",
  "title": "RELATING TO HOMELESSNESS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Homelessness",
    "Kauhale Projects",
    "Reporting Requirements",
    "Statewide Office on Homelessness and Housing Solutions"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Statewide Office on Homelessness and Housing Solutions to make an annual report on the number of sheltered and unsheltered homeless individuals and on housing placement.  Requires the Statewide Office on Homelessness and Housing Solutions to annually report to the Legislature on contracts and plans or proposals to enhance kauhale projects.  Requires the Statewide Office on Homelessness and Housing Solutions to annually report to the Legislature on coordination between the office and any county, state, or federal agencies, or private or nonprofit organizations.  Effective 7/1/3000.  (HD1)"
    }
  ],
