  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Corrections and Rehabilitation to establish a five-year pilot program to employ and pay incarcerated individuals with fewer than five years left on their sentence the minimum wage.  Requires the Department of Corrections and Rehabilitation to submit reports to the Legislature.  Makes an appropriation."
    }
  ],
