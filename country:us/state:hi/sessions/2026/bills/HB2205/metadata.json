  "abstracts": [
    {
      "note": "description",
      "abstract": "Replaces the current statutory prohibition on private shoreline hardening with a policy directing the minimization of these structures.  Establishes a clear, time-limited statutory framework for emergency permits within the conservation district, including defined standards for permit duration and extension."
    }
  ],
