  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Sustainable Tourism Infrastructure Matching Grant Program within the Department of Business, Economic Development, and Tourism to support one-time capital investments that advance measurable sustainability and climate resilience outcomes within the State's visitor industry.  Requires annual reports to the Legislature.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
