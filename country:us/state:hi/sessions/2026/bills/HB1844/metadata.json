  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Except for Important Agricultural Lands, requires the Land Use Commission to reclassify lands that are designated for urban growth under a county general plan or county development plan as being in the urban district at the request of the county, subject to certain conditions.  Effective 7/1/3000.  (HD2)"
    }
  ],
