{
  "legislative_session": "2026",
  "identifier": "HB2596",
  "title": "RELATING TO PLANTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Department of Agriculture and Biosecurity",
    "Invasive Plant Species",
    "Invasive Species Council",
    "Labeling",
    "Weed Risk Assessment"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires persons who sell or offer plants for sale at retail to provide information on the risk of invasiveness of the plant species.  Requires the Invasive Species Council to develop a labeling system for plants that displays the plants' weed risk assessments.  Establishes fines for violations.  Effective 1/1/2027."
    }
  ],
