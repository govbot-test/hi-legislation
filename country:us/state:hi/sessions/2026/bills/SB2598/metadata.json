  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the use of moneys in certain special and revolving funds for operation and administration costs of related programs.  Authorizes the use of the Hawaii agricultural development revolving fund moneys for the acquisition of interests or rights in land and any ongoing costs related thereto.  (CD1)"
    }
  ],
