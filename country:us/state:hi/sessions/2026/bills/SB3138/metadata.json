{
  "legislative_session": "2026",
  "identifier": "SB3138",
  "title": "RELATING TO INDEPENDENT AUDITS OF DEPOSIT BEVERAGE DISTRIBUTORS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Department of Health",
    "Deposit Beverage Container Program",
    "Deposit Beverage Distributor",
    "Exemption",
    "Frequency",
    "Independent Audit"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Limits the independent audit requirement under the State's Deposit Beverage Container Program to deposit beverage distributors who distribute 5 million or more deposit beverage containers a year.  Identifies frequency of obtaining and submitting independent audits based on quantities of deposit beverage containers distributed.  Defines \"distribute\" to include the manufacture, import, and sale of deposit beverage containers.  Creates minimum requirements for independent audits.  (CD1)"
    }
  ],
