  "identifier": "SB2271",
  "title": "RELATING TO HOSPITAL LICENSING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Accreditation Organizations",
    "CMS",
    "Certification Organizations",
