  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Health to adopt rules to allow hospitals to demonstrate compliance with all licensing inspections required by the State through accreditation or certification by any accreditation or certification organization approved by the Centers for Medicare and Medicaid Services.  (CD1)"
    }
  ],
