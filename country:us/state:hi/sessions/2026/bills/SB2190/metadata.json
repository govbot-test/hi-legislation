  "identifier": "SB2190",
  "title": "RELATING TO INCLUSIONARY ZONING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Counties",
    "Development",
    "Exemption",
    "Housing",
    "Inclusionary Zoning"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits any law, ordinance, or rule from imposing an inclusionary zoning requirement on housing offered exclusively for sale or rent in perpetuity to buyers or renters who are residents of the State, are owner-occupants or renters, and do not own any other real property.  Effective 7/1/3000.  (HD1)"
    }
  ],
