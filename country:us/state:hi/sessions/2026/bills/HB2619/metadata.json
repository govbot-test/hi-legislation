  "identifier": "HB2619",
  "title": "RELATING TO HOMEMADE FOOD PRODUCTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOH",
    "Farm Kitchens",
    "Home Kitchens",
