  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Health to adopt rules for the regulation of farm kitchens producing homemade food products that are no more stringent than those for home kitchens producing homemade food products.  Effective 7/1/3000.  (SD1)"
    }
  ],
