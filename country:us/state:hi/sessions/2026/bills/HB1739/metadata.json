{
  "legislative_session": "2026",
  "identifier": "HB1739",
  "title": "RELATING TO TRANSIT-ORIENTED DEVELOPMENT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "County Regulations",
    "County-designated Transit-Oriented Development Areas",
    "Prohibition",
    "Transit-Supportive Densities"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the development of transit-supportive densities to be allowed in any county-designated transit-oriented development area.  Prohibits the counties from enacting an ordinance, rule, regulation, development standard, zoning provision, or other land use control that restricts the development of transit-supportive densities.  Effective 7/1/3000.  (HD2)"
    }
  ],
