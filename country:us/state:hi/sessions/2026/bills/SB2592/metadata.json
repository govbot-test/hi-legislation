  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of the Attorney General to publish, on the Department's public website, an annual report that compiles information on firearms, firearm-related deaths and injuries, and firearm violations.  Effective 7/1/2050.  (SD1)"
    }
