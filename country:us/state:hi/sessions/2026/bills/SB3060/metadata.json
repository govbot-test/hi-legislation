  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides that an actor is not obliged to retreat for purposes of self-defense and defense of others, from agricultural lands if the actor is lawfully present as an owner, lessee, employee, or agent of the State, unless the actor was the initial aggressor."
    }
