  ],
  "subject": [
    "Commission on Water Resources Management",
    "District Boundary Amendment",
    "Land Use Commission"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires any petitioner for a district boundary amendment to obtain certification from the Commission on Water Resources Management that enough water is available for the project needs without causing harm to the relevant aquifers and provide that certification to the Land Use Commission."
    }
  ],
