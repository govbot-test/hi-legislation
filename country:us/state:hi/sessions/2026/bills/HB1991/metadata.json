{
  "legislative_session": "2026",
  "identifier": "HB1991",
  "title": "RELATING TO THE LIQUOR TAX.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Alcohol By Volume",
    "Liquor Tax",
    "Small Craft Producer Pub Licensees",
    "Taxation"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Replaces the defined liquor categories subject to the liquor tax with alcohol-by-volume categories, but with a separate rate for beer manufactured by a small craft producer pub licensee.  Adjusts the liquor tax rates for inflation.  Effective 7/1/3000.  (HD2)"
    }
  ],
