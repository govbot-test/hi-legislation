  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Hawaii Emergency Management Agency, fire chiefs, Law Enforcement Standards Board, and Department of Health to make available at least one hour of dementia\u2011specific training for first responders, including law enforcement officers, fire first responders, and emergency medical services personnel.  Requires the Executive Office on Aging to take certain steps when reviewing and recommending dementia-specific training curricula.  Effective 7/1/3000.  (SD1)"
    }
  ],
