{
  "legislative_session": "2026",
  "identifier": "HB1976",
  "title": "RELATING TO DEMENTIA.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Alzheimer's Disease",
