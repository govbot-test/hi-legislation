  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Board of Land and Natural Resources to adopt rules that implement wildlife viewing guidelines that substantially conform to the wildlife viewing guidelines issued by the National Oceanic and Atmospheric Administration.  Requires annual reports to the Legislature until rules are adopted.  Effective 7/1/3000.  (HD1)"
    }
  ],
