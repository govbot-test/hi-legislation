  "legislative_session": "2026",
  "identifier": "HB2198",
  "title": "RELATING TO PREDICTION MARKETS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Gambling",
    "Hawaii Penal Code",
    "Prediction Markets"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the definition of \"gambling\" to include predictive markets involving the purchase, sale, or financial speculation of securities, commodities, or other similar financial products on the outcome or future contingent event related to catastrophe, contests, death, legislation, national security, people, politics, and sports.  Effective 7/1/3000.  (HD2)"
    }
  ],
