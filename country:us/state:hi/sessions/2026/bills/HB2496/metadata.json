  "identifier": "HB2496",
  "title": "RELATING TO AGRICULTURE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Grant Program",
    "Hawaii Agricultural Transportation Assistance Program",
    "New Special Fund",
    "Reimbursement Program",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Hawaii Agricultural Transportation Assistance Program, to consist of a reimbursement program for geographically disadvantaged farmers and livestock producers to mitigate the high costs of transportation for agricultural products, inputs, and supplies, and a grant program to assist small-scale farmers, ranchers, food hubs, and agricultural producers in rural or underserved areas with transportation costs directly related to the production and distribution of agricultural commodities.  Establishes the Hawaii Agricultural Transportation Assistance Special Fund.  Requires reports to the Legislature.  Appropriates funds."
    }
  ],
