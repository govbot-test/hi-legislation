  "subject": [
    "Appropriation ($)",
    "DOH",
    "In-Home Care Services",
    "KupunAloha Pilot Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes within the Department of Health a one-year KupunAloha Pilot Program to provide in-home health care and support services to eligible participants who do not otherwise qualify for government assistance for these services.  Appropriates funds for the pilot program.  Pilot program sunsets 6/30/2027.  (CD1)"
    }
  ],
