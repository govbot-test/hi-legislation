  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends Act 289, Session Laws of Hawaii 2025, to replace the Senior Residence at Iwilei parcel with the Westridge parcel, change the transfer date for the Alii Tower parcel to 12/31/2026, changes the deadline for approval by the City and County of Honolulu to 12/31/2027, and changes the repeal date to 1/1/2028."
    }
  ],
