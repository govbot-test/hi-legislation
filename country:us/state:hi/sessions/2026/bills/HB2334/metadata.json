  "subject": [
    "DOT",
    "NEPA Assignment",
    "National Environmental Policy Act"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Transportation to assume responsibilities under the National Environmental Policy Act of 1969 for highway projects, as well as railroad, public transportation, or multimodal projects within the State, allowing streamlined environmental reviews.  Provides a limited waiver of sovereign immunity to comply with federal requirements.  Effective 7/1/3000.  (HD1)"
    }
  ],
