{
  "legislative_session": "2026",
  "identifier": "SB2314",
  "title": "RELATING TO THE HAWAIIAN LANGUAGE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Hawaiian Language",
    "Public Documents",
    "State Law"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires that whenever there is a difference between the English and Hawaii version of law that is material to its interpretation, priority shall be given to the language that aligns with the intent of the legislature as evidenced by legislative history, context, and purpose.  Clarifies that Hawaiian shall not be required for public acts and transactions, but is welcomed.  (SD1)"
    }
  ],
