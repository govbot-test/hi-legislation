  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Agriculture and Biosecurity to package and sell a portion of its agricultural loan portfolio to permitted third parties.  Appropriates funds out of the Agricultural Loans Revolving Fund to increase its expenditure ceiling.  Effective 7/1/2050.  (SD1)"
    }
  ],
