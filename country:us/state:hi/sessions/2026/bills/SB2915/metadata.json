  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals the requirement that a certain amount received from the cigarette tax on the wholesale price of each article or item of certain tobacco products deposited into the Hawaii Cancer Research Special Fund must be used for debt service of capital expenditures and building maintenance.  Appropriates funds for the University of Hawaii Cancer Center."
    }
