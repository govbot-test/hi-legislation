  "subject": [
    "Appropriation ($)",
    "DOH",
    "Houseless Individuals",
    "Intensive Mobile Team Pilot Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes and appropriates funds for a 2-year Intensive Mobile Team Pilot Program in the Department of Health to provide intensive mobile treatment-type services to chronically houseless individuals suffering from serious brain disorders, including schizophrenia and schizoaffective disorder.  Effective 7/1/3000.  (SD1)"
    }
  ],
