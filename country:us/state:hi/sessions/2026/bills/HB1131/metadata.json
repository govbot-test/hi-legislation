  "identifier": "HB1131",
  "title": "RELATING TO AN INTENSIVE MOBILE TEAM PILOT PROGRAM FOR HOUSELESS INDIVIDUALS SUFFERING FROM SERIOUS BRAIN DISORDERS.",
  "from_organization": "~{\"classification\": \"lower\"}",
