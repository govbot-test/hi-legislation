  "identifier": "SB2731",
  "title": "RELATING TO SENTENCING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Misdemeanors",
    "Nonviolent Offenses",
    "Penal Code",
    "Sentencing"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Limits the maximum term of imprisonment for misdemeanors, or for offenses punishable by up to or not exceeding one year, to three hundred sixty-four days.  Allows individuals previously sentenced to a one-year term of imprisonment to apply to the court for a sentence modification to conform to the new limit.  Effective 7/1/3000.  (HD1)"
    }
  ],
