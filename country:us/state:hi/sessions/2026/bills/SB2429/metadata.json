  "identifier": "SB2429",
  "title": "RELATING TO TRAFFIC SAFETY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOT",
    "Excessive Speeding",
    "Habitual Speeder",
    "Intelligent Speed Assistance",
