  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires retail sellers of firearms to provide purchasers with notice regarding the law on firearms storage.  Expands the requirements for the secure storage of firearms.  Clarifies the offense of criminally negligent storage of a firearm."
    }
