  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes that fines for pedestrian violations under chapter 291C, Hawaii Revised Statutes, shall not exceed $25.  Requires state and county agencies to revise applicable schedules of fines, rules, and procedures to comply with the monetary limit."
    }
  ],
