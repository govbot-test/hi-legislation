  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the State Auditor, in collaboration with the Office of the City Auditor for the City and County of Honolulu, to conduct a financial audit of all state and City and County of Honolulu expenditures on homelessness programs within the City and County of Honolulu during the 2024-2025 and 2025-2026 fiscal years.  Appropriates funds."
    }
  ],
