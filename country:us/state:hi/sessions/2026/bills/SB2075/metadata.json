{
  "legislative_session": "2026",
  "identifier": "SB2075",
  "title": "RELATING TO PUBLIC PROCUREMENT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Competitive Sealed Bidding",
    "Competitive Sealed Proposals",
    "Debarment",
    "Hawaii Bidders",
    "Hawaii Offerors",
    "Local Preference",
    "Public Procurement",
    "Rules"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires purchasing agencies to apply a five per cent flat rate local preference in evaluating bids or proposals from qualified Hawaii bidders or offerors who submit a timely preference certification.  Establishes criteria for a bid or proposal to qualify for a local preference.  Establishes requirements for the qualification and certification of Hawaii bidders and offerors and consequences for failure to maintain qualification.  Requires the Procurement Policy Board to adopt rules.  (CD1)"
    }
  ],
