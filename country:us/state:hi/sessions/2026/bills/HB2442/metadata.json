{
  "legislative_session": "2026",
  "identifier": "HB2442",
  "title": "RELATING TO PARKING FOR DISABLED PERSONS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Parking",
    "Persons with Disabilities"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 7/1/27, increases the number of required accessible and van-accessible parking spaces in parking facilities with more than twenty-five parking spaces that are covered by title II or III of the Americans with Disabilities Act, with an exception for qualifying public entities managing large parking inventories that are otherwise compliant with Americans with Disabilities Act standards.  Effective 7/1/3000.  (HD2)"
    }
  ],
