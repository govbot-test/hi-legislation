  "identifier": "SB3074",
  "title": "RELATING TO COURT-ORDERED PAYMENTS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Collections",
    "Consequences of Non-Payment",
    "Fees",
    "Fines",
    "Penal Code",
    "and Restitution"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Judiciary to contract with a collection agency or licensed attorney to collect delinquent court-ordered fees, fines, sanctions, and court costs.  Allows courts to specify a period of time or installments for payment of fines, fees, and restitution, and requires the defendant to show cause if the defendant defaults on the payments."
    }
  ],
