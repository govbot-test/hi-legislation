  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Board of Education and collective bargaining units to calculate student-to-teacher ratios for class sizes according to a prescribed method to promote quality education and positive student-teacher interactions.  Informs parents if changes to class sizes are needed."
    }
  ],
