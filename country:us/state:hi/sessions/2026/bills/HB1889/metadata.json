{
  "legislative_session": "2026",
  "identifier": "HB1889",
  "title": "RELATING TO SCHOOL PSYCHOLOGISTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOE",
    "Report",
    "School Psychologists",
    "Working Group"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Creates a School Psychologists Working Group within the Department of Education to recommend actionable steps or propose legislation for an immediate pathway to licensure for school psychologists that can be acted upon in 2027.  Requires a report to the Legislature.  Effective 7/1/3000.  (HD1)"
    }
  ],
