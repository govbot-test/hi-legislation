  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Office of Community Culture, Arts, and Innovation within the Department of Business, Economic Development, and Tourism for administrative purposes only.  Requires annual reports to the Legislature.  Appropriates funds for an Executive Director position and Specialist position within the Office of Community Culture, Arts, and Innovation.  Establishes the Community and Cultural Partnership Program.  (CD1)"
    }
  ],
