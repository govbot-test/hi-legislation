  "identifier": "HB1526",
  "title": "RELATING TO DISCRIMINATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Anti-discrimination",
    "Certain Characteristics",
    "Intersectionality",
    "Prohibitions"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits discrimination based on:  (1) The perception that a person possesses certain characteristics; (2) The perception that a person is associated with a person who possesses, or is perceived to possess, certain characteristics; or (3) The intersection or combination of two or more specified characteristics in relation to a person."
    }
  ],
