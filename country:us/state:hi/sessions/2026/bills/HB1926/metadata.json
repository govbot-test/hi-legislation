{
  "legislative_session": "2026",
  "identifier": "HB1926",
  "title": "RELATING TO RED HILL.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Groundwater Modeling and Sampling",
    "Monitoring and Testing",
    "Red Hill Remediation Special Fund",
    "Remediation",
    "Water Data Testing and Verification"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates funds for studies on remediation of substances released from the Red Hill Bulk Fuel Storage Facility; environmental monitoring and testing; research on groundwater modeling and sampling; and independent testing and verification of water data, to be published on a public dashboard.  Requires the Department of Land and Natural Resources to seek reimbursement from the United States Department of Defense.  Effective 11/20/2121.  (SD1)"
    }
  ],
