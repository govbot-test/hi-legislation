  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands the scope of persons who are subject to public financial disclosure requirements.  Makes technical, conforming amendments to disclosure provisions applicable to legislators.  Clarifies that an amount of stock may be reported by the value or number of shares.  Effective 7/1/3000.  (HD2)"
    }
  ],
