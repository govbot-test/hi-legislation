  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Primary Care Providers Working Group within the State Health Planning and Development Agency to address issues relating to, and develop recommendations for the stabilization of, primary care services in Hawaii.  Requires the Working Group to make a report to the Legislature.  Sunsets the Working Group on 6/30/2027.  Effective 1/1/2050.  (SD1)"
    }
  ],
