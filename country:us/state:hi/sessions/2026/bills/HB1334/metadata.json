{
  "legislative_session": "2026",
  "identifier": "HB1334",
  "title": "RELATING TO MEAT DONATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Axis Deer Meat Donation Pilot Program",
    "Charitable",
    "Department of Agriculture and Biosecurity",
    "Department of Health",
    "Food Donation",
    "Religious",
    "or Nonprofit Organizations"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an Axis Deer Meat Donation Pilot Program to exempt the donation of axis deer meat to a charitable, religious, or nonprofit organization for the purpose of feeding needy individuals from certain laws regarding the inspection and transportation of axis deer meat, carcasses, and meat products, subject to certain requirements.  Requires reports to the Legislature.  Sunsets 6/30/2033.  (CD2)"
    }
  ],
