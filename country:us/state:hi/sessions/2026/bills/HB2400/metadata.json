  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates funds for Department of Hawaiian Home Lands projects eligible for general fund revenues that are generated by increases in transient accommodations tax collections and intended to be expended equally across projects related to natural resources, climate resilience, and destination management.  Effective 7/1/3000.  (HD1)"
    }
