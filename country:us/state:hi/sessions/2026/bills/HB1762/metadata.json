  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a cost-benefit analysis requirement that defines a specific financial impact threshold for administrative rules.  Requires legislative action through concurrent resolution to approve an agency\u2019s major rule change above the threshold of one million dollars."
    }
