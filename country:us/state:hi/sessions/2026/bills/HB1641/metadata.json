  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits the lease or rental of a high-speed electric device.  Prohibits the sale or offer for sale of a high-speed electric device, under certain conditions.  Prohibits the operation of a high-speed electric device in certain situations.  Establishes penalties.  Effective 7/1/3000.  (HD2)"
    }
  ],
