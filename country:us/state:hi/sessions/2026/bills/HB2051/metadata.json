  "subject": [
    "Campaign Spending Commission Package",
    "Cash Contribution Limits",
    "Escheat",
    "Return of Contribution"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends section 11-364, HRS, to provide that an excess contribution of more than $100 in cash, in the aggregate, from a single person during an election period to a candidate, candidate committee, or noncandidate committee shall escheat to the Hawaii election campaign fund if not returned to the contributor within 30 days."
    }
  ],
