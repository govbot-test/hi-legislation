  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Removes county-specific expenditure restrictions for funds in the Automated Speed Enforcement Systems Program Special Fund.  Requires unencumbered and unexpended revenues from the Automated Speed Enforcement Systems Program Special Fund in excess of a certain amount as of June 30 of each year to lapse to the general fund.  Effective 7/1/3000.  (HD1)"
    }
  ],
