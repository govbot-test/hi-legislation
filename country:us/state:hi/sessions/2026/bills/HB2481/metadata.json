  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Statewide Office on Homelessness and Housing Solutions to establish a permanent Return-to-Home Program to return homeless individuals in the State to families and relatives in their home states.  Requires the Office to report to the Legislature.  Appropriates funds."
    }
