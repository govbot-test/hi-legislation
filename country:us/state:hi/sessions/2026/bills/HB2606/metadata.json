  "abstracts": [
    {
      "note": "description",
      "abstract": "Implements certain recommendations of the SPEED Task Force.  Establishes a working group within the State Building Code Council to develop proposals for an off-site construction program.  Requires a report to the Legislature.  Appropriates funds.  Effective 7/1/2055.  (SD1)"
    }
  ],
