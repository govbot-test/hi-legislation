  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 1/1/2027, repeals the fourteen years and under age limit for health insurance coverage requirements for the diagnosis and treatment of autism.  Repeals the maximum coverage benefit limit of $25,000 for applied behavioral analysis services."
    }
