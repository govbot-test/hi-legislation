{
  "legislative_session": "2026",
  "identifier": "HB469",
  "title": "RELATING TO PARKING FOR DISABLED PERSONS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DCAB",
    "Disability Travel Placard",
    "Disabled Persons Parking"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Disability and Communication Access Board to issue a disability travel placard to an applicant who has a valid removeable windshield placard or disabled paid parking exemption permit but does not have a valid special license plate, and provides proof of travel.  (SD2)"
    }
  ],
