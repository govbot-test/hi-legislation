  "legislative_session": "2026",
  "identifier": "HB2137",
  "title": "RELATING TO ARTIFICIAL INTELLIGENCE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Artificial Intelligence",
    "Protections for Individuals",
    "Realistic Digital Imitations"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits certain harmful uses of realistic digital imitations generated by artificial intelligence (AI).  Establishes certain exemptions.  Provides for civil actions and civil remedies for individuals injured by unauthorized AI-generated realistic digital imitations.  (CD1)"
    }
  ],
