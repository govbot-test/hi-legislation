  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Board of Regents to expend funds appropriated to renew, improve, or modernize existing University of Hawaii facilities for only those purposes and not for current, ongoing, or anticipated capital improvement projects.  Requires annual reports to the Legislature.  (SD1)"
    }
  ],
