    "Project",
    "Registration"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "For purposes of registering a condominium project in an agricultural district, (1) lowers the minimum threshold from projects with five units to projects with two units for which a signed statement from a county is required and (2) requires the project applicant to make a presentation on the project to the neighborhood board, if applicable.  Effective 7/1/3000.  (HD1)"
    }
  ],
