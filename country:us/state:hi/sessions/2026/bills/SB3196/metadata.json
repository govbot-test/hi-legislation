  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Labor Day tax credit for employers of construction workers.  Requires any employer of a construction worker to pay the construction worker at a rate that is twice the worker's regular rate of pay for any work performed on Labor Day."
    }
  ],
