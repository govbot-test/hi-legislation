{
  "legislative_session": "2026",
  "identifier": "SB2623",
  "title": "RELATING TO LICENSING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Age",
    "Board of Pharmacy",
    "Certificates of Registration",
    "Registered Pharmacy Technicians",
    "Renewal"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Specifies that registered pharmacy technicians must be at least sixteen years old.  Clarifies that registered pharmacy technicians shall be at least eighteen years old and meet other certain requirements to administer vaccinations.  Authorizes the Board of Pharmacy to renew certificates of registration for registered pharmacy technicians.  Clarifies renewal requirements and forfeiture and restoration provisions for certificates of registration.  (CD1)"
    }
  ],
