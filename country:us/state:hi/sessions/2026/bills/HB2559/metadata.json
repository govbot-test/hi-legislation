  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires a licensed real estate broker or salesperson to provide written disclosure to the seller when marketing residential real property through a private or off-market listing.  Includes failure to provide the written disclosure as grounds for disciplinary action against a licensed real estate broker or salesperson.  Effective 7/1/3000.  (HD1)"
    }
  ],
