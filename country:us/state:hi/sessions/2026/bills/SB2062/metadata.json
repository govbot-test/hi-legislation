{
  "legislative_session": "2026",
  "identifier": "SB2062",
  "title": "RELATING TO THE HAWAII HOUSING FINANCE AND DEVELOPMENT CORPORATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Dwelling Unit Revolving Fund",
    "Dwelling Unit Revolving Fund Equity Program",
    "HHFDC"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Dwelling Unit Revolving Fund Equity Program as a permanent program to be administered by the Hawaii Housing Finance and Development Corporation.  Authorizes the Hawaii Housing Finance and Development Corporation to purchase equity in for-sale housing development projects for qualified residents of the State using moneys in the Dwelling Unit Revolving Fund to lower the initial purchasing price.  Establishes equity repayment requirements.  Effective 6/29/2050."
    }
  ],
