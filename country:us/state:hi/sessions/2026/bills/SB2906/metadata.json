  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Tourism Liaison Officer position within the Office of the Governor.  Amends the duties of the Hawaii Tourism Authority to focus on marketing and branding, rather than destination management and regenerative tourism.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
