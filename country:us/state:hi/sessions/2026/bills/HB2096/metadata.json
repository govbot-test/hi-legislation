{
  "legislative_session": "2026",
  "identifier": "HB2096",
  "title": "RELATING TO AGGRAVATED CIRCUMSTANCES IN CHILD PROTECTIVE PROCEEDINGS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Aggravated Circumstances Hearings",
    "Child Protective Proceedings",
    "Family Courts",
    "Judiciary Package"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies and expands procedures for aggravated circumstances determinations in Child Protective Act proceedings.  Authorizes the Family Court to make a finding of aggravated circumstances at any stage of a Child Protective Act proceeding before the termination of parental rights, rather than limiting these findings to the return hearing.  Incorporates the definition of torture under the Penal Code for purposes of defining aggravated circumstances involving child torture under the Child Protective Act.  (SD1)"
    }
  ],
