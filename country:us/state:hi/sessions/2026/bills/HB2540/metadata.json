{
  "legislative_session": "2026",
  "identifier": "HB2540",
  "title": "RELATING TO LAW ENFORCEMENT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Immigration Enforcement",
    "Facial Coverings",
    "Law Enforcement Agencies",
    "Law Enforcement Officers",
    "Visible Identification"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits with certain exceptions, the use of facial coverings and requires visible identification by law enforcement officers and their vehicles in the performance of their duties.  Requires state and county law enforcement agencies to establish policies regarding state and county cooperation with federal civil immigration enforcement.  Prohibits law enforcement officers from prolonging a stop to inquire about a person's civil immigration status.  Establishes criminal offenses for use of a mask or facial covering by a law enforcement officer, lack of visible identification, and unauthorized civil immigration arrest or detention.  Effective 3/22/2075.  (SD2)"
    }
  ],
