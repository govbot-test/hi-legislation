{
  "legislative_session": "2026",
  "identifier": "SB2438",
  "title": "RELATING TO CIVIL INTERFERENCE WITH CONSTITUTIONAL AND STATUTORY RIGHTS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AG",
    "Civil Remedies",
    "Constitutional and Statutory Rights",
