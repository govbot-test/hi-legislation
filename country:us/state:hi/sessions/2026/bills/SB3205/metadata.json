  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases from 70% to 90% the taxation rate on electronic smoking devices and e-liquid sold, used, or possessed by a wholesaler or dealer after 12/31/2026.  Provides for the deposit of the additional tax revenue into the Hawaii cancer research special fund."
    }
