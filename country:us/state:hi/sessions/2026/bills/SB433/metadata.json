  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits any person from openly carrying a deadly or dangerous weapon.  Includes bladed weapon in the list of deadly or dangerous weapons.  Establishes an affirmative defense to a prosecution for the purposes of lawful self-defense and transporting a weapon."
    }
  ],
