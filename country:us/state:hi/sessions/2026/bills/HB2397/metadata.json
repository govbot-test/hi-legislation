{
  "legislative_session": "2026",
  "identifier": "HB2397",
  "title": "RELATING TO SCHOOL FACILITIES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Capacity",
    "Charter Schools",
    "Pre-Kindergarten",
    "School Facilities Special Fund",
    "School Impact Fees",
    "Transfer"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Transfers school impact fees from the Kalihi-Ala Moana school impact district to the School Impact Fees subaccount of the School Facilities Special Fund for the acquisition and renovation of one or more buildings, or the acquisition of land and construction of a new building, in the 96813 zip code to develop and expand pre-kindergarten and charter school capacity.  Provides that the funds appropriated and expended shall be used to serve students residing within the Kalihi-Ala Moana school impact district, with certain exceptions.  Effective 7/1/3000.  (SD1)"
    }
  ],
