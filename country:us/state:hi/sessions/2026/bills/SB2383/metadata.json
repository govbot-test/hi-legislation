  "subject": [
    "Appropriation ($)",
    "DLE",
    "Retention Bonus"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Law Enforcement to provide $15,000 retention bonuses to all eligible sworn law enforcement officers who meet specified requirements.  Requires the Department of Law Enforcement to verify eligibility.  Appropriates funds for the payment of retention bonuses."
    }
  ],
