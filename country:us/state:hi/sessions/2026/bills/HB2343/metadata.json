  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals the 6/30/2027 deadline by which the Maui State Veterans Home must be assimilated into a state agency having a Maui affiliation and instead requires the assimilation to be completed as soon as practicable.  (SD1)"
    }
  ],
