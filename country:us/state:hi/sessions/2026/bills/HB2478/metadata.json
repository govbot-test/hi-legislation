  "legislative_session": "2026",
  "identifier": "HB2478",
  "title": "RELATING TO BONDS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Counties",
    "County Debt Limit Statements",
    "Housing Infrastructure Growth Bonds"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the counties to implement housing infrastructure growth bonds.  Conforms county debt limit statements law to permit counties to exclude housing infrastructure growth bonds from the debt limit of the counties if a constitutional amendment authorizing the use of housing infrastructure growth bonds and excluding housing infrastructure growth bonds from determinations of the counties' funded debt is ratified.  Effective 7/1/3000.  (HD1)"
    }
  ],
