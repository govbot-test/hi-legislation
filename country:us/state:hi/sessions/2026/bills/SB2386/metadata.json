{
  "legislative_session": "2026",
  "identifier": "SB2386",
  "title": "RELATING TO EMPLOYMENT EARNINGS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Disclosure",
    "Employment",
    "Exemption",
    "Job Listing"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that the requirement to disclose hourly rates or salary ranges on job listings applies to full-time, part-time, temporary, or seasonal employment.  Repeals the exemption for employers having fewer than fifty employees from the disclosure requirement.  Effective 7/1/3000.  (HD2)"
    }
  ],
