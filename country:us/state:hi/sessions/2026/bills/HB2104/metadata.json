{
  "legislative_session": "2026",
  "identifier": "HB2104",
  "title": "RELATING TO ISLAND BURIAL COUNCILS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Historic Preservation",
    "Island Burial Councils",
    "Office of Hawaiian Affairs Package"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Extends the time to fill vacancies that occur during an Island Burial Council member's term.  Provides per diem compensation in the form of a stipend for Island Burial Council members representing geographic regions.  Adjusts the Island Burial Councils' quorum for business to be a majority of the appointed council members, but no fewer than three members.  (CD1)"
    }
  ],
