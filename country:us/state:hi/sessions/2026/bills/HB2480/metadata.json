  "subject": [
    "Assumption of Risk",
    "Emergency Responder",
    "Evacuation",
    "Immunity"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Protects emergency responders from liability during periods of evacuation.  Provides that individuals who wilfully fail to comply with predictive evacuation orders assume the risk and waive liability.  Effective 7/1/3000.  (HD1)"
    }
  ],
