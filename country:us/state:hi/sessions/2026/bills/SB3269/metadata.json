{
  "legislative_session": "2026",
  "identifier": "SB3269",
  "title": "PROPOSING AMENDMENTS TO ARTICLE VII, SECTIONS 12 AND 13, OF THE CONSTITUTION OF THE STATE OF HAWAII TO EXPRESSLY PROVIDE THAT THE LEGISLATURE MAY AUTHORIZE THE COUNTIES TO ISSUE TAX INCREMENT BONDS AND TO EXCLUDE TAX INCREMENT BONDS FROM DETERMINATIONS OF THE FUNDED DEBT OF THE COUNTIES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Constitutional Amendment (ConAm)",
    "Tax Increment Bonds"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Proposes amendments to the Constitution of the State of Hawaii to expressly provide that the Legislature may authorize, by general law, political subdivisions, such as counties, to issue tax increment bonds and to exclude tax increment bonds in calculating the debt limit of the political subdivisions."
    }
  ],
