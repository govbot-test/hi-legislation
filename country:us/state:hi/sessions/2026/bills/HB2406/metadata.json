  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires any disposition of more than one thousand acres of public lands to governments by the Board of Land and Natural Resources to be subject to approval by a majority vote of both houses of the Legislature.  Requires the government seeking the disposition of the public land to submit for introduction to the Legislature a resolution containing certain information.  Requires a copy of the draft resolution to be sent to the Office of Hawaiian Affairs."
    }
  ],
