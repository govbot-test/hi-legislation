  ],
  "subject": [
    "Compassionate Release",
    "Department of Corrections and Rehabilitation",
    "Hawaii Paroling Authority",
    "Working Group ($)"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a protocol for compassionate release for certain ill or seriously debilitated incarcerated persons.  Establishes a temporary working group within the Department of Corrections and Rehabilitation to develop initial administrative rules to implement the protocol.  Effective 7/1/3000.  (HD1)"
    }
  ],
