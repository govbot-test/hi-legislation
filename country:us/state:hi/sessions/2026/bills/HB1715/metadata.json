  "legislative_session": "2026",
  "identifier": "HB1715",
  "title": "RELATING TO AFFORDABLE HOUSING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Criteria",
    "Hawaii Housing Finance and Development Corporation",
    "Permanently Affordable For-Sale Housing",
    "Resale Restrictions"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes HHFDC to designate certain for-sale units as permanently affordable housing, subject to certain restrictions.  Clarifies that certain resale and occupancy restrictions apply only to projects developed prior to a certain date.  Amends the definition of \"qualified resident\" for the purposes of HHFDC housing development programs.  Effective 7/1/3000.  (SD1)"
    }
  ],
