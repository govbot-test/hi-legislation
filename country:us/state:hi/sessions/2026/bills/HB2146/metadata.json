  "identifier": "HB2146",
  "title": "RELATING TO SUGAR-SWEETENED BEVERAGES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advisory Committee",
    "Appropriation ($)",
    "Department of Health",
