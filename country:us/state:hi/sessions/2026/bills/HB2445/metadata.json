  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Education to develop, adopt, and implement a standardized emergency response plan governing immigration enforcement activity at or within one thousand feet of public schools and adopt policies and procedures to address immigration enforcement activity at certain school-related location and events.  Effective 7/1/3000.  (HD1)"
    }
  ],
