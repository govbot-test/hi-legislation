  "abstracts": [
    {
      "note": "description",
      "abstract": "Removes the barrier requiring applicants for professional or vocational licensing to be United States citizens, United States nationals, or persons with work visas.  Allows applicants to provide individual tax identification numbers in lieu of social security numbers if all other requirements are met."
    }
  ],
