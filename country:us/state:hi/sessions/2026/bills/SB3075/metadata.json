  "abstracts": [
    {
      "note": "description",
      "abstract": "Permanently exempts specified positions of the Department of the Attorney General and its administratively attached Hawaii Correctional System Oversight Commission from civil service (chapter 76, HRS) and, for certain positions where the exemption from collective bargaining under chapter 89, HRS, may be unclear, to expressly provide the exemption.  Makes housekeeping amendments to section 28-10.5(b), HRS."
    }
  ],
