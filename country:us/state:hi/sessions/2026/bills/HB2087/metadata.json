  "abstracts": [
    {
      "note": "description",
      "abstract": "Maintains the petty misdemeanor offense of abuse of family or household member by repealing the sunset of amendments made to sections 709-906 and 853-4, HRS, by Act 19, SLH 2020.  Repeals provisions authorizing a deferred acceptance of a guilty plea for misdemeanor and petty misdemeanor abuse of family or household members offenses."
    }
  ],
