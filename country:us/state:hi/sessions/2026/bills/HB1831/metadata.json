  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes and provides funding for the Department of Agriculture and Biosecurity, in coordination with relevant state agencies, to identify and, if legally permissible, resolve survey deficiencies and wastewater compliance issues on non-agricultural park lands.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
