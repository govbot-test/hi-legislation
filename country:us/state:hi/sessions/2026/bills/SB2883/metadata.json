  "identifier": "SB2883",
  "title": "RELATING TO BUILDING CODES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Apartment Buildings",
    "Category 3",
    "Category 5",
    "Hurricanes",
    "Residential Safe Rooms",
    "Single Family Residences"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires all single family residences and apartment buildings built after 1/1/2027 include a safe room that can withstand winds of two hundred miles per hour or higher.  Requires single\u2011family residences and apartment buildings built after 1/1/2027 be built to withstand Category 3 hurricanes when located in an area with winds of one hundred thirty miles per hour and a Category 5 hurricane when located in an area with winds of one hundred forty miles per hour or higher."
    }
  ],
