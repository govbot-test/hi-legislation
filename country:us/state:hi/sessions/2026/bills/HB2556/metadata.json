  "subject": [
    "Appropriation ($)",
    "Education",
    "Emergency Preparedness",
    "School Safety"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the department of education to equip all classroom doors with interior locks, maintain a public address system, feature an emergency access route, and maintain fire alarms.  Mandates the establishment of a school emergency management plan.  Requires schools to conduct regular testing and emergency preparedness drills.  Appropriates funds."
    }
  ],
