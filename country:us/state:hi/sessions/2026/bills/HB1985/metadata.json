{
  "legislative_session": "2026",
  "identifier": "HB1985",
  "title": "RELATING TO CESSPOOLS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation",
    "Cesspools",
    "Conversion",
    "Extensions",
    "Goal",
    "Mandatory Upgrade",
    "Public Outreach and Education",
    "or Connection"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "PART II:  Allows certain extensions of the deadline for cesspool conversions.  Establishes a goal for the Department of Health to prioritize the upgrade, conversion, or connection of cesspools that pose the highest risk to human health or the environment.  PART III:  Authorizes and appropriates funds to the Department of Health to retain qualified consultants as necessary to identify necessary public outreach and education resources and tools and develop a comprehensive public outreach strategy and website to educate property owners and wastewater industry professionals about information and resources regarding the State's cesspool upgrade, conversion, and connection requirements and deadlines.  Effective 7/1/3000.  (HD1)"
    }
  ],
