{
  "legislative_session": "2026",
  "identifier": "HB1718",
  "title": "RELATING TO HOUSING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Affordable Housing",
    "County Powers",
    "HHFDC",
    "Mixed-Use Developments",
    "Sunset"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Limits mixed-use developments to transit-oriented developments.  Repeals the sunset date of Act 45, SLH 2024, thereby making permanent the authority of the counties to share in facilitating the development, construction, financing, refinancing, or other provision of mixed-use developments, including low- and moderate-income housing projects, and issue county bonds before 7/1/2033 for this purpose.  (CD1)"
    }
  ],
