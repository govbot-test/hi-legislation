  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Business, Economic Development, and Tourism to study the impacts of the incremental minimum wage increases pursuant to Act 114, SLH 2022, on businesses and other employers.  Requires a report to the Legislature.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
