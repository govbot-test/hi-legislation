  "abstracts": [
    {
      "note": "description",
      "abstract": "For purposes of registering a condominium project in an agricultural district, (1) lowers the threshold from projects with five units to projects with two units for which a signed statement from a county is required and (2) requires a signed statement from the neighborhood board, if applicable."
    }
  ],
