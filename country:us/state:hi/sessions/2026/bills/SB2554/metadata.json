  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a joint legislative Long-Term Care Financing Advisory Commission to examine the feasibility of different financing options for long-term care services and supports.  Permits the Commission, through the Legislative Reference Bureau, to contract for services of a part-time project director and prepare proposals for contracts for consultants to support the work of the Commission.  Requires the Commission to submit reports to the Legislature.  Appropriates funds."
    }
  ],
