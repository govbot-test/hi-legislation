  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the position of the Hawaii Invasive Species Council Executive Director.  Appropriates funds to the Department of Land and Natural Resources, rather than the Department of Agriculture and Biosecurity, for the HISC for fiscal year 2026-2027.  Requires a report to the Legislature.  Effective 7/1/2050.  (SD1)"
    }
  ],
