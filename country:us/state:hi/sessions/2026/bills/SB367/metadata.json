  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits the issuance of a certificate of inspection for a moped or motor vehicle that has been altered, installed, or otherwise modified in any way which will noticeably increase the noise emitted by the motor vehicle or moped above that emitted by the motor vehicle or moped as equipped from the factory."
    }
  ],
