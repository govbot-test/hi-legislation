  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 7/1/27, increases the number of required accessible and van accessible parking spaces in parking lots with more than twenty-five parking spaces that are covered by title II or III of the Americans with Disabilities Act with certain expectations.  Effective 1/30/2050.  (SD1)"
    }
  ],
