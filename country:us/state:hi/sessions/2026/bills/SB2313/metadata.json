  "identifier": "SB2313",
  "title": "RELATING TO PUBLIC FINANCING FOR CANDIDATES TO ELECTED OFFICE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Campaign Spending Commission",
    "Comprehensive Public Funding",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a comprehensive system of public financing for all candidates seeking election to state and county public offices in the State, to begin with the 2028 general election year.  Requires the Campaign Spending Commission to submit reports to the Legislature.  Appropriates funds.  Effective 3/22/2075.  (SD1)"
    }
  ],
