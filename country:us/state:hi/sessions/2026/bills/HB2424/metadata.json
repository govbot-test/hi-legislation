  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Between 7/1/2026 and 12/31/2028, authorizes each county planning agency to petition the Land Use Commission for a district boundary amendment to reclassify certain lands within the agricultural district to the rural district through the district boundary amendment process.  Repeals 12/31/2028.  Effective 7/1/3000.  (HD2)"
    }
  ],
