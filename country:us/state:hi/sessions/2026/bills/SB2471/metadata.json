{
  "legislative_session": "2026",
  "identifier": "SB2471",
  "title": "RELATING TO THE POWERS OF ARTIFICIAL PERSONS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AG",
    "Agricultural Cooperative Associations",
    "Ballot-Issue Activities",
    "Business Entities",
    "Consumer Cooperative Associations",
    "Corporations",
    "DCCA",
    "Election Activities",
    "Limitations",
    "Limited Liability Companies",
    "Limited Liability Partnerships",
