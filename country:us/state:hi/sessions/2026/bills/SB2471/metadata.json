    "Limited-Equity Housing Cooperatives",
    "Nonprofit Corporations",
    "Penalties",
    "Professional Corporations",
    "State-Chartered Credit Unions"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Reaffirms that artificial persons created under state law possess only those powers that are necessary or convenient to carry out lawful purposes, and that those powers do not include the power to spend money or contribute anything of value to influence elections or ballot measures.  Authorizes the Attorney General and the Director of Commerce and Consumer Affairs to impose certain penalties for violations.  Effective 7/1/2027.  (CD2)"
    }
  ],
