  "identifier": "HB2613",
  "title": "RELATING TO HEMP.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Cannabinoids Drink Products",
    "Hemp",
    "Penalties",
    "Sale"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Permits the sale of commercial drink products that contain no more than 10 milligrams of hemp-derived cannabinoids to persons twenty-one years of age or older.  Establishes penalties for the sale or furnishing of cannabinoid drink products to, and the purchase or possession of cannabinoid drink products by, persons under twenty-one years of age."
    }
  ],
