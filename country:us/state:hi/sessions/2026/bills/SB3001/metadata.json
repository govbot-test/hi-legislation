{
  "legislative_session": "2026",
  "identifier": "SB3001",
  "title": "RELATING TO ARTIFICIAL INTELLIGENCE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AI Companions",
    "Artificial Intelligence",
    "Attorney General",
    "DCCA",
    "DOH",
