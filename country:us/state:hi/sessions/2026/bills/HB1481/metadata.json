{
  "legislative_session": "2026",
  "identifier": "HB1481",
  "title": "RELATING TO HUMAN REMAINS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Burial-transit Permit",
    "Cemetery",
    "Crematory",
    "DOH",
    "Disposition of Remains",
    "Funeral Establishment",
    "Hydrolysis Facility",
    "Mortuary"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires any cemetery, crematory, funeral establishment, hydrolysis facility, or mortuary to dispose of the remains of a dead human body no later than sixty days from the later of either the date a burial\u2011transit permit has been issued or the date of an affidavit for amendment of the permit has been submitted.  (CD1)"
    }
  ],
