  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Hawaii Emergency Management Agency to convert temporary special project positions created for Federal Emergency Management Agency funded disaster recovery operations into permanent positions exempt from civil service, subject to certain limitations.  Effective 7/1/3000.  (HD2)"
    }
