  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Education to make available all public school outdoor facilities and grounds on Saturdays and Sundays for public and community use without the need for any license, permit, or deposit of fees, under certain conditions.  Requires reports to the Legislature.  Repeals on 6/30/2030."
    }
  ],
