  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the maximum contribution and carryover amounts for a public service flexible spending account plan to be set annually in accordance with the maximum amounts allowed under section 125 of the Internal Revenue Service Code.  Effective 7/1/2027.  (CD1)"
    }
  ],
