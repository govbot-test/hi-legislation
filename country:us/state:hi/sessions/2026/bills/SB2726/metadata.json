  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a two-year Youth Ride Free Pilot Program within the Department of Transportation.  Specifies that certain Program administrative costs incurred by the counties are eligible for reimbursement from the State.  Requires a report to the Legislature.  Appropriates funds.  Sunsets 6/30/2028."
    }
