{
  "legislative_session": "2026",
  "identifier": "SB3261",
  "title": "RELATING TO ATHLETE AGENTS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agent Contract",
    "Athlete Agents",
    "Endorsement",
    "Image",
    "Name",
    "Professional Representation",
    "Registration",
    "Student Athletes",
    "and Likeness"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits any person from providing advisory, negotiation, or procurement assistance to or on behalf of a student athlete relating to endorsements; promotional or marketing services; appearances; autographs; social media branding; content creation or distribution; licensing of publicity rights; brand development, sponsorship, or promotional arrangements; or agreements related to the name, image, or likeness of the student athlete, without being a registered athlete agent in the State and having a valid agency contract executed in compliance with applicable law.  (SD1)"
    }
  ],
