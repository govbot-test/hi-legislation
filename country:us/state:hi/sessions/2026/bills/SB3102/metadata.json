  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies the consulting role and responsibilities of the Department of Transportation in the Department of Commerce and Consumer Affairs' development and implementation of port pilot licensure standards, requirements, and criteria.  Repeals Port Allen from the list of designated pilotage waters.  (HD2)"
    }
  ],
