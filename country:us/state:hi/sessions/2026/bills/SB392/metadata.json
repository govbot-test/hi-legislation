  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the definition of electric bicycles subject to various state laws and classifies electric bicycles by top assisted speed.  Establishes additional regulations for the registration and use of electric bicycles.  Increases the minimum age to operate an electric bicycle."
    }
  ],
