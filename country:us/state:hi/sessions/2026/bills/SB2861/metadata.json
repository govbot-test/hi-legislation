{
  "legislative_session": "2026",
  "identifier": "SB2861",
  "title": "RELATING TO THE OFFICE OF WELLNESS AND RESILIENCE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administering Agency",
