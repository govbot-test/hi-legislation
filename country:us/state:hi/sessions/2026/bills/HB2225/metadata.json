  "identifier": "HB2225",
  "title": "RELATING TO HEALTH.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Beneficiaries",
    "Cost Sharing",
    "Deductibles",
    "Pass-Through Pricing",
    "Pharmacy Benefit Managers",
    "Prescription Drug Benefit Plans",
    "Providers",
