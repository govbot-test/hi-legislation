  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires applicants for rental housing revolving fund moneys to be either organizations that are required to use all financial surplus, excluding fees, to develop additional housing in the State, or government agencies.  Effective 7/1/2050."
    }
  ],
