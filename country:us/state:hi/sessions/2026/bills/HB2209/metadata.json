{
  "legislative_session": "2026",
  "identifier": "HB2209",
  "title": "RELATING TO HEALTH INSURANCE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Anti-Assignment Clause",
    "Assignment of Benefits",
    "Enforcement",
    "Substance Use Disorder Services",
    "Treatment Provider"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires health insurance carriers to honor a patient's written assignment of benefits to a substance use disorder treatment provider.  Prohibits health insurance contracts from including anti-assignment clauses that restrict or invalidate a patient's right to assign benefits.  Authorizes the Insurance Commissioner to adopt rules and take enforcement action to ensure compliance.  Requires the Insurance Commissioner to publish an annual summary.  Allows providers to bring civil actions to compel payment and obtain injunctive relief, damages, interest, and attorneys' fees for violations.  Deems violations to be unfair methods of competition and unfair or deceptive acts or practices.  Requires insurers to furnish an explanation of benefits to the assigned provider upon request."
    }
  ],
