  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Land and Natural Resources to adopt rules regarding safe and humane hunting practices of feral pigs and hunting dog welfare standards.  Establishes requirements for the hunter education program instruction.  Includes the use of dogs to torture wildlife or game mammals as torture in the second degree.  Effective 7/1/2050.  (SD1)"
    }
  ],
