  ],
  "subject": [
    "Appropriation ($)",
    "Campaign Spending Commission Package",
    "Partial Public Financing"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases the expenditure limit and the amount of partial public campaign financing available for all elective offices.  Adjusts the minimum amount of qualifying contributions certain candidates must receive to participate in the program.  Increases the matching fund payments for excess qualifying contributions.  Appropriates funds for the program.  Effective 7/1/3000.  (HD1)"
    }
  ],
