  "abstracts": [
    {
      "note": "description",
      "abstract": "Reduces condominium associations' cash flow plans from a thirty-year projection to a twenty-five-year projection of the association's future income and expenses to fully fund its replacement reserves requirements each year during that twenty-five-year period."
    }
  ],
