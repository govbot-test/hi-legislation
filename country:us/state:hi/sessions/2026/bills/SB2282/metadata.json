  "legislative_session": "2026",
  "identifier": "SB2282",
  "title": "RELATING TO INSURER PRIOR AUTHORIZATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Health Insurance",
    "Medical Insurance",
    "Medicare",
    "Prior Authorization"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Prior Authorization Committee to specify medical conditions for which prior authorization by the insurer for treatment is not required for health insurance coverage.  Requires health plan insurers to align their prior authorization processes for other conditions with Medicare policies."
    }
  ],
