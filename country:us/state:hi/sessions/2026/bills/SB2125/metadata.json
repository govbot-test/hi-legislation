{
  "legislative_session": "2026",
  "identifier": "SB2125",
  "title": "RELATING TO TEACHER LICENSING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Charter Schools",
    "DOE",
    "Emergency Hires",
    "Exemptions",
    "Licensure Progress",
    "Teacher Licensing"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows the Department of Education and charter schools to hire unlicensed individuals as teachers on an emergency basis for five, rather than three, years.  Requires that unlicensed teachers hired on an emergency basis make continuous and verifiable progress toward satisfying licensing requirements.  Sunsets on 6/30/2031, but provides that unlicensed emergency hires employed before the sunset date may continue employment for up to five years from their hiring date, under certain conditions.  (CD1)"
    }
  ],
