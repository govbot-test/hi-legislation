  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Education to establish a student bus fare rate system that includes free bus passes for students whose household qualifies the student for free lunch or reduced price lunch under the free and reduced price lunch program.  Requires reports to the Legislature.  Appropriates funds."
    }
  ],
