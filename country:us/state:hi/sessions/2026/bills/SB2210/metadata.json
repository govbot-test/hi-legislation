  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows the Hawaii Civil Rights Commission to prosecute discrimination based on source of income in housing cases.  Clarifies penalties.  Establishes a position.  Appropriates funds.  (SD1)"
    }
