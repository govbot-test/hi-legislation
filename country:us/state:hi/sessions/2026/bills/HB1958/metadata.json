  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes, for a county with a population greater than three hundred thousand, enforcement procedures to prevent domiciling or storing of personal property on public property within a bus stop area, if a person does not intend to use the public transportation services.  Effective 7/1/3000.  (HD1)"
    }
  ],
