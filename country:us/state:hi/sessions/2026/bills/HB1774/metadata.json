  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires and appropriates funds for the Hawaii Climate Change Mitigation and Adaptation Commission to develop, implement, and maintain a centralized resource website to connect residents to support and resources to address affordability, health, safety, and the impacts of climate change.  Effective 7/1/3000.  (SD1)"
    }
  ],
