  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals a provision in Act 4, Special Session Laws of Hawaii 2005, that prohibits the Department of Human Services from taking any action to remove pharmaceutical benefits management from managed care plans that provide health care coverage for Hawaii Medicaid beneficiaries.  Effective 7/1/3000.  (HD1)"
    }
  ],
