{
  "legislative_session": "2026",
  "identifier": "SB2876",
  "title": "RELATING TO NATURAL HAIR BRAIDING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Board of Barbering and Cosmetology",
    "Exemption from Licensure",
    "Health",
    "Natural Hair Braiding",
    "Registration",
    "Sanitation",
    "and Safety Practices"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 1/1/2028, requires natural hair braiders to be registered, rather than licensed, under the Board of Barbering and Cosmetology.  By 11/1/2026, requires the Board to adopt rules prescribing the approved courses or programs that cover sanitation, health, and safety practices required for natural hair braiding registration.  (CD1)"
    }
  ],
