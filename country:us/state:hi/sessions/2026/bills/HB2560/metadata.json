  "legislative_session": "2026",
  "identifier": "HB2560",
  "title": "RELATING TO HOMELESSNESS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DHS",
    "DOE",
    "Financial Stabilization Assistance",
    "Homelessness",
    "Pilot Program",
    "Temporary Assistance for Needy Families"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a two-year-pilot program within the Department of Human Services to provide temporary financial stabilization assistance to families with students identified as experiencing homelessness.  Funds the program through the Department of Human Services using allowable Temporary Assistance for Needy Families funds.  Requires Department of Education Complex Area Community Homeless Concerns Liaison to make approved purchases.  Effective 7/1/3000.  (HD2)"
    }
  ],
