  "abstracts": [
    {
      "note": "description",
      "abstract": "For taxable years beginning after 1/1/2027, establishes a nonrefundable income tax credit for certain agricultural investment costs incurred for agricultural activities conducted on Hawaiian home lands.  Effective 7/1/2050.  (SD1)"
    }
