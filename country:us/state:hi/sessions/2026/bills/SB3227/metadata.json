  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Hawaii Technology Development Corporation to establish state goals and implement projects to advance economic diversification through innovation and technology.  Appropriates funds to support the Hawaii Small Business Innovation Research Program, Manufacturing Assistance Program, and accelerator and small business training programs.  Requires annual reports to the Legislature.  Effective 7/1/2050.  (SD1)"
    }
  ],
