  ],
  "subject": [
    "Increase",
    "Research Activities",
    "Tax Credit"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the research activity tax credit so that references to the base amount in section 41 of the Internal Revenue Code shall not apply and credit for all qualified research expenses may be taken without regard to the amount of expenses for previous years.  Increases the annual aggregate cap for the research activity tax credit."
    }
  ],
