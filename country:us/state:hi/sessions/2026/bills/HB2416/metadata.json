  "legislative_session": "2026",
  "identifier": "HB2416",
  "title": "RELATING TO A MARITIME YOUTH APPRENTICESHIP PATHWAY PROGRAM.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Maritime Youth Apprenticeship Pathway Program",
    "Report",
    "Study",
    "UH",
    "University of Hawaii Community College System",
    "Workforce Development"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Directs the University of Hawaii Community College System, in partnership with state agencies and maritime employers, to conduct a study and develop a plan for a statewide Maritime Youth Apprenticeship Pathway Program for individuals ages 16 to 24.  Requires a report to the Legislature with recommendations on program structure, resource needs, proposed legislation and implementation options.  Appropriates funds.  Effective 7/31/2055.  (SD1)"
    }
  ],
