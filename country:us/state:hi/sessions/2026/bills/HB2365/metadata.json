  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Chief Election Officer role to be an elected position by popular vote beginning with the 2030 general election.  Amends the appointment process of the elections commission to subject nominations to confirmation by an appointing body.  Makes conforming amendments."
    }
