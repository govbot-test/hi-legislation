  "subject": [
    "Automatic Voter Registration",
    "Elections",
    "Identification Cards",
    "Motor Vehicle Permits and Licenses",
    "Opt-In"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes state agencies to implement automatic voter registration if designated by the Office of Elections.  Requires eligible applicants for instruction permits, provisional licenses, driver's licenses, and identification cards to be automatically registered or preregistered to vote unless the applicant opts out.  Effective 7/1/3000.  (HD1)"
    }
  ],
