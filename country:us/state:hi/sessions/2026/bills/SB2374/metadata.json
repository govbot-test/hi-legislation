  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Blue Economy Working Group to study how to develop and support marine-based economic activities that align with the State's decarbonization and restorative food production goals.  Requires a report to the Legislature.  Effective 7/1/2050.  (SD1)"
    }
  ],
