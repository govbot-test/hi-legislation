  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies the labeling and advertising requirements for roasted coffee, instant coffee, and ready-to-drink coffee beverages based on where they were grown and processed.  Defines \"regional origin\".  Effective 7/1/2050.  (SD1)"
    }
  ],
