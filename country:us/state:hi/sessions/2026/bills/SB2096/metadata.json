  "legislative_session": "2026",
  "identifier": "SB2096",
  "title": "RELATING TO WASTEWATER MANAGEMENT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOH",
    "PFAS",
    "Perfluoroalkyl and Polyfluoroalkyl Substances",
    "Rules",
    "Testing",
    "Wastewater Management"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires certain wastewater treatment works to test sewage sludge and any other residual material intended for land application for the presence of PFAS.  Requires the Director of Health to adopt rules for the monitoring, sampling, testing, and data collection of sewage sludge and other residual material at wastewater treatment works that contain PFAS.  Effective 7/1/3000.  (HD1)"
    }
  ],
