  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 1/1/2030, prohibits the use or application of a pesticide containing 1,3-dichloropropene as an active ingredient, such as Telone.  Effective 7/1/3001.  (HD3)"
    }
