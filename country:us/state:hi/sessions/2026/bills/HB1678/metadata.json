  "identifier": "HB1678",
  "title": "RELATING TO ASSOCIATIONS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Candidates",
    "Condominium Associations",
