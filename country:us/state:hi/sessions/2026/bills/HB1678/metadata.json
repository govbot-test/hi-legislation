  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that in planned community association and condominium association elections conducted by cumulative voting, cumulative voting rights apply to all candidates, including write-ins, and that individual votes are used when allocating votes.  (CD1)"
    }
  ],
