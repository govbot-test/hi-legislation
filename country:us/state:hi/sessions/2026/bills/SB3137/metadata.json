  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Removes duplicative food-related statutory material and aligns all food-related provisions under chapter 328, HRS.  Ensures adequate statutory authority for permits, fees, inspections, and enforcement.  On 6/30/2027, repeals the Sanitation and Environmental Health Special Fund and transfers any unexpended or unencumbered balance to the newly established Food Safety and Environmental Health Special Fund.  Makes conforming amendments.  (CD1)"
    }
  ],
