{
  "legislative_session": "2026",
  "identifier": "SB3137",
  "title": "RELATING TO THE DEPARTMENT OF HEALTH'S AUTHORITY TO REGULATE FOOD, DRUGS, AND COSMETICS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Chapter 328",
    "Consolidation of Food Safety",
    "Department of Health",
    "Drugs",
    "Establishment",
