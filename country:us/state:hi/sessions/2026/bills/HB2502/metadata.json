  "identifier": "HB2502",
  "title": "RELATING TO ARTIFICIAL INTELLIGENCE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AG",
    "Artificial Intelligence",
    "Conversational Artificial Intelligence Services",
    "DCCA",
    "Disclosures",
