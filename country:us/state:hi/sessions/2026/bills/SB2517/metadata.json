  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the penalty for the unlawful possession, control, or transfer of a firearm or ammunition in violation of a valid judicial protective order or restraining order by reclassifying the offense from a misdemeanor to a class C felony.  Effective 7/1/3000.  (HD1)"
    }
  ],
