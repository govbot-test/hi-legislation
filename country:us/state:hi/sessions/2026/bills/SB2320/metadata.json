  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Kuleana AgTech Pathways Program to create career pipelines in the fields of agriculture and agricultural technology.  Requires the University of Hawaii to collaborate with the Department of Education, Department of Agriculture and Biosecurity, Agribusiness Development Corporation, Department of Labor and Industrial Relations, and appropriate community organizations to develop and administer the program.  Requires reports to the Legislature.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
