{
  "legislative_session": "2026",
  "identifier": "SB3133",
  "title": "RELATING TO PREVENTIVE MEDICINE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Child Health Supervision Services",
    "DOH",
    "EUTF",
    "Immunization",
    "Insurance",
    "Pharmacists",
    "Prevailing Medical Standards",
    "Preventive Services Coverage",
    "Recommendations",
    "Standing Orders"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Specifies that no person is subject to liability for providing clinical preventive services in accordance with Department of Health recommendations.  Requires health insurers, mutual benefit societies, health maintenance organizations, and plans issued by the Hawaii Employer-Union Health Benefits Trust Fund to provide coverage for clinical preventive services.  Authorizes the Department of Health to make recommendations relating to clinical preventive services and issue standing orders for medications and immunizations.  Clarifies that, for child health supervision services coverage, the prevailing medical standards include recommendations by the Department of Health.  Prohibits denial of coverage and prior authorization for clinical preventive services based on medical necessity.  Specifies that a registered pharmacist may order a vaccine in accordance with the recommendations from the Department of Health.  Exempts this measure from an Auditor impact assessment report.  Effective 7/1/3000.  (HD3)"
    }
  ],
