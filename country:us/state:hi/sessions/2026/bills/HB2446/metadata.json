  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Labor and Industrial Relations to establish a Community Wage Theft Enforcement Partnership Program and enter into contracts or memoranda of agreements with community-based organizations to enhance outreach, referral, and recovery of stolen wages.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
