  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides that any person who uses their property, including firearms, hunting animals, or vehicles, to hunt on private land without the permission of the owner or occupier of the land shall be subject to a fine for a first offense and have their property be subject forfeiture to the State for a second or subsequent offense.  Effective 7/1/3000.  (HD1)"
    }
  ],
