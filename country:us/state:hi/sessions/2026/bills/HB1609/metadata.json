  "identifier": "HB1609",
  "title": "RELATING TO STATE FACILITIES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advertising",
    "Concessions",
    "Convention Center",
    "Convention Center Enterprise Special Fund",
    "Hawaii Tourism Authority",
