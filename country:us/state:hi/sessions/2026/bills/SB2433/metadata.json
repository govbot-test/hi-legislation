  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands the uses of the Condominium Education Trust Fund to include educational resources for condominium unit owners in condominium governance.  Requires the Real Estate Commission to ensure the interests of condominium unit owners are represented in certain activities funded by the Condominium Education Trust Fund.  Effective 7/1/3000.  (HD2)"
    }
  ],
