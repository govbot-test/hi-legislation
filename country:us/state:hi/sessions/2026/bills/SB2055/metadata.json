  "legislative_session": "2026",
  "identifier": "SB2055",
  "title": "RELATING TO CIVIL RIGHTS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Annual Report",
    "Appropriations ($)",
    "Civil Rights Commission",
    "Civil Rights Violations",
    "Helpline",
    "Monthly Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Civil Rights Commission to establish a twenty-four-hour intake helpline to assist individuals who experience or witness civil rights violations in the State.  Requires the Civil Rights Commission to compile an annual report and hold an annual public hearing on data obtained through the helpline.  Requires the Civil Rights Commission to compile and submit to the Legislature, and post on its website, a monthly preliminary report on data obtained through the helpline.  Appropriates funds to establish an unspecified number of Civil Rights Investigator, Data Analyst, and Program Manager positions within the Civil Rights Commission.  Appropriates funds for the Civil Rights Commission to contract with Aloha United Way to implement the twenty-four-hour intake helpline and for website and data development costs.  Effective 7/1/3000.  (HD1)"
    }
  ],
