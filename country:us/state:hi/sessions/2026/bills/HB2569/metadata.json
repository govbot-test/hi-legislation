  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the display of outdoor advertising devices, including digital outdoor signage devices, to be allowed within the Waikiki Special District and requires the adoption of necessary county ordinances.  Allows the display of outdoor advertising devices, including digital outdoor signage devices, within the Stadium Development District with the authorization of the Stadium Authority."
    }
  ],
