{
  "legislative_session": "2026",
  "identifier": "SB2022",
  "title": "RELATING TO STATE WATER CODE PENALTIES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CWRM",
    "Penalties",
    "State Water Code"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Adds a minimum penalty and maximum penalty per violation of the State Water Code.  Authorizes the Commission on Water Resource Management to consider each day that a violation exists or continues to exist a separate offense.  Establishes factors the CWRM must consider when determining the amount of the penalty.  Increases maximum fines every 5 years from 2031 to 2046.  Effective 7/1/2050.  (SD1)"
    }
  ],
