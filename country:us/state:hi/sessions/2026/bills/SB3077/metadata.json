  "abstracts": [
    {
      "note": "description",
      "abstract": "Adopts the Uniform Health Care Decisions Act (2023), as modified, to replace existing chapters related to advance health care directives and advance mental health care directives.  Requires the Attorney General to convene a working group.  Requires a report to the Legislature.  Effective 1/30/2050.  Implementation effective 7/1/20209.  (SD2)"
    }
  ],
