{
  "legislative_session": "2026",
  "identifier": "HB2315",
  "title": "RELATING TO STATE EMPLOYEE BENEFITS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOH",
    "Down Payment Assistance",
    "Home Purchases",
    "Reports",
    "Vacation Payout Pilot Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Health to establish a vacation payout pilot program in which eligible Department of Health employees may defer unused vacation leave credits in favor of a pay out to provide home purchase down payment assistance.  Requires reports to the Legislature.  Sunsets 6/30/2029.  (SD1)"
    }
  ],
