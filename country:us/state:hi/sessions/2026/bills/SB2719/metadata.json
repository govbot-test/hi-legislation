  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Carbon Emissions Tax and Dividend Special Fund.  Gradually increases the Environmental Response, Energy, Carbon Emissions, and Food Security Tax and establishes a refundable income tax credit to mitigate the effect of the increased tax on taxpayers.  Requires reports to the Legislature.  Appropriates funds."
    }
  ],
