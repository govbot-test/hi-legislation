{
  "legislative_session": "2026",
  "identifier": "HB1572",
  "title": "RELATING TO AQUACULTURE DEVELOPMENT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "DAB",
    "Demonstration Sites",
    "Reports",
    "Restorative Aquaculture Advisory Council",
    "Restorative Aquaculture Development Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Agriculture and Biosecurity to:  (1) Establish a Restorative Aquaculture Development Program to reduce aquaculture permit processing time, support aquaculture infrastructure expansion, increase the aquaculture workforce, and pursue federal aquaculture grants; (2) Establish three pilot demonstration sites for restorative aquaculture; and (3) Convene a Restorative Aquaculture Advisory Council.  Requires reports to the Legislature.  Appropriates funds.  Sunsets 6/30/2030.  Effective 7/1/2050.  (SD1)"
    }
  ],
