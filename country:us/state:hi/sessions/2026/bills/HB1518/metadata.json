{
  "legislative_session": "2026",
  "identifier": "HB1518",
  "title": "RELATING TO THE SUPPLEMENTAL NUTRITION ASSISTANCE PROGRAM.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DHS",
    "Felony Drug Offenders",
    "Incarcerated Individuals",
    "Pre-Release Application Process",
    "SNAP"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "By 1/1/2028, requires the Department of Human Services, upon obtaining a federal waiver, to establish a pre-release Supplemental Nutrition Assistance Program (SNAP) application process for inmates nearing release.  Allows all individuals convicted of an offense involving the possession, use, or distribution of a controlled substance to apply for SNAP benefits, regardless of treatment status.  (CD1)"
    }
  ],
