{
  "legislative_session": "2026",
  "identifier": "HB2022",
  "title": "RELATING TO MOTOR VEHICLE REGISTRATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "County Annual Vehicle Registration Fee",
    "Reports",
    "Vehicle Weight Tax"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Specifies that the county annual vehicle registration fee shall not exceed the state annual motor vehicle registration fee for counties with a population of five hundred thousand or more.  Specifies that counties with a population of five hundred thousand or more are required to spend a certain portion of the collected revenues from county motor vehicle registration fees and weight tax on roadway repair and maintenance.  Specifies that the county annual vehicle weight tax shall not exceed the state annual vehicle weight tax for counties with a population of five hundred thousand or more.  Requires annual reports to the Legislature.  Effective 7/1/3000.  (SD1)"
    }
  ],
