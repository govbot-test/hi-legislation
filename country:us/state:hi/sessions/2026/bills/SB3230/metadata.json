  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes governmental bodies and public employees to procure project management services through non-governmental third-party contracts under certain conditions.  Appropriates funds to establish a Special Project Branch within the Public Works Division of the Department of Accounting and General Services.  Effective 7/1/3000.  (HD1)"
    }
  ],
