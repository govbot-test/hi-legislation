  "abstracts": [
    {
      "note": "description",
      "abstract": "Designates the Hawaii Symphony Orchestra as the State of Hawaii Symphony Orchestra.  Requires annual reports to the Legislature.  Exempts state funds received by the State of Hawaii Symphony Orchestra from chapter 42F, Hawaii Revised Statutes.  (SD1)"
    }
  ],
