  "identifier": "SB2547",
  "title": "RELATING TO THE COASTAL ZONE MANAGEMENT ACT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Coastal Zone Management Act",
    "Development",
    "Excluded Activities",
    "Exemption",
    "Lahaina",
    "Maui Wildfires",
    "Permitting",
    "Public Infrastructure Improvement Projects",
    "Requirements",
