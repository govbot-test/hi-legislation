  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a temporary Solid Waste Management Working Group in the Office of the Governor to examine materials management policies and programs that reduce solid waste and protect the environment, and to present a list of alternative technologies to address solid waste management.  Requires a report to the Legislature.  Repeals 6/30/2027.  Effective 7/1/2050.  (SD1)"
    }
  ],
