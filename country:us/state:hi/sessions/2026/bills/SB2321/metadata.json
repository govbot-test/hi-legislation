  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a two-year Two-Lined Spittlebug Response Pilot Program to mitigate and control the spread of the two-lined spittlebug.  Requires reports to the Legislature.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
