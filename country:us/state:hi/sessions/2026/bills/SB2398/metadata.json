  "abstracts": [
    {
      "note": "description",
      "abstract": "No later than 1/1/2029, requires each county board of water supply to publish a map of its service area and a list of service-restricted areas on their website.  Specifies a procedure for responding to certain water availability requests.  (CD1)"
    }
  ],
