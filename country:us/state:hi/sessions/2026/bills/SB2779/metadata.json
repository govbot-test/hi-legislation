{
  "legislative_session": "2026",
  "identifier": "SB2779",
  "title": "RELATING TO COCONUT TREES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Coconut Trees",
    "DAB",
    "Labeling",
    "Landscape Palms",
    "Natural Management of Coconut Rhinoceros Beetle Tax Credit",
    "Natural Pesticides",
    "Non-Pesticide Management",
    "Seed Banks"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes recognition of coconut trees as a source of food and water, and as a cultural treasure.  Requires the Department of Agriculture and Biosecurity to establish rules to allow the use of coconut tree seed banks in the State.  Requires owners or operators of property where any coconut tree is located to post and maintain a sign that clearly indicates that the coconut tree is a landscape palm.  Requires the Department of Agriculture and Biosecurity to establish labeling standards for non-consumable landscape palms.  Establishes an income tax credit for consumable coconut trees maintained through natural management practices."
    }
  ],
