  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Ombudsman's Office for Condominium Associations within the Department of Commerce and Consumer Affairs.  Updates the Condominium Property Act to integrate the role and functions of the ombudsman's office for condominium associations.  Appropriates funds from the Condominium Education Trust Fund for establishment of the Ombudsman's Office for Condominium Associations."
    }
  ],
