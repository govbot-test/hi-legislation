{
  "legislative_session": "2026",
  "identifier": "SB3069",
  "title": "RELATING TO CIVIL SERVICE EXEMPT POSITIONS WITHIN THE DEPARTMENT OF ACCOUNTING AND GENERAL SERVICES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Annual Reports",
    "Civil Service",
    "Collective Bargaining",
    "Comptroller's Office",
    "DAGS",
    "Exemptions",
    "Information Technology Modernization Efforts",
    "Special Project Branch of the Public Works Division"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Part I:  Makes conforming amendments to section 76-16(b), HRS, for positions the Department of Accounting and General Services is authorized to establish and fill pursuant to section 26\u20116(b)(9), HRS, and requires annual reports to the Legislature.  Part II:  Authorizes DAGS to establish and fill up to 3 full-time equivalent positions within its Public Works Division's Special Project Branch that shall be exempt from civil service and collective bargaining requirements as part of the State's efforts to undertake unique and specialized public works projects and requires DAGS to submit annual reports to the Legislature.  Part II:  Sunsets 12/31/2031.  (CD1)"
    }
  ],
