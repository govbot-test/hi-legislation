  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals the prohibition on the construction, modification, or expansion of a landfill unit, or any component of a landfill unit, inland of an underground injection control line in a county with a population greater than five hundred thousand.  Effective 7/1/3000.  (HD1)"
    }
  ],
