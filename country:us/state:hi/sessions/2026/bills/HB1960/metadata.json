{
  "legislative_session": "2026",
  "identifier": "HB1960",
  "title": "RELATING TO HUMAN TRAFFICKING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AG",
    "DLE",
    "Human Trafficking Awareness",
    "Penalties",
    "Reporting",
    "Rules",
    "Signage",
    "Training",
    "Transient Accommodations Sector"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of the Attorney General to develop a Human Trafficking Awareness Training Program, or approve externally developed programs, to educate and train workers in the transient accommodations sector.  Requires transient accommodations employers or transient accommodations third-party contractors to periodically provide the human trafficking awareness training to certain employees and contract workers, keep records of the training, post signage, and develop and implement a human trafficking prevention policy that includes procedures for the reporting of suspected human trafficking.  Establishes penalties.  Requires the Department of Law Enforcement to adopt rules.  (CD1)"
    }
  ],
