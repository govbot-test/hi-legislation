{
  "legislative_session": "2026",
  "identifier": "HB2583",
  "title": "RELATING TO ECONOMIC DEVELOPMENT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Credit Enhancement",
    "DBEDT",
    "Hawaii Micro-Lending Credit Enhancement Program",
    "Loan Loss Reserves",
    "Reports",
    "Small Businesses",
    "Special Fund"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Hawaii Micro-Lending Credit Enhancement Program within the Department of Business, Economic Development, and Tourism to expand micro-lending capacity by providing state\u2011funded loan loss reserves or other credit enhancement that absorbs first losses on qualified micro-loans made by participating lenders to Hawaii small businesses.  Allows borrower fees and state matching contributions to capitalize lender-held loan loss reserve accounts.  Establishes the Hawaii Micro-Lending Credit Enhancement Special Fund.  Requires annual reports to the Legislature.  Appropriates funds out of the Special Fund.  (CD1)"
    }
  ],
