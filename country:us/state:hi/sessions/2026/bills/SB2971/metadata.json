  ],
  "subject": [
    "Appropriation ($)",
    "DOH",
    "Municipal Wastewater Treatment Facilities",
    "State R-1 Water Standards"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "By 1/1/2040, requires all municipal wastewater treatment facilities owned by a State or county agency to meet state R-1 water standards.  Requires the Department of Health to adopt five-year benchmarks to ensure compliance with state R-1 water standards.  Requires the Legislature to appropriate sufficient funds.  Appropriates funds."
    }
  ],
