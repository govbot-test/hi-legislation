  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows a retirant employed as an investigator identified by the Department of Law Enforcement or Department of the Attorney General as a labor shortage or difficult-to-fill position to be rehired without reenrollment in the Employees' Retirement System and without a loss or interruption of retirement benefits, subject to certain conditions.  Requires annual reports to the Legislature to include details on the employment of retirants as investigators."
    }
  ],
