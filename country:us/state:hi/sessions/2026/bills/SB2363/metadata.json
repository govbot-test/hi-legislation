  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the counties to close or restrict public lands under the county's jurisdiction when necessary to protect public health, ensure public safety, or preserve natural or cultural resources.  Effective 7/1/3000.  (HD2)"
    }
