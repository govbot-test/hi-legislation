  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 1/1/2027, requires health insurers, mutual benefit societies, health maintenance organizations, and health plans under the State's Medicaid managed care program to provide coverage for brief cognitive assessments for individuals fifty years of age and older."
    }
