  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals the sunset date of Act 45, Session Laws of Hawaii 2024, thereby making permanent the authority of the counties to share in facilitating the development, construction, financing, refinancing, or other provision of mixed-use developments, including low- and moderate-income housing projects, and issue county bonds for this purpose."
    }
  ],
