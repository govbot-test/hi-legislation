{
  "legislative_session": "2026",
  "identifier": "HB1535",
  "title": "RELATING TO AUTOMATED EXTERNAL DEFIBRILLATORS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "911 Fund",
    "Automated External Defibrillator Devices",
    "Automated External Defibrillator Registry",
    "DOH",
    "Income Tax Credit",
    "Places of Public Accommodation",
    "Reporting"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an income tax credit for automated external defibrillator devices that are installed and placed in service in certain places of public accommodation located in the State, subject to registration requirements.  Authorizes the Department of Health to establish a statewide automated external defibrillator registry to collect and maintain certain information.  Requires the owner or operator of an automated external defibrillator located in a place of public accommodation to conduct certain maintenance.  Requires reporting of certain automated external defibrillator data to the Department of Health.  Requires the Department of Health to coordinate with certain entities.  Requires the Department of Health to request funds from the 911 Fund for the establishment and maintenance of the automated external defibrillator registry.  Effective 7/1/3000.  (SD1)"
    }
  ],
