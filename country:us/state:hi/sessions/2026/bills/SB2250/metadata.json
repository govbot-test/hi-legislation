  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the offense of promoting a controlled substance in, on, or near schools, school vehicles, public parks, or public housing projects or complexes to include homeless facilities.  Effective 7/1/3000.  (HD1)"
