  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Education to report to the Legislature on the integration of certain content into existing social studies curricula at public schools.  Establishes a one-year 100th Infantry Battalion history curriculum pilot program within certain public high schools during the 2026-2027 school year.  Requires reports to the Legislature.  (SD1)"
    }
  ],
