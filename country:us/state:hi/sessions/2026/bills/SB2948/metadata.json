{
  "legislative_session": "2026",
  "identifier": "SB2948",
  "title": "RELATING TO INSURANCE FRAUD.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "DCCA",
    "Declarations of States of Emergency",
    "Insurance Commissioner",
    "Insurance Division",
    "Insurance Fraud",
    "Insurance Fraud Investigations Branch",
    "Penalties",
    "Reports",
    "Whistleblower Protection"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits certain solicitation and inducement practices relating to insurance claims.  Establishes disaster-related insurance fraud offenses.  Broadens the scope of the offense of insurance fraud and the acts that constitute insurance fraud.  Clarifies the penalties for the offense of insurance fraud and the capabilities and operations of the Insurance Fraud Investigations Branch, including the annual report to the Legislature and the use of fraud analytics.  Reiterates protections for insurance fraud whistleblowers.  Appropriates funds.  Effective 7/1/3000.  (HD2)"
    }
  ],
