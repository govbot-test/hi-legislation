  "identifier": "SB2274",
  "title": "RELATING TO MEDICAL CANNABIS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DLE",
    "Inspection",
    "Medical Cannabis",
    "Medical Records",
    "Repeal"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals statutory language that currently authorizes the Department of Law Enforcement to:  (1) inspect a qualifying medical cannabis patient's medical records held by the health provider who issued a written certification for the qualifying patient; and (2) suspend or revoke a health provider's ability to issue written certification for medical cannabis if the provider refuses the foregoing inspection, or if the medical records do not comply with the medical use of cannabis law."
    }
  ],
