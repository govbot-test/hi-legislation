  "identifier": "SB2371",
  "title": "RELATING TO AGRIVOLTAICS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agriculture",
    "Agrivoltaics",
    "Beginning Farmers",
    "Counties",
    "DAB",
    "LUC",
    "Landowners",
    "Public Utilities Commission",
    "Renewable Energy",
    "Reports",
