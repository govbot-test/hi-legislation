{
  "legislative_session": "2026",
  "identifier": "SB2816",
  "title": "RELATING TO STATE ENTERPRISE ZONES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Comprehensive Review",
    "DBEDT",
    "DOTax",
    "Eligible Business Activity",
    "Enterprise Zones",
    "Innovation Enterprises",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands the definition of \"eligible business activity\" for the purposes of the Enterprise Zone Program to include certain research and development activities and information technology design and production services.  Authorizes the Department of Business, Economic Development, and Tourism to declare up to two census tracts in the State that contain an innovation enterprise to be designated as an enterprise zone, subject to the Governor's approval.  Requires DBEDT to conduct an in-house comprehensive review, in consultation with the Department of Taxation, of the State Enterprise Zones Program and requires a report to the Legislature.  Effective 7/1/3000.  (HD1)"
    }
  ],
