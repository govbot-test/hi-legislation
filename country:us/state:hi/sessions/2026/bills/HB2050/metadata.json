{
  "legislative_session": "2026",
  "identifier": "HB2050",
  "title": "RELATING TO PARTIAL PUBLIC FINANCING OF ELECTIONS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Campaign Spending Commission Package",
    "Partial Public Financing"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases the expenditure limit and the amount of partial public campaign financing available for all elective offices.  Adjusts the minimum amount of qualifying contributions certain candidates must receive to participate in the program.  Increases the matching fund payments for excess qualifying contributions.  Appropriates funds for the program.  Effective 11/4/2026.  (CD1)"
    }
  ],
