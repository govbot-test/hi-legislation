  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes specific deadlines within the facilitated application process to obtain a permit and requires the Department of Business, Economic Development, and Tourism to establish certain resources and processes to help streamline permit applications.  Authorizes the Department of Transportation to select projects to participate in the facilitated application process.  Effective 7/1/3000.  (HD1)"
    }
