  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Office of the State Search and Rescue Coordinator within the Office of the Governor.  Provides for the authority and duties of the State Search and Rescue Coordinator.  Designates participating agencies and their duties with regard to state search and rescue operations and training.  Establishes the Search and Rescue Special Fund.  Requires reports to the Legislature.  Appropriates funds."
    }
  ],
