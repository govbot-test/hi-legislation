  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Public Utilities Commission to conduct a proceeding to study and implement the Smart Imports Program. Establishes the Smart Imports Program and requires electric utilities to offer excess electricity to consumers during daylight hours at cost for any legal purpose beginning January 1, 2028.  Requires the Public Utilities Commission to adopt rules and establish penalties."
    }
  ],
