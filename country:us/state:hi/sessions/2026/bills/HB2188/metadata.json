  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires landlords or landlord's agents to accept comprehensive reusable tenant screening reports, if made available by an applicant, and prohibits application fees in such cases.  Establishes remedies for refusing to accept those reports.  Effective 7/1/3000.  (HD1)"
    }
  ],
