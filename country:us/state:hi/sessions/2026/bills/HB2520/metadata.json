  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that references to the base amount in section 41, Internal Revenue Code of 1986, as amended, shall not apply to the tax credit for research activities, and that the tax credit for qualified research expenses may be claimed without regard to expenses in previous years.  Increases the annual cap on the total amount of credits that may be certified by the Department of Business, Economic Development, and Tourism."
    }
  ],
