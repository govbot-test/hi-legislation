  "identifier": "SB2780",
  "title": "RELATING TO HUMAN REMAINS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Burial-transit Permit",
    "Cemetery",
    "Crematory",
    "DOH",
    "Disposition of Human Remains",
    "Funeral Establishment",
    "Hydrolysis Facility",
    "Mortuary",
    "Rules"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires any funeral establishment, mortuary, cemetery, crematory, or hydrolysis facility to dispose of the remains of a dead human body no later than sixty days from the date a burial\u2011transit permit has been issued or from the date of an affidavit for amendment of the permit has been submitted, whichever is later.  Specifies that the Department of Health is not required to include specific disposition dates on the permit.  Requires the Department to adopt rules."
    }
  ],
