  "legislative_session": "2026",
  "identifier": "HB2503",
  "title": "RELATING TO FIREWORKS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Air Delivery",
    "Civil Forfeiture",
    "Criminal Enforcement",
    "Fireworks"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes civil asset forfeiture related to fireworks offenses that constitute felonies.  Amends the definition of \"aerial device\".  Clarifies that the offense of sending or receiving fireworks or articles pyrotechnic by air delivery applies regardless of whether the offender accompanies the air delivery.  Effective 7/1/2055.  (SD2)"
    }
  ],
