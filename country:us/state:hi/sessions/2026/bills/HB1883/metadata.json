  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 1/1/2027, authorizes county lifeguards providing services at a county or state beach park to administer epinephrine auto-injectors to render emergency care to another person.  Requires the counties to approve training providers and establish standards for the use and administration of epinephrine auto-injectors.  Establishes requirements for health care providers to issue prescriptions for, and pharmacists to dispense, epinephrine auto-injectors to counties or county life guards.  Establishes certain limitations of liability."
    }
  ],
