  "identifier": "HB1883",
  "title": "RELATING TO EPINEPHRINE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Beach Parks",
    "Counties",
    "County Lifeguards",
