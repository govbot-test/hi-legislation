  "subject": [
    "DOH",
    "Denitrification Capacity",
    "Individual Wastewater Systems",
    "Nearshore Waters",
    "Shorelines"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 7/1/2027, requires newly installed or modified individual wastewater systems that are near the shoreline or on highly porous soils to include denitrification capacity.  Requires the Department of Health to reduce requirements for disposal systems connected to wastewater systems with denitrification capacity.  Effective 7/1/3000.  (HD1)"
    }
  ],
