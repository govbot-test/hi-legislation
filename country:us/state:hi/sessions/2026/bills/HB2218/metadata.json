  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Board of Land and Natural Resources to enter into community co-management agreements and establishes qualifications for eligible community co-managers.  Authorizes the disposition of public lands by a community co-management agreement.  (CD1)"
    }
  ],
