  "abstracts": [
    {
      "note": "description",
      "abstract": "Defines \"portable solar generation device\" and establishes certain requirements for their regulation and use exclusively within units in condominiums organized pursuant to Chapter 514B, HRS.  Requires the Public Utilities Commission to establish an online registration system.  Clarifies that portable solar generation devices are subject to certain approval procedures for installation in condominiums.  Requires reports to the Legislature."
    }
  ],
