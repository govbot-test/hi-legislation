  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires State departments, offices, and agencies to ensure and enforce that all arborists and other professionals in its employ, including contractors, who manage trees or lands that will impact public trees adhere to best management practices.  Effective 7/1/2525.  (SD1)"
    }
  ],
