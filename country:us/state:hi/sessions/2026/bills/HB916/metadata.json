{
  "legislative_session": "2026",
  "identifier": "HB916",
  "title": "RELATING TO THE LOW-INCOME HOUSING TAX CREDIT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Affordable Housing",
    "Low-Income Housing Tax Credit",
    "Transient Accommodations Tax"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows tax credits claimed under the State Low-Income Housing Tax Credit Program to be used to offset taxes imposed by the state transient accommodations tax law.  Specifies that tax credit amounts applied to state transient accommodations taxes be limited to state transient accommodations taxes imposed in the same county in which the qualified low-income building is located.  Makes permanent Act 129, SLH 2016.  Applies to taxable years beginning after 12/31/2027.  Effective 7/1/3000.  (SD1)"
    }
  ],
