  "legislative_session": "2026",
  "identifier": "SB521",
  "title": "RELATING TO ACCESS TO WATER ON HAWAIIAN HOME LANDS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Access to Water",
    "Agreements",
    "County Board or Department of Water Supply",
    "DHHL",
    "Hawaiian Home Lands"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Hawaiian Home Lands to work with the appropriate county board or department of water supply to provide access to potable and agricultural water on Hawaiian home lands; provided that any agreement between DHHL and that county board or department of water supply is made available to the public."
    }
  ],
