  "abstracts": [
    {
      "note": "description",
      "abstract": "Restricts the sale of liquor under temporary liquor licenses to confined and demarcated spaces not located on public streets, roads, sidewalks, or pedestrian walkways.  Applies restrictions to temporary liquor licenses granted to nonprofit organizations."
    }
