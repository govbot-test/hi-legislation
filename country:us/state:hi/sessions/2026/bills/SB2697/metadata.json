{
  "legislative_session": "2026",
  "identifier": "SB2697",
  "title": "RELATING TO TRANSPORTATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Counties",
    "DOT",
    "Enforcement",
    "Expired Registration",
    "High Occupancy Vehicle Lanes",
