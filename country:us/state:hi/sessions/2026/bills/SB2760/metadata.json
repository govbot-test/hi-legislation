  "identifier": "SB2760",
  "title": "RELATING TO INVASIVE SPECIES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "DAB",
