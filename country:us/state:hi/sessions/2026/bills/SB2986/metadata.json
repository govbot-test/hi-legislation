{
  "legislative_session": "2026",
  "identifier": "SB2986",
  "title": "RELATING TO THE LAND USE COMMISSION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "District Boundary Amendments",
    "Land Use Commission",
    "Substantial Commencement"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Land Use Commission to amend, revise, or modify a decision and order granting a district boundary amendment, or fine a petitioner, upon finding that a petitioner or its successors or assigns have not adhered to the conditions imposed by the Commission, regardless of whether there has been substantial commencement of use of the land.  Defines \"substantial commencement\".  Effective 3/22/2075.  (SD2)"
    }
  ],
