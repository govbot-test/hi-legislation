  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a position within the State Foundation on Culture and the Arts to support implementation and coordination of specialized arts programs and therapeutic arts interventions for underserved and neurodiverse populations.  Appropriates funds for the position, programs, and interventions.  Effective 7/1/3000.  (HD1)"
    }
  ],
