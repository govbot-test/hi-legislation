  "identifier": "HB2279",
  "title": "RELATING TO EXPUNGEMENT ORDERS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Expungement Orders",
    "Violations"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the expungement orders law to reflect that a person who is arrested for or charged with a crime but convicted of a violation is eligible for an expungement of their arrest record for that incident.  (CD1)"
    }
  ],
