  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits the Public Utilities Commission from approving costs of infrastructure, operations and maintenance, fuel, or other costs relating to supplying and using liquefied natural gas unless certain conditions are met.  Requires the Public Utilities Commission to consider the effect of fossil fuels on renewable energy, stranded investment risks and costs, and costs and risks of reliance on a single fuel supply or monopoly supplier when making determinations of the reasonableness of the costs pertaining to electric or gas utility system capital improvements and operations.  Effective 7/1/3000.  (HD1)"
    }
  ],
