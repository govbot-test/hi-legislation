  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Civic Education Grant Program to provide support to public middle and intermediate schools in providing civic education to students through department approved programming.  Establishes a Civic Education Trust Fund.  Requires reports to the Legislature.  Effective 7/1/2050.  (SD1)"
    }
  ],
