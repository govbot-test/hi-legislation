  "abstracts": [
    {
      "note": "description",
      "abstract": "Creates the offense of organized retail theft.  Provides penalties for organized retail theft which are increased based on value of property and leadership roles.  Creates an organized retail theft task force.  Effective 7/1/3000.  (HD1)"
    }
