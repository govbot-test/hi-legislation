  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires a Governor, Lieutenant Governor, member of the Legislature, department heads and their deputies, and any spouse or dependent child of a Governor, Lieutenant Governor, member of the Legislature, or department head and their deputies to place certain financial interests in a blind trust.  Prohibits a Governor, Lieutenant Governor, member of the Legislature, department head and their deputies, and any spouse or dependent child of a Governor, Lieutenant Governor, member of the Legislature, or department head and their deputies from acquiring certain financial interests during their term of service.  Effective 1/1/2077.  (SD1)"
    }
  ],
