  ],
  "subject": [
    "Penal Code",
    "Penalty",
    "Theft in the First Degree"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires a mandatory twelve-month minimum sentence of incarceration for a conviction of theft in the first degree when the value of the property or services stolen exceeds $250,000, whether imposed as a mandatory minimum sentence for an indeterminate term of imprisonment or as a condition of probation, in addition to any other authorized disposition such as restitution or a fine."
    }
  ],
