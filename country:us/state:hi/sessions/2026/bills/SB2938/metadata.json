  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Office of the State Search and Rescue Coordinator within the Hawaii Emergency Management Agency.  Provides for the authority and duties of the State Search and Rescue Coordinator.  Designates participating agencies and their duties with regard to state search and rescue operations and training.  Establishes the Search and Rescue Special Fund.  Requires reports to the Legislature.  Requires the Administrator of Emergency Management to hire the Coordinator by 1/1/2027.  Appropriates funds.  Effective 7/1/2525.  (SD1)"
    }
  ],
