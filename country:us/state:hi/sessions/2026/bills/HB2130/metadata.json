  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Makes any state-chartered corporation, limited liability company, limited partnership, limited liability partnership, cooperative, nonprofit, or other association lack the legal capacity to make expenditures or contributions in connection with elections or ballot measures.  Deems any election or ballot measure expenditure or contribution to be ultra vires or void as a matter of law, triggering administrative forfeiture of charter privileges, including limited liability and perpetual duration, until reinstatement.  Effective 1/1/2027."
    }
  ],
