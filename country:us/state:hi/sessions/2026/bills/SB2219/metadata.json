  "subject": [
    "Capitol Visitor Center Working Group",
    "DAGS",
    "LRB",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Capitol Visitor Center Working Group to study the feasibility of establishing a Capitol Visitor Center and submit a report to the Legislature.  Requires the Department of Accounting and General Services to provide administrative support to the Working Group.  Requires the Legislative Reference Bureau to assist the Working Group in preparing and submitting the report to the Legislature.  Working Group to sunset on 6/30/2027.  Effective 1/1/2525.  (SD1)"
    }
  ],
