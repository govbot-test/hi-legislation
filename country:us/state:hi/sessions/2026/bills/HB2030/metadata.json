  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Transportation to establish a clean vehicle rebate program to provide rebates for the purchase or lease of new and used zero-emission vehicles and plug-in hybrid electric vehicles.  Establishes the clean vehicle special fund.  Beginning 1/1/2027, establishes a transportation affordability and energy security tax.  Effective 7/1/3000.  (HD2)"
    }
  ],
