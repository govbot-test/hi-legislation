{
  "legislative_session": "2026",
  "identifier": "SB2001",
  "title": "RELATING TO THE BANYAN DRIVE COMMUNITY DEVELOPMENT DISTRICT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Banyan Drive Community Development District",
    "Banyan Drive Hawaii Redevelopment Agency",
    "HCDA",
    "Lineal Descendant",
    "New Special Fund",
    "Powers and Duties"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Banyan Drive Community Development District within the Hawaii Community Development Authority.  Establishes the Banyan Drive Community Development District Special Fund.  Specifies the powers and duties of HCDA as it relates to the District.  Amends the composition of HCDA to include representatives of the District, Chairperson of the Banyan Drive Hawaii Redevelopment Agency, and a lineal descendant of the Waiakea Ahupuaa.  Appropriates funds.  (CD1)"
    }
  ],
