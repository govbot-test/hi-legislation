  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes deaf motor vehicle owners to register their vehicle as being owned by a deaf individual so that a deafness designation appears when a law enforcement officer accesses the motor vehicle's information.  Effective 1/1/2027.  (CD1)"
    }
  ],
