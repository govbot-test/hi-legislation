  "identifier": "SB2851",
  "title": "RELATING TO DEAF INDIVIDUALS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Deaf",
    "Disability",
