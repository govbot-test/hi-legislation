  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Education to establish a climate literacy certificate program to provide students with an advanced understanding of climate change through academic coursework and hands-on learning.  Effective 7/1/3000.  (HD1)"
    }
