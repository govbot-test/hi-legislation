  "identifier": "SB2584",
  "title": "RELATING TO CRIMINAL PROCEEDINGS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Criminal Offenses",
    "Dismissal",
    "Procedure",
