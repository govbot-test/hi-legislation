  "identifier": "SB3031",
  "title": "RELATING TO THE CONVEYANCE TAX.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Beach Preservation and Restoration Special Fund",
    "Coastal Zone Management",
    "Conveyance Tax",
    "Natural Resource Protection",
    "Property Acquisition",
    "Special Subaccount"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Renames the Beach Restoration Special Fund as the Beach Preservation and Restoration Fund.  Establishes the Special Subaccount of the Special Fund.  Requires that all conveyance tax revenues collected from the conveyance or transfer of real property located in whole or in part in a sea level rise exposure area be deposited into the special subaccount of the Special Fund.  Allows funds in the special subaccount of the Special Fund to be used to acquire property.  Effective 7/1/2050.  (SD1)"
    }
  ],
