{
  "legislative_session": "2026",
  "identifier": "HB1885",
  "title": "RELATING TO STANDARDS OF CONDUCT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Contracts",
    "Disqualification",
    "Ethics",
    "Relatives and Household Members of Directors and Deputy Directors"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits a state agency from entering into any contract to procure or dispose of goods or services, or for construction, with any business that is owned or operated, or in which a controlling interest is held, by a relative or household member of a director or deputy director of a principal state department."
    }
  ],
