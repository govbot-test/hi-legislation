  "identifier": "SB2394",
  "title": "RELATING TO TAXES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "General Excise Tax",
    "Rental Motor Vehicles",
    "Teacher Temporary Hazard Pay Special Fund",
    "Use Tax"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Excludes the sale of a motor vehicle to a lessor of rental motor vehicles for use as a rental motor vehicle as a sale at wholesale.  Imposes the maximum allowable excise tax on the use of tangible personal property in the State for the importation or purchase of a motor vehicle by a lessor of rental motor vehicles for use as a rental motor vehicle.  Establishes a Teacher Temporary Hazard Pay Special Fund to pay a temporary hazard pay bonus to certain eligible teachers.  Beginning 7/1/2026 until 7/1/2030, deposits the additional tax revenue generated by this Act into the Teacher Temporary Hazard Pay Special Fund."
    }
  ],
