  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Cooperative Development Program within the Department of Business, Economic Development, and Tourism to award grants to support the establishment of new cooperatives in the State.  Requires the Department to adopt rules.  Requires annual reports to the Legislature.  Appropriates funds.  Sunsets 6/30/2031."
    }
  ],
