  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes conditions under which archaeological inventory surveys and reconnaissance surveys are required.  Establishes conditions under which archaeological permits may be issued and revoked and the practice of archaeology may be temporarily revoked.  Modifies the composition and operations of island burial councils.  Modifies procedures upon the inadvertent discovery of burial sites.  Effective 7/1/2050.  (SD1)"
    }
  ],
