  "identifier": "HB2533",
  "title": "RELATING TO EDUCATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Additional Benefits or Credits",
    "Appropriation ($)",
    "DOE",
    "Teachers"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Education to provide additional benefits to:  (1) teachers with special assignments where their duties and responsibilities are greater than their ordinary duties and responsibilities; (2) teachers in Hawaiian language medium education whose responsibilities are greater or unique and require additional language skills; and (3) teachers at special needs schools.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
