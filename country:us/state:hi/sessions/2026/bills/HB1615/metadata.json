  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Declares that the State is an ocean cluster.  Establishes the Office of Marine Affairs within the Hawaii Technology Development Corporation for administrative purposes only.  Establishes and appropriates funds for the Marine Affairs Coordinator position.  Requires the Marine Affairs Coordinator to submit annual reports to the Governor and Legislature.  Transfers the functions of the Governor's Advisory Committee on Marine Affairs to the Office of Marine Affairs.  Appropriates funds for the Office of Marine Affairs to procure the services of a consultant to support the marine affairs declaration of intent.  Effective 7/1/3050.  (SD1)"
    }
  ],
