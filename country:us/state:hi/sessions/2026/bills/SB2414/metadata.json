  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Disability and Communication Access Board to study the health care communication needs of patients who are deaf, hard-of-hearing, or deaf-blind.  Requires a report to the Legislature 20 days prior to the 2027 Regular Session."
    }
  ],
