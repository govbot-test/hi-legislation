{
  "legislative_session": "2026",
  "identifier": "HB1663",
  "title": "RELATING TO REIMBURSEMENT OF PUBLIC OFFICERS AND EMPLOYEES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Interest Owed",
    "Public Employees",
    "Reimbursement",
    "Travel Costs"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the State or a county to reimburse an officer or employee for work-related travel costs that the officer or employee loaned to the State or a county within thirty calendar days of submitting an approved statement of completed travel.  Requires the State or a county to pay interest on a loan not reimbursed within thirty calendar days until the loan is fully reimbursed.  Obligates an officer or employee to request a complete refund from the travel vendor for travel not taken for good cause.  Entitles an officer or employee to reimbursement from the State or a county when a travel vendor offers a partial refund or no refund.  Effective 1/1/2077.  (SD1)"
    }
  ],
