  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Fuel Tank Advisory Committee to hold at least one regular meeting during each calendar quarter.  Requires the Advisory Committee to hold one regular meeting each year that convenes outside of normal business hours.  Appropriates funds. Effective 7/1/2050.  (SD1)"
    }
  ],
