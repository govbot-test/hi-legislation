  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases the age of an individual who is required to wear a helmet for electric foot scooters and bicycles.  Prohibits a person from operating any class of electric bicycle or electronic micro-mobility device unless that person wears a helmet.  Effective 7/1/3000.  (HD1)"
    }
  ],
