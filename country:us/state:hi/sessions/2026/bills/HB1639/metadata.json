{
  "legislative_session": "2026",
  "identifier": "HB1639",
  "title": "RELATING TO NOTARIES PUBLIC.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Bureau of Conveyances",
    "Fraudulently Notarized Recorded Instruments",
    "Notary Public"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Bureau of Conveyances to void any recorded instrument that was fraudulently notarized when attested to by the purported notary public.  Requires the Bureau of Conveyance to allow title holders to suspend additional recordings on their title, unless given prior authorization by the title holder, subject to certain limitations."
    }
  ],
