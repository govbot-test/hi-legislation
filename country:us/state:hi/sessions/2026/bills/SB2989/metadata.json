  "subject": [
    "Department of Transportation",
    "Electric Bicycles",
    "Electric Micro Mobility Devices",
    "Electric Mobility Devices",
    "Electric Mobility Rebate Program",
    "Electric Mobility Subaccount",
    "Electric Motorcycles",
    "High-Speed Electric Device",
