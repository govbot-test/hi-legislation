  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires certain employers to provide unpaid and paid leave of absence for victims of workplace violence or threat of workplace violence.  Expands the type of certification an employee may provide to an employer if the leave exceeds five days per calendar year."
    }
  ],
