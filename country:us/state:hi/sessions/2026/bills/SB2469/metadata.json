  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an unrealized gains surcharge on certain property transfers subject to the estate and generation-skipping transfer tax.  Except for certain types of properties within estates, lowers the applicable exclusion amount allowed."
