{
  "legislative_session": "2026",
  "identifier": "SB2834",
  "title": "RELATING TO ENVIRONMENTAL REVIEW.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Affordable Housing Projects",
    "Attorneys' Fees",
    "Clean Energy Projects",
    "Environmental Review",
    "Judicial Proceedings",
    "Supreme Court"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Shortens the period within which certain judicial proceedings involving environmental assessments and environmental impact statements for actions that propose the use of land for, or construction of, affordable housing or clean energy projects must be initiated.  Requires judicial proceedings involving actions that propose the use of land for, or construction of, affordable housing or clean energy projects to be filed directly with the Supreme Court and prohibits the Supreme Court from awarding attorneys' fees in these judicial proceedings."
    }
  ],
