  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits music streaming platforms from hosting, distributing, or otherwise making available in the State music performed or attributed to an artificial intelligence music artist.  Makes violations an unfair method of competition and an unfair and deceptive act or practice.  Effective 7/1/3000.  (HD1)"
    }
  ],
