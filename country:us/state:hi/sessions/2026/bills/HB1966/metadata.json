{
  "legislative_session": "2026",
  "identifier": "HB1966",
  "title": "RELATING TO THE EMERGENCY MEDICAL SERVICES SPECIAL FUND.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Allowable Uses",
    "Billable Emergency Medical Services",
    "Emergency Medical Services Special Fund"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the Emergency Medical Services Special Fund by authorizing the deposit of revenues from billable emergency medical services.  Amends the composition and allowable uses of the special fund.  Establishes a cap on the unencumbered and unexpended balance in the special fund.  Exempts expenditures from the special fund from chapters 103D and 103F, HRS.  Discontinues the allocation of cigarette tax revenues to the special fund beginning 1/1/2027.  Effective 7/1/3000.  (SD1)"
    }
  ],
