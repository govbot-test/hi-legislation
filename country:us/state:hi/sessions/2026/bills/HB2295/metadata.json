  "identifier": "HB2295",
  "title": "RELATING TO GOVERNMENT CONTRACTING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Contractors Licensing Exemption",
    "Governmental Contracting Agencies",
    "Prevailing Wages",
    "Procurement Standards"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Raises the ceiling for the prevailing wages exemption on public works construction projects from $2,000 to $5,000 for governmental contracting agencies.  Creates exemption to contractors licensing laws for public works construction projects valued up to $5,000 for governmental contracting agencies."
    }
  ],
