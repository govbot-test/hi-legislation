{
  "legislative_session": "2026",
  "identifier": "HB1935",
  "title": "RELATING TO PERSONAL INFORMATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Candidates",
    "Covered Public Servants",
    "Home Address",
    "Personal Information",
    "Removal"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires every government agency that maintains, uses, collects or processes the home address of a covered public servant or candidate, to ensure that their home address is not publicly accessible.  Requires every government agency to redact or otherwise remove home addresses from certain websites, databases, and printed documents or publications.  Authorizes an individual to request disclosure of the home address, under certain circumstances.  Allows a covered public servant or candidate to object to the disclosure of their home address."
    }
  ],
