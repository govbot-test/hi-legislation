  "identifier": "SB2537",
  "title": "RELATING TO THE LAND USE COMMISSION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Boards and Commissions",
    "LUC",
    "Office of Hawaiian Affairs Package"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the composition of the Land Use Commission to require at least one member who has substantial experience and expertise in water resource management.  Requires the Office of Hawaiian Affairs to submit a list of nominees to the Governor for the appointment of a commission member having substantial experience or expertise in traditional Hawaiian land usage and knowledge of cultural land practices."
    }
  ],
