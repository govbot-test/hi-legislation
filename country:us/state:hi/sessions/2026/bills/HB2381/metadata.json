  "identifier": "HB2381",
  "title": "RELATING TO PUBLIC CHARTER SCHOOLS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Per-pupil Allocation",
    "Public Charter Schools",
    "TNBCIP",
    "Teacher Differential",
    "Weighted Student Formula"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Teacher National Board Certification Incentive Program to incentivize public charter school teachers who achieve national board certification under the National Board for Professional Teaching Standards.  Requires that incentives paid to public charter school teachers under the Teacher National Board Certification Incentive Program established for public charter school teachers and other teacher differentials be paid from funds appropriated to the State Public Charter School Commission, instead of the per-pupil allocation.  Effective 7/1/3000.  (HD1)"
    }
  ],
