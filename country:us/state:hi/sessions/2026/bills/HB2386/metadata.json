  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Public Utilities Commission to establish automatic adjustment mechanisms by rules that include specified criteria.  Grants Governor veto-authority over the rules.  Authorizes the Public Utilities Commission to waive or exempt any water carrier from any requirement under the Hawaii Water Carrier Act.  Repeals 7/1/2032.  (SD2)"
    }
  ],
