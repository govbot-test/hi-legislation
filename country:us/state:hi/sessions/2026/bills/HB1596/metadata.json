  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Basic Needs Pilot Program at a single campus of the University of Hawaii system.  Authorizes the establishment of a Housing Stability Pilot Project at that campus.  Appropriates funds.  Effective 7/1/3000.  Sunsets 6/30/2028.  (HD1)"
    }
  ],
