  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Phases in requirements that all newly manufactured washing machines sold within the State by January 1, 2042, be equipped with a microfiber filter.  Requires certification that newly manufactured washing machines have microfiber filters.  Establishes penalties."
    }
  ],
