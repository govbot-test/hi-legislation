  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Taxation to accept, evaluate and make determinations on offers in compromise under certain conditions, including for offers requiring the Governor's approval.  Amends the income tax and general excise tax statute of limitation periods for collection or commencement of proceedings to six years, except in cases of false or fraudulent returns, or intent to evade tax.  Effective 1/1/2027."
    }
  ],
