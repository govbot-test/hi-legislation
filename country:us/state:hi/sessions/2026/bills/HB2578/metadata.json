  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides that a determination of personal liability for another person's unpaid general excise taxes is an assessment subject to the due process procedures and appeals available for other assessments.  Effective 1/1/2027.  (SD1)"
    }
  ],
