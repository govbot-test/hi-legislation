  "subject": [
    "Citizenship",
    "DCCA",
    "Individual Tax Identification Numbers",
    "Professional or Vocational Licensing"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Removes the barrier that requires applicants for professional or vocational licensing to be United States citizens, United States nationals, or persons with work visas.  Allows an applicant to provide the applicant's individual tax identification number with a sworn affidavit in lieu of social security numbers when the applicant does not have a social security number.  Effective 7/1/3000.  (HD1)"
    }
  ],
