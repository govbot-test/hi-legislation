  "identifier": "HB2049",
  "title": "RELATING TO HOUSING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Conveyance Tax",
    "County-designated Transit-oriented Development",
    "Department of Hawaiian Home Lands",
    "Department of Land and Natural Resources",
    "Dwelling Unit Revolving Fund",
    "Hawaii Agricultural Development Revolving Fund",
    "Hawaiian Home Lands Infrastructure and Housing Special Fund",
    "Infrastructure Funding",
    "Special Land and Development Fund"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Restructures the conveyance tax to a marginal rate system for the sale of properties with residential use, adjusts the tax for multifamily properties to reflect value on a per-unit basis, and applies a cost-of-living adjustment to conveyance tax rates.  Allocates revenues from conveyance tax collections.  Allocates a portion of conveyance tax collections to the Dwelling Unit Revolving Fund to fund infrastructure programs in areas that meet minimum standards of transit-supportive density.  Allocates a portion of conveyance tax revenues to the Hawaii Agricultural Development Revolving Fund, Special Land and Development Fund, and Hawaiian Home Lands Infrastructure and Housing Special Fund.  Establishes and appropriates funds out of the Hawaiian Home Lands Infrastructure and Housing Special Fund.  Authorizes the Hawaii Agricultural Development Revolving Fund to be used to acquire land.  Effective 7/1/3000.  (SD1)"
    }
  ],
