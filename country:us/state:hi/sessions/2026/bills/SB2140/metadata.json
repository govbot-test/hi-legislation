{
  "legislative_session": "2026",
  "identifier": "SB2140",
  "title": "RELATING TO COUNTY LABOR STANDARDS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Benefits",
    "Contractors",
