  "abstracts": [
    {
      "note": "description",
      "abstract": "Exempts the Hawaii Tourism Authority's contracts or agreements for sports events from the Hawaii Public Procurement Code and all other requirements of law for competitive bidding.  Requires HTA to notify the Chief Procurement Officer of exempt contracts executed.  Requires an annual report to the State Procurement Office.  Effective 7/1/2050.  (SD2)"
    }
  ],
