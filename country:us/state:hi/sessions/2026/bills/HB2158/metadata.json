{
  "legislative_session": "2026",
  "identifier": "HB2158",
  "title": "RELATING TO THE UNIVERSITY OF HAWAII.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Online Dashboard",
    "Program Level Transparency",
    "Reports",
    "UH"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the University of Hawaii System to develop, implement, and maintain a publicly accessible, systemwide online dashboard.  Requires the dashboard to include and maintain relevant information needed for students and their families for academic decision-making.  Requires a preliminary report on 12/1/2026.  Requires annual reports to the Legislature beginning 12/1/2027.  Requires a supplementary report to the legislature no later than twenty days prior to the convening of the Regular Session of 2031.  Sunsets 6/30/31.  (CD1)"
    }
  ],
