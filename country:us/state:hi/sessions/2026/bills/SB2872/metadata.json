  "identifier": "SB2872",
  "title": "RELATING TO RETIRED EDUCATION EMPLOYEES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrators",
