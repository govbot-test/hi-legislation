  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Regular Session Review Working Group to develop a comprehensive plan and make recommendations to the Legislature on the adoption of an effective year-round legislative session calendar.  Establishes a Technical Advisory Committee to advise the Regular Session Review Working Group.  Requires reports to the Legislature.  Requires report finalization and drafting assistance from the Legislative Reference Bureau.  Dissolves the Working Group and Advisory Committee on 6/30/2028.  Appropriates funds.  Effective 10/18/3000.  (SD1)"
    }
  ],
