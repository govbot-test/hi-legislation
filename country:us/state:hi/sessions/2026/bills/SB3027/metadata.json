  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes patient rights with respect to timely access to specialists and referrals and prior authorization determination timelines.  Establishes certain requirements for health carriers for prior authorization determinations.  Establishes certain requirements for the use of automated decision support tools for claims determinations and utilization review.  Requires health carriers to establish certain safeguards for protected health information.  Establishes certain reporting requirements for network adequacy.  Establishes certain provider protections.  Expands the Insurance Commissioner's enforcement authority."
    }
  ],
