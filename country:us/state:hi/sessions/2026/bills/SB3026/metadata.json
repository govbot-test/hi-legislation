  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits health care facilities, health care providers, and emergency medical services from furnishing medical debt to a consumer credit reporting agency.  Prohibits consumer credit reporting agencies from reporting or maintaining medical debt information in the file on a consumer."
    }
  ],
