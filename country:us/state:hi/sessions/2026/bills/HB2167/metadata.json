{
  "legislative_session": "2026",
  "identifier": "HB2167",
  "title": "RELATING TO YOUTH HOMELESSNESS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Office of Youth Services",
    "Youth Homelessness",
    "Youth Housing Stability Assistance Pilot Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Office of Youth Services to establish a five-year Youth Housing Stability Assistance Pilot Program to enter into contracts with nonprofit organizations or execute memoranda of agreement with government agencies to support eligible youth with financial assistance.  Appropriates funds.  Effective 7/1/3000.  Sunsets 6/30/2031.  (SD1)"
    }
  ],
