  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires that income tax credits existing on 12/31/2026 include a sunset on 12/31/2030.  Requires that income tax credits established or renewed after 12/31/2026 include a sunset 7 years after the date of enactment or renewal of the tax credit.  Provides for exceptions."
    }
  ],
