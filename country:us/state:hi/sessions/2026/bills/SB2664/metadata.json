  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Labor and Industrial Relations to establish and administer the Construction Worker COVID-19 Hazard Pay Program.  Appropriates funds to pay eligible construction workers a one-time payment in recognition for essential labor performed during the COVID-19 pandemic.  Sunsets 6/30/2031."
    }
  ],
