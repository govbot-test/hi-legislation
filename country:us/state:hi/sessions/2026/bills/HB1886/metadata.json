{
  "legislative_session": "2026",
  "identifier": "HB1886",
  "title": "RELATING TO GOVERNMENT OPERATIONS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Criminal Offenses",
    "Facial Coverings",
    "Federal Law Enforcement",
    "Law Enforcement",
    "State and County Law Enforcement",
    "State and Federal Collaboration",
    "Visible Identification"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes provisions limiting state and federal collaboration for purposes of immigration enforcement operations.  Establishes identification and facial coverings standards for state and federal law enforcement officers.  Establishes criminal offenses for improper facial coverings and lack of visible identification and unauthorized civil immigration arrest or detention.  Effective 7/1/2055.  (SD2)"
    }
  ],
