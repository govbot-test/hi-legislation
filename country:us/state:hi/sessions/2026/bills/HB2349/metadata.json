  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Director of Commerce and Consumer Affairs to make certain contact information for newly registered entities available online.  Requires the Director to transmit the contact information to the Business Development and Support Division of the Department of Business, Economic Development, and Tourism.  Effective 7/1/3000.  (HD1)"
    }
  ],
