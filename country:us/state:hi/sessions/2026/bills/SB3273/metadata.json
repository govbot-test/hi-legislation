  "abstracts": [
    {
      "note": "description",
      "abstract": "Exempts certain positions in the Developmental Disabilities Division of the Department of Health and Hawaii State Hospital from civil service.  Authorizes the Director of Health to appoint two additional associate administrators and two project managers for the Hawaii State Hospital or a secure psychiatric rehabilitation facility."
    }
