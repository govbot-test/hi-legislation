  "legislative_session": "2026",
  "identifier": "HB2472",
  "title": "RELATING TO THE HAWAII EMPLOYER-UNION HEALTH BENEFITS TRUST FUND STAFF SALARIES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Assistant Administrator",
    "Hawaii EUTF",
    "Salary Determination ($)"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Board of Trustees of the Hawaii Employer-Union Health Benefits Trust Fund to establish the salary for the Assistant Administrator.  Requires the board to first conduct a market analysis of commensurate salaries in the private sector.  Effective 7/1/3000.  (SD1)"
    }
  ],
