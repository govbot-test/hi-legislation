  "identifier": "SB2540",
  "title": "RELATING TO YOUTH PENALTIES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Community Service",
    "Court Costs",
