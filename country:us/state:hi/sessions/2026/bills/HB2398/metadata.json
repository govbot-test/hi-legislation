  "legislative_session": "2026",
  "identifier": "HB2398",
  "title": "RELATING TO LIBRARIES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "BOE",
    "DOE",
    "Hawaii State Public Library System",
    "Land Use",
    "Public Library System Facilities",
    "State Librarian"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that the Board of Education, through the State Librarian, has exclusive authority over the development, use, support, and improvement and maintenance of public library system facilities.  Allows the Board of Education to authorize the State Librarian to exercise exclusive control of certain land for development or expansion purposes, subject to legislative appropriation.  Requires the Department of Education to expeditiously cooperate with the State Librarian and Hawaii State Public Library System to effectuate any project authorized by the Board of Education on certain lands.  Effective 7/31/2055.  (SD1)"
    }
  ],
