  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits insurers from refusing to issue or renew, canceling, restricting, otherwise terminating, or charging higher rates for a commercial general liability insurance policy, homeowners insurance policy, renters insurance policy, or dwelling fire policy based on the breed of any dog that is kept on the insured premises."
    }
