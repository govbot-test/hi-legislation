  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Board of Education Internal Audit Office.  Requires the Board of Education to establish, as a standing committee of the Board, a standing committee with a scope that includes audit-related responsibilities.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
