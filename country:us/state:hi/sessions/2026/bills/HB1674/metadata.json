  "title": "RELATING TO FAMILY CAREGIVER SUPPORT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Assessments",
