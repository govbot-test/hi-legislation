  "legislative_session": "2026",
  "identifier": "HB1956",
  "title": "RELATING TO FRESHWATER WATERWAYS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Freshwater Waterways",
    "Personal Property",
    "Prohibition Against Residing"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits residing in, on, or within fifty feet of a freshwater waterway.  Authorizes law enforcement officers to enforce the prohibition.  Specifies that violation is a civil violation, not a criminal offense.  Establishes procedures for the removal, inventory, storage, and disposal of unattended personal property.  Effective 7/1/3000.  (HD1)"
    }
  ],
