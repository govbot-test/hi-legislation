{
  "legislative_session": "2026",
  "identifier": "SB3076",
  "title": "RELATING TO TOBACCO ENFORCEMENT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ATG",
    "Asset Forfeiture",
    "DoTAX",
    "Inspections",
    "Seizures",
    "Stamps",
    "Tobacco Products"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that untaxed tobacco products are subject to forfeiture as contraband, without regard to the procedures set forth in Hawaii's asset forfeiture law in the same manner as untaxed cigarettes.  Confirms the authority of the Department of Taxation and the Department of the Attorney General to inspect and seize tobacco products, including electronic smoking devices and e-liquids.  Effective 9/1/2026.  (CD1)"
    }
  ],
