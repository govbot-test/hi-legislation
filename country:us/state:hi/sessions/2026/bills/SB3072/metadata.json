{
  "legislative_session": "2026",
  "identifier": "SB3072",
  "title": "RELATING TO THEFT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Penal Code",
    "Penalty",
    "Theft in the First Degree"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires a mandatory twelve-month minimum sentence of incarceration, without the possibility of parole, for a conviction of theft in the first degree when the value of the property or services stolen exceeds $250,000, whether imposed as a mandatory minimum sentence for an indeterminate term of imprisonment or as a condition of probation, in addition to any other authorized disposition such as restitution or a fine.  (SD1)"
    }
  ],
