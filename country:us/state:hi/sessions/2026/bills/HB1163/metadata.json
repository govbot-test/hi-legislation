  "subject": [
    "Department of Transportation",
    "Federal Motor Carrier Safety Administration",
    "Non-Domiciled Commercial Driver's Licenses and Non-Domiciled Commercial Learner's Permits"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends requirements to commercial driver's license qualification standards to meet current federal regulations to allow the State to issue a non-domiciled commercial learner's permit and non\u2011domiciled commercial driver's license for applicants who are unable to provide proof of citizenship or lawful permanent residency.  (CD1)"
    }
  ],
