  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Board of Education Internal Audit Office to conduct program and fiscal evaluations of the Department of Education's key strategic initiatives to identify program improvements and provide other benefits.  Requires the Board of Education to establish a standing committee with a scope that includes audit-related responsibilities.  Appropriates moneys."
    }
  ],
