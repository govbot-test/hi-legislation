{
  "legislative_session": "2026",
  "identifier": "SB2862",
  "title": "RELATING TO GUBERNATORIAL APPOINTMENTS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advice and Consent",
    "Gubernatorial Appointments",
    "Salaries",
    "Senate Confirmation"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires any person in a position that is not subject to the civil service law to obtain the advice and consent of the senate if the person is appointed by the governor to serve in the executive branch or is appointed pursuant to section 346-381.5, HRS.  Requires persons currently serving in positions made subject to the advice and consent of the Senate by this Act to obtain the advice and consent of the Senate during the Regular Session of 2027 unless the appointee was subject to the advice and consent of the Senate.  Effective 1/1/2525.  (SD1)"
    }
  ],
