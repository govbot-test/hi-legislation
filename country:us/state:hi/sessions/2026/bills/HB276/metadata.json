{
  "legislative_session": "2026",
  "identifier": "HB276",
  "title": "RELATING TO CONDOMINIUMS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Annual Report",
    "Condominiums",
    "Homeowner-Developers"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Excludes a homeowner-developer from the annual requirement to file a developer's report and pay a fee if the homeowner's development consists of no more than two units, one in which the developer has resided as their principal place of residence for at least ten years and one for which the initial sale of the other unit has been completed, subject to certain conditions.  Effective 7/1/3000.  (SD1)"
    }
  ],
