  "subject": [
    "Agricultural Development and Food Security Special Fund",
    "Appropriation ($)",
    "Carbon Cashback Tax Credit",
    "Carbon Emissions",
    "Carbon Emissions Tax and Dividend Special Fund",
    "Department of Taxation",
    "Energy",
    "Environmental Response",
    "Reports",
    "and Food Security Tax"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Reestablishes the Agricultural Development and Food Security Special Fund.  Renames the Environmental Response, Energy, and Food Security Tax, also known as the barrel tax, as the Environmental Response, Energy, Carbon Emissions, and Food Security Tax; gradually increases barrel tax rates; and allocates portions of barrel tax revenues to the Agricultural Development and Food Security Special Fund, Carbon Emissions Tax and Dividend Special Fund, Airport Revenue Fund, and Boating Special Fund.  Establishes a refundable Carbon Cashback Tax Credit and appropriates funds to the Department of Taxation to administer the tax credit.  Establishes the Carbon Emissions Tax and Dividend Special Fund to be used in the administration of the barrel tax and Carbon Cashback Tax Credit and for public awareness of the Carbon Cashback Tax Credit.  Requires the Department of Taxation to submit reports to the Legislature.  Effective 7/1/3000.  (HD1)"
    }
  ],
