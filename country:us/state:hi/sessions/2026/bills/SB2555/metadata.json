  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows a retirant to be employed without reenrollment in the Employees' Retirement System and without loss or interruption of benefits if the retirant is employed in a position identified as one needed for succession planning.  Effective 1/1/2077.  (SD1)"
    }
