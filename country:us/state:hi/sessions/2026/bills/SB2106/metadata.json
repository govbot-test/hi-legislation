  "subject": [
    "Delivery Sellers",
    "Dietary Supplements",
    "Muscle Building",
    "Nonprescription Diet Pills",
    "Prohibition",
    "Retail Establishments",
    "Sale or Delivery to Minors",
    "Weight Loss"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits the sale of nonprescription diet pills and dietary supplements for weight loss or muscle building to any person under eighteen years of age.  Requires retail establishments and delivery sellers to follow certain protocols regarding certain products to prevent access by minors to the restricted products.  Effective 1/30/2050.  (SD1)"
    }
  ],
