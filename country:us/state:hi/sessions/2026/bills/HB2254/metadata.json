  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Judiciary to contract with a collection agency or licensed attorney to collect delinquent court-ordered fees, fines, sanctions, and court costs.  Clarifies the collection and prioritization of court-ordered fees, fines, and restitution.  Establishes procedures for proof of compliance hearings and consequences for nonpayment.  Effective 7/1/3000.  (HD1)"
    }
  ],
