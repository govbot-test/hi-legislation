  "title": "RELATING TO COURT-ORDERED PAYMENTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Collections",
    "Consequences of Non-Payment",
    "Fees",
