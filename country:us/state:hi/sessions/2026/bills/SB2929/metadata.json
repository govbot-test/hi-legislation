{
  "legislative_session": "2026",
  "identifier": "SB2929",
  "title": "RELATING TO PUBLIC NOTICE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Access Hawaii Committee",
    "ETS",
    "Electronic Posting",
    "Public Notices"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes government agencies to satisfy public notice requirements by electronic posting on official state or county websites or electronic calendars, while preserving traditional publication as an option.  Directs the Office of Enterprise Technology Services, in consultation with the Access Hawaii Committee, to adopt rules governing the implementation of electronic notice before the electronic notice authorization takes legal effect.  Effective 7/1/3000.  (HD2)"
    }
  ],
