  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a five-year agriculture and biosecurity workforce development pilot program within the Department of Agriculture and Biosecurity, in collaboration with the University of Hawaii's Leeward Community College, Department of Human Resources Development, and Department of Law Enforcement.  Requires a report to the Legislature.  Effective 7/1/3000.  (HD1)"
    }
  ],
