  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Agriculture and Biosecurity to conduct a study on insurance coverage for small agricultural producers.  Requires a report to the Legislature.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
