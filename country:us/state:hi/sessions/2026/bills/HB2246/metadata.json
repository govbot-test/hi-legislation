  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Agricultural Grant Program and Agricultural Grant Revolving Fund to allow the Department of Agriculture and Biosecurity to retain and expend federal indirect overhead reimbursements for the purposes of grant searching, application, execution, reporting, and auditing.  (CD1)"
    }
