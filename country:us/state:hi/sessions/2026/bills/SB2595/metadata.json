{
  "legislative_session": "2026",
  "identifier": "SB2595",
  "title": "RELATING TO THE AGRIBUSINESS DEVELOPMENT CORPORATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ADC",
    "Appraised Market Value Rate",
    "DOE",
    "Food and Product Innovation Network",
    "Lease",
    "License",
    "Rental"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires payments to the Agribusiness Development Corporation for letting, licensing, or renting of its properties to be at appraised market value rates or higher, except where the lessees, licensees, and tenants grow, raise, and harvest fresh local agricultural products for the Department of Education or are partner members of the Food and Product Innovation Network.  Effective 7/1/3000.  (HD1)"
    }
  ],
