  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Board of Land and Natural Resources to extend the term of all leases of public lands to the United States Military that expire in 2028, 2029, 2030, or 2031 for a period of five years to allow the Military additional time to complete and submit an environmental impact statement for the leased public lands."
    }
  ],
