  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Exempts any agricultural enterprise practicing diversified agriculture on lands formerly used for commercial sugarcane production within the conservation district from any permitting and site plan approval requirements established for lands in a conservation district.  Effective 7/1/3000.  (HD1)"
    }
  ],
