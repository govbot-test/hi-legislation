  "identifier": "SB2088",
  "title": "RELATING TO HEALTH CARE PLANS FOR WORKERS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Catastrophic Health Plan",
    "DLIR",
    "Health Savings Account",
    "High Deductible Health Plan",
