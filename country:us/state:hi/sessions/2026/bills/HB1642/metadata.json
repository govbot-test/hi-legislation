  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 10/1/2026, prohibits the ownership, operation, or management of a digital financial asset transaction kiosk that accepts United States currency from a customer in exchange for a digital financial asset.  (CD1)"
    }
