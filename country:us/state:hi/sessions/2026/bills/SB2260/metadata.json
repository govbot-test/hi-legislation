  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides that an individual who becomes a lessee of a tract of Hawaiian home lands, either as an original lessee or as a successor lessee, shall forfeit any interest as an original lessee or successor lessee in any other tract of Hawaiian home lands and be removed from any applicant waitlist."
    }
  ],
