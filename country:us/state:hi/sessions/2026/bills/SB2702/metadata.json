  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a limited right of first refusal for the Department of Hawaiian Home Lands with respect to county real property tax sales.  Requires advance notice from the counties to the Department of Hawaiian Home Lands of qualifying properties.  (SD1)"
    }
  ],
