  "abstracts": [
    {
      "note": "description",
      "abstract": "Exempts from the general excise tax, gross receipts from the sale of hearing aids received by a hospital, infirmary, medical clinic, health care facility, pharmacy, or a practitioner licensed to administer drugs to an individual.  Effective 1/30/2050.  Implementation effective 1/1/2027.  (SD1)"
    }
  ],
