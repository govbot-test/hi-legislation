  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a mattress stewardship working group within the Department of Health to develop a program to ensure the collection, reuse, and recycling of mattresses, box springs, and mattress foundations.  Effective 7/1/3000.  (HD1)"
    }
