  "subject": [
    "Iatrogenic Infertility",
    "Insurance",
    "Mandatory Coverage",
    "Medically Necessary Treatment",
    "Standard Fertility Preservation Services"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "For policies, contracts, plans, and agreements issued or renewed after 12/31/2026, requires insurers, mutual benefit societies, and health maintenance organizations to provide coverage for standard fertility preservation services for persons undergoing medically necessary treatment that may cause iatrogenic infertility.  (CD1)"
    }
  ],
