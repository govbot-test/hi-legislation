  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the sustainable tourism infrastructure matching grant program within the Department of Business, Economic Development, and Tourism to support one-time capital investments that advance measurable sustainability and climate resilience outcomes within the State's visitor industry.  Requires annual reports to the Legislature.  Appropriates funds."
