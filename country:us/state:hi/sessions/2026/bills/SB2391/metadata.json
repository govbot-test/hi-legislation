  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides annual salary step increases for public schools and public charter school teachers who have completed one year's satisfactory service and comply with specified requirements, if negotiated into a collective bargaining agreement pursuant to section 89-9, HRS, and subject to funds appropriated by the Legislature.  Effective 7/1/3000.  (HD1)"
    }
  ],
