{
  "legislative_session": "2026",
  "identifier": "SB1166",
  "title": "RELATING TO INSURANCE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Climate Change",
    "Climate Disaster",
    "Extreme Weather",
    "HHRF",
    "HPIA",
    "Property Insurance",
    "Responsible Parties"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows the Hawaii Property Insurance Association, the Hawaii Hurricane Relief Fund, and private insurers to bring claims against responsible parties for amounts paid by the insurers for losses resulting from climate disasters and extreme weather attributable to climate change.  Requires insurance rates established by the Hawaii Property Insurance Association to account for any proceeds from the civil claims against a responsible party.  Effective 7/1/3000.  (HD2)"
    }
  ],
