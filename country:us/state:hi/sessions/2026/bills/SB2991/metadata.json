  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that persons whose driver's licenses have been revoked for certain alcohol-related offenses are required to undergo reexamination before the examiner of drivers may relicense the person.  Requires a notice and order of administrative revocation to include certain information.  Effective 7/1/3000.  (HD1)"
    }
  ],
