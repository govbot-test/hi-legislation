  ],
  "subject": [
    "Building Code",
    "Contractor Repair Act",
    "Inspection",
    "Limitations on Recovery",
    "Rejection of Claims",
    "Repair",
    "Statute of Repose"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits actions based on a building code violation unless the violation was a material violation of the building code.  Specifies that claimants must comply with the Contractor Repair Act and bars persons from joining a class action for failure to comply with the Contractor Repair Act.  Repeals the requirement that inspections and testing be completed within nine months.  Deletes duplicative language for when persons may accept a settlement offer.  Limits the amount a claimant can recover if the claimant rejects a contractor's reasonable proposal for inspection or a reasonable offer to remedy.  (HD1)"
    }
  ],
