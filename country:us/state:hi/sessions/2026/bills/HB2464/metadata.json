  "subject": [
    "Appropriation ($)",
    "DOTAX",
    "Family Caregiver Tax Credit",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a family caregiver tax credit for nonpaid family caregivers.  Requires the Department of Taxation to submit annual reports to the legislature.  Appropriates moneys to the Executive Office on Aging.  The tax credit applies to taxable years beginning after 12/31/2027.  Effective 12/31/2026."
    }
  ],
