  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits residing on agricultural park lots unless within a farm dwelling permitted by the Board of Agriculture and Biosecurity.  Authorizes the Department of Agriculture and Biosecurity to conduct inspections of agricultural park lots for unpermitted farm dwellings during fiscal year 2026-2027."
    }
  ],
