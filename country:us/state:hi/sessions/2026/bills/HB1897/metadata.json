  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the conditions and procedures of alternative dispute resolution methods for condominium-related disputes, including the use of facilitative mediation, evaluative mediation, or binding arbitration.  Effective 7/1/3000.  (SD1)"
    }
  ],
