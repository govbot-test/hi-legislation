  "identifier": "HB1897",
  "title": "RELATING TO CONDOMINIUM ALTERNATIVE DISPUTE RESOLUTION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Alternative Dispute Resolution",
    "Binding Arbitration",
    "Condominiums",
