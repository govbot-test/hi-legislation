  ],
  "subject": [
    "Appropriation ($)",
    "DCCA",
    "Establishment",
    "Office of Artificial Intelligence Safety and Regulation"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Office of Artificial Intelligence Safety and Regulation within the Department of Commerce and Consumer Affairs to regulate the development, deployment, and use of artificial intelligence technologies in the State.  Prohibits the deployment of artificial intelligence products in the State unless affirmative proof establishing the product's safety is submitted to the Office.  Appropriates funds."
    }
  ],
