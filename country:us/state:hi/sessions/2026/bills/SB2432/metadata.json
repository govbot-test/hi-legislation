  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires licensure for individuals managing common interest community associations for compensation.  Clarifies that common interest community association manager licensure is distinct from real estate licensure.  Establishes the qualifications, continuing education, and standards of conduct required for common interest community association manager licensure.  Authorizes the Department of Commerce and Consumer Affairs to administer licensure of common interest community association managers.  Clarifies exemptions for licensure requirements.  Appropriates funds."
    }
  ],
