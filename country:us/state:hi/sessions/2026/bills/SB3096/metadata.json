{
  "legislative_session": "2026",
  "identifier": "SB3096",
  "title": "RELATING TO THE EMPLOYEES' RETIREMENT SYSTEM'S EMPLOYER CONTRIBUTIONS FOR NORMAL COST AND ACCRUED LIABILITY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "ERS",
    "Employer Contribution Rates",
    "Increase",
    "Unfunded Accrued Liability"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases employer contribution rate for normal cost and accrued liability for police officers, firefighters, and corrections officers to ensure that the amortization period for the unfunded accrued liability of the State's Employees' Retirement System does not exceed the maximum funding period.  Takes effect 7/1//2027.  (CD1)"
    }
  ],
