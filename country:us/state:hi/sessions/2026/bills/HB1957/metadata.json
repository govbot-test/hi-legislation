  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes, for a county with a population greater than three hundred thousand, enforcement procedures to prevent people or personal property from blocking or otherwise impeding ingress or egress to private doorways and entranceways.  Effective 7/1/3000.  (SD1)"
    }
  ],
