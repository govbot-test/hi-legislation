  "identifier": "SB2975",
  "title": "RELATING TO MARINE LIFE CONSERVATION DISTRICTS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Closure Authority",
    "Commercial Activity",
    "DLNR",
    "Marine Life Conservation Districts",
    "Oahu",
