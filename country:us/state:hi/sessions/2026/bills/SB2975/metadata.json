  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Land and Natural Resources to close all or portions of any marine life conservation district for various periods of time and to adopt rules for the regulation of commercial activity within a marine life conservation district; provided that the marine life conservation district is located on or adjacent to the shores of Oahu.  Effective 7/1/2050.  (SD1)"
    }
  ],
