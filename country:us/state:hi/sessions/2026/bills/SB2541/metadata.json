  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a temporary, independent Public School Realignment and Closure Commission to develop and recommend a comprehensive package of school consolidations, realignments, and closures based on the federal Base Realignment and Closure model.  Requires an expedited approval process by the Governor and Legislature.  Appropriates moneys."
    }
  ],
