{
  "legislative_session": "2026",
  "identifier": "SB3107",
  "title": "RELATING TO PAROLE ELIGIBILITY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Parole Eligibility"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends section 353-64, HRS, to include participation in correctional programs for parole eligibility:  (1) treatment (substance abuse, mental health, sex offender); (2) work furlough as part of vocational education; and (3) other programs designed to assist the committed person with successful reintegration back into the community; all of which are in the scope of programs determined by Department of Corrections and Rehabilitation's Receiving and Diagnostic (RAD) assessments and recommended for parole eligibility.  Effective 7/1/2050.  (SD1)"
    }
  ],
