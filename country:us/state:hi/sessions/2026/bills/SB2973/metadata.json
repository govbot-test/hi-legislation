  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Division of Aquatic Resources of the Department of Land and Natural Resources to begin the rulemaking process no later than 7/1/2026 to regulate or ban jug line fishing and jug rig variant fishing methods.  Effective 7/1/3000.  (HD1)"
    }
