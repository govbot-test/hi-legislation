  "legislative_session": "2026",
  "identifier": "HB2434",
  "title": "RELATING TO WATER.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Counties and Subdivisions",
    "Department of Land and Natural Resources",
    "Water Licenses"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a framework that provides counties or their subdivisions priority and the right of first refusal to obtain intergovernmental agreements related to the disposition of water resources for public purposes.  Establishes criteria to be applied when determining that the issuance of a state water license is in the best interest of the State."
    }
  ],
