  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates funds to the Department of Health to contract with community-based organizations to provide preventive and early intervention mental health services to adolescents within the community.  Requires a report to the Legislature.  Effective 7/1/3000.  (HD1)"
    }
