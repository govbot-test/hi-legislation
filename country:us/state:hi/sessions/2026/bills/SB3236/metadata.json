  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires and appropriates funds for the Hawaii Emergency Management Agency to establish a Central Oahu Care Home Community Resilience Pilot Program to assist eligible care home facilities to implement structural and operational resilience improvements.  Requires a report to the Legislature."
    }
