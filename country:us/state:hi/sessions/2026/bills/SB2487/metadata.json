{
  "legislative_session": "2026",
  "identifier": "SB2487",
  "title": "RELATING TO THE PUBLIC UTILITIES COMMISSION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Hawaii Ratepayer Protection Act of 2026",
    "PUC",
    "Performance-Based Incentives",
    "Ratemaking"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Public Utilities Commission to establish performance-based incentives, including revenue adjustment mechanisms, cost control mechanisms, and reward and penalty mechanisms on or before 1/1/2027.  Clarifies that the Public Utilities Commission is authorized to adopt alternative ratemaking procedures to establish electric utility rates and performance-based incentives.  (CD1)"
    }
  ],
