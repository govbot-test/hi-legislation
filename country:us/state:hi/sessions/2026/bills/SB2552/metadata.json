{
  "legislative_session": "2026",
  "identifier": "SB2552",
  "title": "RELATING TO THE INDIVIDUAL HOUSING ACCOUNT PROGRAM.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Income Tax",
    "Increase",
    "Individual Housing Accounts",
    "Maximum Annual Deduction",
    "Maximum Total Deduction",
    "Pre-tax Savings"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "For taxable years beginning 1/1/2027: (1) increases the maximum annual and total allowable deduction for contributions to individual housing accounts for income tax deductions; and (2) increases the maximum allowable contributions for individual housing accounts to qualify for the income tax deductions.  Repeals outdated language applicable to first\u2011time home purchases made before 1/1/1990, by persons with an individual housing account.  (CD1)"
    }
  ],
