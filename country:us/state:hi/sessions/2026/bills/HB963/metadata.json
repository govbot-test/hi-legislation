  "identifier": "HB963",
  "title": "RELATING TO CRIMES AGAINST ELDERS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Assault in the First and Second Degrees",
    "Attendant Circumstances",
    "Elders",
