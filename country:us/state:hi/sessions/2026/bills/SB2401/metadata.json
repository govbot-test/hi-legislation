{
  "legislative_session": "2026",
  "identifier": "SB2401",
  "title": "RELATING TO REGIONAL SHORELINE MITIGATION DISTRICTS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Coastal Erosion",
    "OPSD",
    "Permits",
    "Regional Shoreline Mitigation Districts",
    "Shoreline Adaptation Pathways Planning"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Office of Planning and Sustainable Development to plan and serve in a coordinating role to develop shoreline adaptation pathways plans for regional shoreline mitigation districts designated by OPSD.  Establishes procedures for the review of state and county permits associated with regional shoreline mitigation districts.  (CD2)"
    }
  ],
