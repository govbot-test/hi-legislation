  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an order of succession for an Interim Chief Election Officer in the event of a vacancy in the position of Chief Election Officer until the Elections Commission appoints a new Chief Election Officer.  (CD1)"
    }
