  "abstracts": [
    {
      "note": "description",
      "abstract": "Applies the retail or higher general excise tax or use tax rate to purchases or imports of new motor vehicles by rental car companies and requires the revenue to be deposited into the Hawaiian Home Lands Special Fund.  Establishes the Hawaiian Home Lands Special Fund.  Appropriates funds for a position in the Department of Taxation.  Appropriates funds out of the Hawaiian Home Lands Special Fund.  Effective 7/1/3000.  (HD2)"
    }
  ],
