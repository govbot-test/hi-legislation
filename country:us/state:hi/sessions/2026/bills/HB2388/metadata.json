  "identifier": "HB2388",
  "title": "RELATING TO PUBLIC NOTICE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "County Clerks",
    "County-Wide Notice",
    "Electronic Posting Pilot Project",
    "Public Notices",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Electronic Posting Pilot Project for any county with a population between one hundred thousand and 175,000, to be administered by the county clerk of each participating county.  Allows county agencies to satisfy county-wide public notice requirements by posting notices on official county websites, while retaining publication as an option.  Requires a report to the Legislature.  Effective 1/1/2525.  (SD1)"
    }
  ],
