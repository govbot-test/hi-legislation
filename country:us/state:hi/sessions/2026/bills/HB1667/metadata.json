  "identifier": "HB1667",
  "title": "RELATING TO CIVIL IDENTIFICATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Lowering of Age to Obtain",
    "State Civil Identification Card"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Lowers the age to obtain a state civil identification card without a signature from a parent or guardian from eighteen years old to sixteen years old.  Effective 7/1/2027.  (CD1)"
    }
  ],
