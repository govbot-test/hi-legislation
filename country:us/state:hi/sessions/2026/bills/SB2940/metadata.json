  "identifier": "SB2940",
  "title": "RELATING TO SOLAR ENERGY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "PUC",
    "Portable Solar Generation Device",
    "Registration",
    "Requirements"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Defines and provides requirements for the use of a portable solar generation device.  Requires each portable solar generation device to be registered with the Public Utilities Commission.  Provides that electric utility companies are not liable for any damage or injury caused by a portable solar generation device.  Requires the Public Utilities Commission to establish and maintain an online system for registering a portable solar generation device, at no cost to the customer."
    }
  ],
