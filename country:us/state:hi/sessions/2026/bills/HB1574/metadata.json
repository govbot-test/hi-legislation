{
  "legislative_session": "2026",
  "identifier": "HB1574",
  "title": "RELATING TO THE HEALTHCARE EDUCATION LOAN REPAYMENT PROGRAM.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Healthcare Education Loan Repayment Program",
    "Healthcare Professionals",
    "Minimum Service Requirements"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Formally codifies the Healthcare Education Loan Repayment Program.  Requires a participant in the Healthcare Education Loan Repayment Program who receives a new award on or after July 1, 2027, to remain and work in the State for a certain number of years based on the amount of financial assistance received.  Effective 7/31/2055.  (SD2)"
    }
  ],
