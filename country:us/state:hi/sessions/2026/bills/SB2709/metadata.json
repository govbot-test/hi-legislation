  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Agriculture and Biosecurity to establish rules to enforce the Akamai Arrival Program.  Requires DAB to strengthen enforcement of plant and non-domestic animal quarantine and microorganism importations.  (SD1)"
    }
  ],
