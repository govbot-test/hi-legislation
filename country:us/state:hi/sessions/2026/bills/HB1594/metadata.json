  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires, as a condition of entry into the State, documentation verifying that any dog or cat imported into the State has been surgically sterilized, subject to certain exemptions.  Requires the Department of Agriculture and Biosecurity to establish a breeder registry and adopt rules."
    }
  ],
