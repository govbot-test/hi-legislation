  "abstracts": [
    {
      "note": "description",
      "abstract": "Exempts the donation of wild game meat, including axis deer, by a hunter for the use or distribution by a charitable, religious, or nonprofit organization to needy persons from certain laws regarding the inspection and transportation of meat.  Effective 7/1/3000.  (HD1)"
    }
  ],
