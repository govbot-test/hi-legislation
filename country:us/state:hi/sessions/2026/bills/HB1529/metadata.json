  "abstracts": [
    {
      "note": "description",
      "abstract": "Reduces the quorum requirement for boards and commissions to a majority of current voting members of a board or commission.  Reduces the number of affirmative votes needed to validate action of a board or commission to a majority of members voting at a meeting with quorum."
    }
  ],
