  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the State Librarian to establish an Imagination Library of Hawaii Program to provide one free book each month to children from birth through five years of age who reside in the State.  Appropriates funds.  Effective 7/31/2055.  (SD1)"
    }
  ],
