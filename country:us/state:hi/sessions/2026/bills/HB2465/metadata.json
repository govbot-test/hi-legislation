  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows the charge of unauthorized entry into motor vehicle in the first degree to be brought as a class B felony if property damage of $750 or more occurs or the person has a previous conviction for the same offense within the past five years."
    }
