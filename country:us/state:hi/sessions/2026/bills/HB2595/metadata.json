  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Regional Agricultural Feasibility and Food Systems Production Studies Working Group within the Department of Agriculture and Biosecurity to provide coordinated, region\u2011specific agricultural production and crop feasibility analysis across the State.  Requires reports to the Legislature.  Appropriates funds.  Repeals 6/30/2028.  Effective 7/1/2050.  (SD1)"
    }
  ],
