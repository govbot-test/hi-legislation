{
  "legislative_session": "2026",
  "identifier": "SB2397",
  "title": "RELATING TO NEIGHBORHOOD BOARDS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Neighborhood Boards",
    "Quorum Requirements",
    "Vacancies"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes that when a neighborhood board of the City and County of Honolulu has a vacancy, a majority of the filled seats shall constitute quorum for conducting official board business and discussions before and related to voting.  Effective 1/1/2027.  (CD1)"
    }
  ],
