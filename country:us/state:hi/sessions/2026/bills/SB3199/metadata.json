  "legislative_session": "2026",
  "identifier": "SB3199",
  "title": "RELATING TO MENTAL HEALTH.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Emerging Therapies",
    "JABSOM",
    "Mental Health",
    "Reports",
    "Task Force"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Mental Health Emerging Therapies Task Force within the University of Hawaii at Manoa John A. Burns School of Medicine to prepare the State for the integration of breakthrough therapies, expansion of pathways for clinical trials and clinical research, and development of policy recommendations for safe, ethical, and culturally informed implementation of emerging therapies.  Requires reports to the Legislature.  Sunsets 6/30/2028.  Effective 1/30/2050.  (HD1)"
    }
  ],
