  "abstracts": [
    {
      "note": "description",
      "abstract": "PART II:  Allows certain extensions of the deadline for cesspool conversions.  PART III:  Authorizes and appropriates funds to the Department of Health to retain qualified consultants as necessary to identify necessary public outreach and education resources and tools and develop a comprehensive public outreach strategy and website to educate homeowners and wastewater industry professionals about information and resources regarding the State's cesspool upgrade, conversion, and connection requirements and deadlines."
    }
  ],
