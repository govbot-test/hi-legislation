  ],
  "subject": [
    "DOT",
    "Parking Cash-out Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires employers of twenty or more persons to offer a parking cash-out program in place of a parking subsidy and report to the Department of Transportation.  Requires the Department of Transportation to report to the Legislature, adopt rules, and impose fines or penalties on violators."
    }
  ],
