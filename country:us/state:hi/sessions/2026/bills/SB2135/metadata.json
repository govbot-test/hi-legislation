{
  "legislative_session": "2026",
  "identifier": "SB2135",
  "title": "RELATING TO PRIVACY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Felony Offense",
    "Minors",
    "Nonconsensual Disclosure of Intimate or Private Images",
    "Penal Code",
    "Vulnerable Adults"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the nonconsensual disclosure of intimate or private images as a criminal offense.  Amends the criteria for an extended term of imprisonment to include defendants whose act of attempting to commit or committing the offense of nonconsensual disclosure of intimate or private images against a minor or vulnerable adult was the proximate cause of the victim's death.  (CD1)"
    }
  ],
