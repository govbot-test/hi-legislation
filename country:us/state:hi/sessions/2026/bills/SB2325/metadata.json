  "identifier": "SB2325",
  "title": "RELATING TO JUVENILE OFFENDERS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Interest of Justice",
    "Juvenile Offenders",
    "Sentence Modification",
    "Sentencing"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes a court to modify sentences imposed on juvenile offenders if certain conditions are met and the court finds that, after considering certain factors, the defendant is not a danger to the safety of any person or the community and the modification is in the interests of justice.  Establishes procedures, provides for hearings and representation by counsel, and authorizes appellate review.  (HD1)"
    }
  ],
