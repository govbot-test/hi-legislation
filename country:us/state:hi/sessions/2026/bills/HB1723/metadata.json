  "abstracts": [
    {
      "note": "description",
      "abstract": "Specifies the conditions upon which the Hawaii Housing Finance and Development Corporation may transfer moneys from within the Rental Housing Revolving Fund to a subaccount and between subaccounts of the revolving fund.  Authorizes the Rental Housing Revolving Fund to be used to provide any and all forms of financing.  Expands the funding priorities of, and appropriates funds into and out of, the Mixed-Income Subaccount.  Effective 7/1/3000.  (HD1)"
    }
  ],
