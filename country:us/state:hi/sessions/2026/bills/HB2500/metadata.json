{
  "legislative_session": "2026",
  "identifier": "HB2500",
  "title": "RELATING TO ARTIFICIAL INTELLIGENCE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Algorithmic Decision Systems",
    "Artificial Intelligence",
    "Deployer",
    "Developer",
    "Disclosure",
    "Enforcement"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 1/1/2027, requires a developer of an algorithmic decision system to provide certain disclosures to a deployer and an individual who is or will be affected by a decision made, informed, or influenced by the algorithmic decision system.  Provides certain rights and procedures for individuals to access and correct data used by an algorithmic decision system.  Requires disclosure requirements for generative artificial intelligence systems.  Provides that a developer and deployer of an algorithmic decision system are jointly and severally liable for a violation of any law that results from the deployer's use of the developer's system, under certain conditions.  Assigns enforcement responsibilities to the attorney general, including establishing rules."
    }
  ],
