  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires all state building construction begun on or after 7/1/2028 to provide at least one universal changing accommodation in each public restroom designated as a family or assisted-use restroom, unless technically infeasible.  Effective 1/1/2525.  (SD1)"
    }
  ],
