  "identifier": "HB1803",
  "title": "RELATING TO STUDENT HEAT EXPOSURE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriations ($)",
