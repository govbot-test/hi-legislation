  "legislative_session": "2026",
  "identifier": "SB3329",
  "title": "RELATING TO PUBLIC TESTIMONY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Authentication",
    "Boards and Commissions",
    "Legislature",
    "Personal Information",
    "Protection",
    "State and Counties",
    "Written Testimony"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits state and county boards from considering written testimony submitted by an individual member of the public unless the written testimony includes certain information necessary for the board to verify the authenticity of the testimony and communicate with the testifier.  Prohibits boards from disclosing any personal information obtained through written public testimony, except the name of the testifier, unless authorized by the testifier.  Requires each house of the Legislature to adopt or amend rules to apply the written public testimony verification process to certain hearings conducted by its standing committees.  Effective 1/1/2028."
    }
  ],
