  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Hawaii Home Energy Assistance Program within the Department of Human Services to assist eligible households in paying their energy bills.  Requires the Public Utilities Commission Public Benefits Fee Administrator to provide certain information and assistance to recipients of the program.  Establishes positions.  Appropriates funds."
    }
  ],
