  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals staff of the legislative branch of the State from the list of individuals not included in any appropriate bargaining unit.  Specifies that the President of the Senate and the Speaker of the House of Representatives shall each have one vote if they have employees in a particular bargaining unit for the purposes of negotiating a collective bargaining agreement."
    }
  ],
