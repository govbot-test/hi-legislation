  "title": "RELATING TO PROPERTY DAMAGE OF CRITICAL INFRASTRUCTURE FACILITIES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Criminal Property Damage of Critical Infrastructure Facilities",
    "Felony",
    "Offenses Against Property Rights"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the class C felony offense of criminal property damage to critical infrastructure facilities.  Expands the term \"critical infrastructure\" to include broadband, wireless, and cable networks.  Effective 7/1/3000.  (HD1)"
    }
  ],
