  "legislative_session": "2026",
  "identifier": "SB2966",
  "title": "RELATING TO PROPERTY INSURANCE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Adjustment",
    "Notice",
    "Property Insurance",
    "Refund",
    "Total Loss"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires insurers, after a policyholder experiences a total loss, to automatically refund any unearned premium; adjust premiums for subsequent policy terms to reflect the absence of a dwelling, structure, or contents; and provide policyholders with clear notice of the coverage needed for vacant property or while rebuilding."
    }
  ],
