  "abstracts": [
    {
      "note": "description",
      "abstract": "Includes recklessly causing serious or substantial bodily injury to a law enforcement officer engaged in the performance of duty as the offense of assault against a law enforcement officer in the first degree.  Increases penalties for the offense of assault against a law enforcement officer in the first degree.  Effective 3/22/2075.  (SD1)"
    }
  ],
