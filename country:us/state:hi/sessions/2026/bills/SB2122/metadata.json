  "abstracts": [
    {
      "note": "description",
      "abstract": "Specifies that the maximum contribution and carryover amounts for a public service flexible spending account plan shall be set in accordance with the annual limits prescribed by the Internal Revenue Service for cafeteria plans.  Effective 1/1/2077.  (SD1)"
    }
  ],
