  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a nonrefundable Workforce Builder Tax Credit for employers who employ qualified interns and apprentices, to be applied to taxable years beginning after 12/31/2026.  Requires a report to the Legislature.  Appropriates funds.  Effective 1/1/2077.  (SD1)"
    }
  ],
