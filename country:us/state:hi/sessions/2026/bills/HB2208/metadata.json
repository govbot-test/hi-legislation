  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes and appropriates funds in the form of grants for the Hawaii Farm to Families Program under the Department of Human Services to alleviate food shortages in the State.  Requires reports to the Legislature.  (SD1)"
    }
  ],
