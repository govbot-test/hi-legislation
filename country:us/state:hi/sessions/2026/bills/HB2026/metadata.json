  "subject": [
    "Oversized Commercial Vehicles",
    "Penalties",
    "Restrictions",
    "Towing",
    "Traffic Code"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Restricts motor vehicles that tow a motor vehicle or trailer from the far left lane on roads with three or more lanes going in the same direction, with exemptions.  Specifies penalties for restricted motor vehicles who drive in the far left lane on roads with three or more lanes moving in the same direction.  Applies restrictions and penalties to a county with a population of 500,000 or more.  (HD1)"
    }
  ],
