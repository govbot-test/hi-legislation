  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Hawaii Technology Development Corporation Revolving Fund to provide state matching funds for federal grants awarded to the Hawaii Technology Development Corporation that support innovation, technology, research, and manufacturing initiatives.  Requires annual reports to the Legislature.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
