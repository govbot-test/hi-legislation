{
  "legislative_session": "2026",
  "identifier": "HB2558",
  "title": "RELATING TO TELEHEALTH.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Out-of-State Physicians",
    "Physician-Patient Relationship",
    "Telehealth"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes out-of-state physicians who are licensed and in good standing in the state in which they reside to provide an initial consultation via telehealth to a patient located in the State, under certain conditions.  Clarifies that a physician-patient relationship may be established with an out-of-state physician via telehealth under certain circumstances.  Effective 7/1/3000.  (HD2)"
    }
  ],
