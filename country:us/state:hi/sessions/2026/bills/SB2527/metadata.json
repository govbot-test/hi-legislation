  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires that state and county firefighters exempt from commercial driver licensure be subject to an alcohol and substance abuse policy for employees that is equivalent to, or exceeds the provisions of, the safety and health standards established by the United States Department of Transportation for holders of commercial driver's licenses."
    }
  ],
