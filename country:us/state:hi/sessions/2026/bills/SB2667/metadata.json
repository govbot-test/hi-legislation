  ],
  "subject": [
    "Oversized Commercial Vehicles",
    "Penalties",
    "Restrictions",
    "Towing",
    "Traffic Code"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the prohibition on the use of the far left lane by commercial vehicles on roadways with three or more lanes going in the same direction.  Restricts motor vehicles towing a vehicle or trailer from using the far left lane, subject to specified exemptions.  Establishes penalties for violations.  Applies restrictions and penalties to a county with a population of 500,000 or more.  (CD1)"
    }
  ],
