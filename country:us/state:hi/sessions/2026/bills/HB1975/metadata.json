  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals the sunset for the State Rent Supplement Program for Kupuna.  Appropriates funds to the Hawaii Public Housing Authority for the State Rent Supplement Program for Kupuna and for two positions to support the program.  Effective 7/1/2050.  (SD1)"
    }
  ],
