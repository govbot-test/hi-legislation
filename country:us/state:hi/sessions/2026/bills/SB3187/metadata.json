  "abstracts": [
    {
      "note": "description",
      "abstract": "Implements certain recommendations of the SPEED Task Force.  Establishes and appropriates funds for a working group within the State Building Code Council to develop proposals for an off-site construction program.  Effective 7/1/3000.  (HD1)"
    }
