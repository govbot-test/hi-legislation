  ],
  "subject": [
    "County Debt Limit Statements",
    "Statutory Amendments",
    "Tax Increment Bonds"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Conforms county debt limit statements law to permit counties to exclude tax increment bonds from the debt limit of the counties if a constitutional amendment authorizing the use of tax increment bonds and excluding tax increment bonds from determinations of the counties' funded debt is ratified."
    }
  ],
