  ],
  "subject": [
    "Authorization",
    "Department of Commerce and Consumer Affairs",
    "Gaming on Cruise Ships",
    "Report",
    "Wagering Tax"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 8/1/2027, authorizes gaming on cruise ships while a cruise ship is traveling within any state waters or for specified times while docked at a state harbor.  Imposes a twenty per cent wagering tax on the adjusted gross receipts derived from gaming on cruise ships.  Requires the Department of Commerce and Consumer Affairs to report to the Legislature."
    }
  ],
