  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 1/1/2027, prohibits the sale, offer for sale, or distribution for sale of any disposable electronic smoking devices in the State.  Establishes penalties.  Effective 1/30/2050.  (SD1)"
    }
  ],
