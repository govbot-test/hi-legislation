  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the office of the legislative analyst to produce fiscal notes on all fiscal bills.  Prohibits a committee from making a decision on a fiscal bill without a fiscal note.  Mandates that fiscal notes be made available to the public.  Appropriates funds."
    }
  ],
