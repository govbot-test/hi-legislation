  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes SHPD to conduct a phased review of a proposed project on private property under certain circumstances.  Amends the process and deadlines by which SHPD must provide written concurrence or non-concurrence for a proposed project on private property or other project that requires entitlement for use, after which concurrence may be assumed and the project may proceed."
    }
  ],
