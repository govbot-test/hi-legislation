{
  "legislative_session": "2026",
  "identifier": "HB1733",
  "title": "RELATING TO THE HOUSING LOAN AND MORTGAGE PROGRAM.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Affordable Rental Housing",
    "HHFDC",
    "Housing Loan and Mortgage Program",
    "Hula Mae Multifamily Revenue Bond Authorization",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases the Hula Mae Multifamily Revenue Bond authorization ceiling amount to continue financing affordable rental housing statewide.  Clarifies that revenue bonds treated as refunding bonds do not count against the authorized aggregate principal amount of the bond.  Requires the Hawaii Housing Finance and Development Corporation to submit a report to the Legislature.  Effective 7/1/3000.  (SD1)"
    }
  ],
