{
  "legislative_session": "2026",
  "identifier": "SB2502",
  "title": "RELATING TO FIREWORKS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Consumer Fireworks",
    "State Fire Council Package"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits the use of consumer fireworks except, by permit, for cultural use.  Repeals portions of section 132D-3(1), HRS, that generally allow the use of consumer fireworks without a permit on New Year's Eve, New Year's Day, and the Fourth of July.  Specifies that no fireworks shall be sold to a permittee holding a permit issued for purposes of cultural use more than 5 calendar days before the applicable cultural use.  Makes technical amendments to definitions of \"consumer fireworks\" and \"cultural\" within fireworks law."
    }
  ],
