  "identifier": "SB2413",
  "title": "RELATING TO MEDICAL CANNABIS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DLE",
    "DOH",
    "Dispensaries",
