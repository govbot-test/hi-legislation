{
  "legislative_session": "2026",
  "identifier": "HB1840",
  "title": "RELATING TO EDUCATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Charter Schools",
    "DOE",
    "Emergency Hires",
    "HTSB",
    "Rules",
    "Support",
    "Visiting International Educator Permit"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Hawaii Teacher Standards Board to develop an alternative pathway for a visiting international educator permit aligned to the duration of the educator's J-1 visa program.  Permits the Department of Education and charter schools to hire unlicensed individuals as teachers on an emergency basis for five, rather than three, years.  Requires HTSB to extend the five-year period in the case of a declared state of emergency.  Requires the Department of Education to provide support to assist emergency hires in meeting the requirements of licensure and require the training be mandatory for emergency hires in their fourth and fifth years.  Effective 7/31/2055.  (SD1)"
    }
  ],
