  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands the services eligible for Medicaid Prospective Payment System reimbursement to include certain services furnished by a federally qualified health center or rural health clinic and provided by mental health professionals under the clinical supervision of a licensed mental health professional.  Requires the Department of Human Services to adopt rules for this purpose and seek federal approvals as necessary.  Effective 7/1/3000.  (HD1)"
    }
  ],
