  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Office of Consumer Protection of the Department of Commerce and Consumer Affairs to conduct a study to determine the extent to which companies operating in the State deploy surveillance pricing practices.  Requires a report to the Legislature.  Appropriates funds.  Effective 1/1/2077.  (SD1)"
    }
  ],
