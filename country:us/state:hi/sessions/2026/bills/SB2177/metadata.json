  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Hawaii Housing Finance and Development Corporation or a county to accept a complete application seeking certain exemptions within 30 days.  Requires HHFDC to process an application and bring it before the Corporation's Board of Directors within 120 days of accepting the application.  Requires county agencies to process an application and bring it before the county's legislative body within 120 days of accepting the application.  Effective 7/1/3000.  (HD1)"
    }
  ],
