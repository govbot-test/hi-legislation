  "subject": [
    "DOH",
    "Vacation Payout Pilot Project"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Health to establish a vacation payout pilot project in which eligible Department of Health employees may defer unused vacation leave credits in favor of a pay out to provide home purchase down payment assistance.  Report required.  Sunsets June 30, 2029."
    }
