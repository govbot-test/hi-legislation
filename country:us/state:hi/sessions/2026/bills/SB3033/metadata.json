  "legislative_session": "2026",
  "identifier": "SB3033",
  "title": "RELATING TO COASTAL ZONE MANAGEMENT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Beach Structure Owners",
    "Coastal Zone Management",
    "DLNR",
    "Imminently Threatened Beach Structures",
    "Petition",
    "Review"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows public petition to the Department of Land and Natural Resources for review of the integrity of beach structures.  Requires the Department to recommend the applicable county agency to order the owner of any beach structure determined to be imminently threatened to resolve, mitigate, and plan for the harmful effects of the beach structure.  Effective 7/1/2050.  (SD1)"
    }
  ],
