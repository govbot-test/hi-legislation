{
  "legislative_session": "2026",
  "identifier": "SB2114",
  "title": "RELATING TO COLLECTIVE BARGAINING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Collective Bargaining",
    "Discharge",
    "Discipline",
    "Exempt Employees",
    "Grievance Procedure",
    "Suspension"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals the prohibition placed on certain employees exempt from Civil Service Law from grieving a suspension or discharge.  Allows any employee who is a member of an appropriate bargaining unit to grieve any disciplinary action, unless prohibited by the applicable collective bargaining agreement.  Effective 7/1/3000.  (HD1)"
    }
  ],
