  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the various requirements in the event of a fetal death, including registration of certain fetal deaths, filing and preparation of a certificate of fetal death, and issuance of a permit for removal, burial, or other disposition.  (SD1)"
    }
  ],
