  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires students of the University of Hawaii, including transfer students, to complete training on federal laws and University policies regarding sexual misconduct prior to the completion of initial registration into the university of Hawaii system.  Amends the frequency that training and programming regarding sexual misconduct is provided to university of Hawaii students and employees."
    }
  ],
