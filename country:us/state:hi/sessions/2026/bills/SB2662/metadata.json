{
  "legislative_session": "2026",
  "identifier": "SB2662",
  "title": "RELATING TO GOVERNMENT ACCOUNTABILITY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Audit",
    "Auditor",
    "Exceptions",
    "External Consultants",
    "Purchasing Agencies",
    "Reports"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires each purchasing agency to provide justification for hiring external consultants.  Requires each agency to seek approval from the Legislature for consulting contracts exceeding a certain dollar amount.  Requires annual reports to the Legislature.  Requires the Compliance Audit Unit within the Office of the Auditor to conduct regular audits of agency consultant contracts to assess cost-effectiveness and compliance.  Establishes exceptions.  Requires each chief procurement officer to ensure that inherent government functions are not delegated to a contractor.  Effective 1/1/2525.  (SD2)"
    }
  ],
