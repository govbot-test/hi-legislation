  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Tenant Displacement Working Group within the Hawaii Housing Finance and Development Corporation to address tenant displacement and relocation in the State.  Requires the Tenant Displacement Working Group to report to the Legislature.  Appropriates Funds.  Effective 7/1/2050.  (SD1)"
    }
