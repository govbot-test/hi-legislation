  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an apprenticeship program income tax credit for certain qualified costs incurred by a taxpayer for a qualified apprenticeship program.  Sunsets 12/31/2036.  Effective 7/1/3000.  (HD3)"
    }
