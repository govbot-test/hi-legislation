  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires Honolulu Community College, in partnership with state agencies and maritime employers, to conduct a study and develop a plan for a statewide Maritime Youth Apprenticeship Pathway Program for individuals ages 16 to 24.  Requires a report to the Legislature with recommendations on program structure, resource needs, proposed legislation and implementation options.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
