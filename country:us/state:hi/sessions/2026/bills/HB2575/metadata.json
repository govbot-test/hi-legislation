  "abstracts": [
    {
      "note": "description",
      "abstract": "Applies the retail or higher general excise tax or use tax rate to purchases or imports of new motor vehicles by rental car companies.  Appropriates funds for a position in the Department of Taxation.  Effective 7/1/3000.  (HD1)"
    }
  ],
