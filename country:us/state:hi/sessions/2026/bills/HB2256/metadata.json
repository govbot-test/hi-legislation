  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that untaxed tobacco products are subject to forfeiture as contraband, without regard to the procedures set forth in Hawaii's asset forfeiture law in the same manner as untaxed cigarettes.  Confirms the authority of the Department of Taxation and the Department of the Attorney General to inspect and seize tobacco products, including electronic smoking devices and e-liquids.  Effective 7/1/3000.  (HD1)"
    }
  ],
