  "abstracts": [
    {
      "note": "description",
      "abstract": "Extends for 10 years the master lease of Mauna Kea lands that is set to expire on December 31, 2033.  Requires that subleases of Mauna Kea lands to astronomical observatories be extended for 10 years."
    }
