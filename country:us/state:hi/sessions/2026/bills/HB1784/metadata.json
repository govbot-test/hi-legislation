  "identifier": "HB1784",
  "title": "RELATING TO EDUCATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "DOE",
    "Dyslexia-Sensitive Universal Screening",
    "Professional Development",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning no later than the 2028-2029 school year, requires the Department of Education to administer a dyslexia-sensitive universal screening to all students in kindergarten through grade three.  Beginning with the 2028-2029 school year, requires certain employees of public schools to have an opportunity to participate in training on literacy instruction.  Requires a report to the Legislature and Board of Education before the 2031-2032 school year.  Appropriates funds."
    }
  ],
