  "abstracts": [
    {
      "note": "description",
      "abstract": "Includes the Chief Investigator and Chief Special Investigator of the Department of Law Enforcement as class A members of the pension and retirement system.  Establishes guidance for the computation of retirement benefits for the Adjutant General, Deputy Adjutant General, Fire Marshal, and Deputy Fire Marshal.  (HD2)"
    }
  ],
