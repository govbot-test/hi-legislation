  "identifier": "SB2057",
  "title": "RELATING TO LAW ENFORCEMENT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "County Law Enforcement Agencies",
    "Federal Immigration Authorities",
    "Immigration Enforcement",
    "Law Enforcement Officials",
    "Prohibition",
    "State Law Enforcement Agencies"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits any law enforcement agency or law enforcement official from entering into an agreement under federal law that permits state or county agencies to engage in immigration enforcement.  Prohibits law enforcement agencies and law enforcement officials from engaging in certain immigration-related actions, except under limited circumstances.  (CD1)"
    }
  ],
