  "legislative_session": "2026",
  "identifier": "SB2370",
  "title": "RELATING TO RENEWABLE ENERGY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Carbon Dioxide Continuous Emissions Monitoring Systems",
    "Carbon Emissions",
    "DOH",
    "Renewable Energy"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Before January 1, 2028, requires every renewable energy source with measurable carbon dioxide emissions that is regulated by the Clean Air Branch of the Department of Health to operate an in-stack carbon dioxide continuous emissions monitoring system in each smokestack.  Establishes carbon dioxide emissions rate standards for renewable energy sources for compliance with renewable portfolio standards."
    }
  ],
