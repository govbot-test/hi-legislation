  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a two-year pilot project to authorize public employers to petition for temporary restraining orders and injunctions against employment-related harassment of certain public employees.  Appropriates funds.  Sunsets 6/30/2028.  Effective 7/1/3000.  (SD1)"
    }
  ],
