{
  "legislative_session": "2026",
  "identifier": "SB3123",
  "title": "RELATING TO PRIVATE SUPPORT OF EDUCATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Conditional Gifts",
    "Contractual Relationships",
    "Donor-Conditioned Educational Awards",
    "Educational Gifts",
    "School-Conditioned Enrollment"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that free tuition at private educational institutions or school-conditioned enrollment at private educational institutions where no tuition or other monetary consideration is required or paid by the recipient are to be considered conditional gifts that support educational advancements rather than contractual obligations unless the parties agree otherwise in writing.  (SD1)"
    }
  ],
