{
  "legislative_session": "2026",
  "identifier": "HB2387",
  "title": "RELATING TO WORKERS' COMPENSATION MEDICAL BENEFITS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Cancer",
    "Disease",
    "Firefighters",
    "Workers' Compensation Medical Benefits"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands workers' compensation medical benefits for firefighters to include coverage for adenocarcinoma or mesothelioma of the respiratory system; cancer of the buccal cavity, cervix, colon, esophagus, ovary, pharynx, skin, female reproductive organs, including the uterus, endometrium, and fallopian tubes, and thyroid; and malignant melanoma.  Specifies that an employer may deny medical benefits under workers' compensation law only if they prove that the cancer or disease was not associated with firefighting duties.  Effective 7/1/3000.  (HD1)"
    }
  ],
