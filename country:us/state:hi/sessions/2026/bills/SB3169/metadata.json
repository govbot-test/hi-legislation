  "title": "RELATING TO COASTAL RESILIENCE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Coastal Resilience Pilot Program",
    "DBEDT",
