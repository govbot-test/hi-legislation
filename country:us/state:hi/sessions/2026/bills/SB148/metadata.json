  "identifier": "SB148",
  "title": "RELATING TO COMBAT SPORTS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Boxing and Combat Sports Commission of Hawaii",
    "Combat Sports Contests",
    "Mixed Martial Arts Contests",
    "Prohibitions",
    "Repeal",
    "State Boxing Commission of Hawaii"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Renames the State Boxing Commission of Hawaii as the Boxing and Combat Sports Commission of Hawaii.  Creates a subcommission on boxing and subcommission on combat sports.  Amends the jurisdiction of the Commission to include combat sports contests.  Prohibits no rules combat or similar combat sports contests.  Repeals the existing Mixed Martial Arts Contests program.  Appropriates funds.  Effective 7/1/3000.  (HD3)"
    }
  ],
