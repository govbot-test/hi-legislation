{
  "legislative_session": "2026",
  "identifier": "SB2601",
  "title": "RELATING TO PROCUREMENT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Certification of Available Funds",
    "Chief Procurement Officer",
    "Penalties",
    "Positions",
