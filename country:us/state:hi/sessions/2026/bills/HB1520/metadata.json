  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that the five\u2011year statute of limitations for criminal prosecutions of campaign finance violations begins upon discovery of the offense by the Campaign Spending Commission.  Effective 3/22/2075.  (SD1)"
    }
