  "identifier": "SB2424",
  "title": "RELATING TO THE HAWAII HOUSING FINANCE AND DEVELOPMENT CORPORATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Affordable Housing",
