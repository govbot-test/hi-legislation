  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Removes the prohibition against qualified residents for Hawaii Housing Finance and Development Corporation-approved projects holding a majority interest in land and removes the requirement that qualified residents demonstrate financial viability or ability to pay rent.  Amends exemptions from statutes, ordinances, charter provisions, and rules for certain housing projects developed by the Corporation that satisfy certain conditions, including requirements related to employment, owner-occupancy, and deed restrictions.  Effective 7/1/3000.  (HD1)"
    }
  ],
