  "identifier": "SB2683",
  "title": "RELATING TO THE HOUSEHOLD AND DEPENDENT CARE SERVICES TAX CREDIT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Applicable Percentage",
    "Employment-related Expenses",
    "Household and Dependent Care Services Tax Credit",
    "Taxation"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases a taxpayer's applicable percentage of employment-related expenses that is used to calculate the household and dependent care services tax credit.  Extends the sunset date of the temporary increase in maximum employment-related expenses that are used to calculate the household and dependent care services tax credit, established by Act 163, SLH 2023, to 6/30/2030.  Sunsets 6/30/2030."
    }
  ],
