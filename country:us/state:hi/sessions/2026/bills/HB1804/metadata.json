{
  "legislative_session": "2026",
  "identifier": "HB1804",
  "title": "RELATING TO LONG-TERM CARE FINANCING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "EOA",
    "Home- and Community-Based Care",
    "Long-Term Care Financing",
