  "abstracts": [
    {
      "note": "description",
      "abstract": "Limits the independent audit requirement to deposit beverage distributors who distribute 2,000,000 or more deposit beverage containers a year.  Identifies frequency of obtaining and submitting independent audits based on quantities of deposit beverage containers imported, manufactured, or distributed. Creates minimum requirements for independent audits."
    }
  ],
