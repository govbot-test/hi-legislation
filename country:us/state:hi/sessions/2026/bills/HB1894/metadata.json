{
  "legislative_session": "2026",
  "identifier": "HB1894",
  "title": "RELATING TO EDUCATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Braille Instruction",
    "Braille Instructional Materials",
    "Braille Literacy Support Services",
    "DOE",
    "Individualized Education Programs",
    "Section 504 Plans"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Education to include the instruction of braille and provision of braille instructional materials under certain circumstances; provide braille literacy support services; cooperate with the Department of Human Services when requested to submit information necessary to maintain a register of the blind in the State; provide comprehensive information about braille literacy services, assistive technology devices, and assistive technology services, including educational programming options; and participate in the development of section 504 plans and individualized education programs.  Appropriates funds.  (CD1)"
    }
  ],
