  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Transportation to implement a pilot program to allow for mobile vehicle safety inspections for passenger cars.  Establishes a four-year sunset date on the pilot program.  Effective 7/1/3000.  (HD1)"
    }
