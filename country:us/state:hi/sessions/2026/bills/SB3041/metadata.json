  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires businesses or restaurants open to the public to post a color-coded placard indicating whether the business or restaurant allows firearms or large knives to be brought onto the premises.  By January 1, 2027, requires the Department of Law Enforcement to provide businesses and restaurants with free and easily downloadable placards.  Effective 1/1/2027."
    }
  ],
