  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires that real property leases between state government entities cost no more than $1 per year except if the real property subject to the lease is being used by a department to meet a core responsibility of that department.  Effective 7/1/3000.  (HD1)"
    }
  ],
