  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes registered nurses and qualified state-licensed health care professionals who are participating in a community paramedicine program approved by the Department of Health who are licensed by the State to administer medication as part of an assisted community treatment order's treatment plan to the subject of the order, under certain circumstances.  Effective 7/1/3000.  (HD1)"
    }
  ],
