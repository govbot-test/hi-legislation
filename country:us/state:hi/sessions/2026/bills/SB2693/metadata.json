  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the issuance of $15 million in general obligation bonds to finance the planning, design, and construction of a 50,000 square foot aerospace hangar and related facilities at Hilo international airport.  Requires matching contributions from the federal government and private sector.  Directs appropriation to be expended by the Department of Transportation.  Requires a report to the Legislature.  Effective 7/1/2050.  (SD1)"
    }
  ],
