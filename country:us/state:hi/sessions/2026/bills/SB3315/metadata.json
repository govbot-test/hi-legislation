  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows applicants or primary caregivers to make a one-time purchase of medical cannabis after the submission of the applicant's certification form while waiting for confirmation of registration from the Department of Health.  Requires the Office of Medical Cannabis Control and Regulation to facilitate the temporary authorization.  Effective 3/22/2075.  (SD2)"
    }
  ],
