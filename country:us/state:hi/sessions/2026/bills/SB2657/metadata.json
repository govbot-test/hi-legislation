{
  "legislative_session": "2026",
  "identifier": "SB2657",
  "title": "RELATING TO ALZHEIMER'S DISEASE AND RELATED DEMENTIAS RESEARCH.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Alzheimer's Disease and Related Dementias",
    "Appropriation ($)",
    "Center on Aging",
    "JABSOM",
    "Positions",
    "Reports",
    "Research Center",
    "UH"
