  "subject": [
    "DBEDT",
    "Hilo-Kona Transportation Pilot Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Hilo-Kona transportation pilot program within the Department of Business, Economic Development, and Tourism to study, plan, evaluate, implement, and trial transportation routes and services connecting Hilo and Kona.  Effective 7/1/3000.  (HD1)"
    }
  ],
