{
  "legislative_session": "2026",
  "identifier": "HB1548",
  "title": "RELATING TO SENTENCING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Misdemeanors",
    "Nonviolent Offenses",
    "Penal Code",
    "Sentencing"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Limits the maximum term of imprisonment for misdemeanors that are not crimes of violence, or for offenses that are not crimes of violence punishable by up to or not exceeding one year, to three hundred sixty-four days.  Allows individuals previously sentenced to a one-year term of imprisonment for an offense that is not a crime of violence to apply to the trial court for reconsideration of the sentence to conform to the revised maximum penalty.  (CD1)"
    }
  ],
