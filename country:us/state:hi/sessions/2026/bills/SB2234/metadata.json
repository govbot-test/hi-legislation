  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies the definition of \"qualified nonprofit housing trust\" in chapter 201H, Hawaii Revised Statutes, to require qualifying organizations to exclusively serve \"qualified residents\" as defined in section 201H-32, Hawaii Revised Statutes.  Effective 7/1/2050.  (SD1)"
    }
