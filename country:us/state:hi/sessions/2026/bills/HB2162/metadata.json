  "identifier": "HB2162",
  "title": "RELATING TO CONDOMINIUMS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Boards of Directors",
    "Condominium Associations",
