    "DCCA",
    "Enforcement",
    "Penalty",
    "Replacement Reserves"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires a condominium association to deposit at least ten per cent of all revenues for each fiscal year, except for estimated replacement reserve assessments, into the total replacement reserves fund of the association.  Requires the Real Estate Commission to enforce the minimum deposit requirement and allows unit owners to file complaints with the Commission.  Holds board members who fail to comply with the minimum deposit requirement personally liable and subject to a fine."
    }
  ],
