  "abstracts": [
    {
      "note": "description",
      "abstract": "Directs the Department of Human Services to convene a working group to develop a statewide Kama\u02bbaina credit program to assist asset limited, income constrained, employed households to pay for essential living costs.  Requires a report to the Legislature."
    }
  ],
