{
  "legislative_session": "2026",
  "identifier": "SB3203",
  "title": "RELATING TO AIR MEDICAL SERVICES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOH",
    "Emergency Medical Services Special Fund",
    "Positions",
    "State Emergency Medical Services System",
    "Statewide Air Medical Services Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Statewide Air Medical Services Program within the Department of Health, Emergency Medical Services and Injury Prevention Systems Branch to coordinate and strengthen air medical services.  Establishes the positions of an air medical director, an air medical program manager, and an air medical coordinator.  Specifies that annual licensure and accreditation fees are to be deposited into the Emergency Medical Services Special Fund for costs of the program.  (CD1)"
    }
  ],
