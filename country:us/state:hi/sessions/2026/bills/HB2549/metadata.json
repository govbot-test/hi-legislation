  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Clean Plant Program within the Department of Agriculture and Biosecurity to support the production, maintenance, and distribution of disease-free, clean plant material to growers, nurseries, and other agricultural producers in the State.  Appropriates funds.  Effective 7/1/3000.  (SD1)"
    }
