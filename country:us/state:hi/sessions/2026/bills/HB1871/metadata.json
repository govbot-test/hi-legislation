  "subject": [
    "Appropriation ($)",
    "DOH",
    "Maternal Health Monitoring Pilot Program",
    "Remote Patient Monitoring"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Maternal Health Monitoring Pilot Program within the Department of Health to offer eligible participants improved maternal health care through remote patient monitoring for maternal hypertension and maternal diabetes.  Appropriates funds.  Effective 1/1/2050.  (SD1)"
    }
  ],
