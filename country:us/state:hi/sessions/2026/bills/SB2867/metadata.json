  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Hawaii Emergency Management Agency, fire chiefs, Law Enforcement Standards Board, and Department of Health to provide or require the provision of at least 1 hour of dementia\u2011specific training for first responders, including law enforcement officers, fire first responders, and emergency medical services personnel.  Requires the Executive Office on Aging to review and recommend dementia-specific training curricula that address the recognition and signs of Alzheimer's disease and related types of dementia."
    }
  ],
