{
  "legislative_session": "2026",
  "identifier": "HB2581",
  "title": "RELATING TO EMERGENCY MANAGEMENT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Disasters",
    "Emergencies",
    "Emergency Management",
    "Emergency Powers",
    "HIEMA",
    "Hawaii Community Resilience Hub Program",
    "Preparedness",
    "Reports"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies the types of events that constitute disasters and emergencies for the purposes of emergency management.  Establishes the Hawaii Community Resilience Hub Program within the Hawaii Emergency Management Agency to support the development of community-based resilience hubs across the State and leverage federal, philanthropic, and private-sector funding for disaster preparedness and climate resilience.  Requires the Agency to identify locations on each island that can be used as state disaster response and mitigation hubs when a state of emergency is declared.  Requires annual reports to the Legislature.  Appropriates moneys.  Effective 7/1/2055.  (SD2)"
    }
  ],
