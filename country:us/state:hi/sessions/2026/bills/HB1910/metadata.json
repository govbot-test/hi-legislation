  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Hawaii Department of Transportation to identify any roadways other than Makakilo Drive that may be used as emergency egress routes in Makakilo.  Requires the Department to plan for, design, and construct an emergency egress route in Makakilo under certain circumstances.  Appropriates moneys."
    }
  ],
