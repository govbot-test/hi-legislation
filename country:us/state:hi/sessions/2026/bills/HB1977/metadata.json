  "subject": [
    "Appropriation ($)",
    "DOH",
    "Maternal and Infant Health Information Mobile Application",
    "Mobile Pregnancy Application",
    "Request for Proposals"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Health to procure a Maternal and Infant Health Information Mobile Application by 1/1/2027 to provide qualified individuals with information on federal and state programs and resources for prenatal, pregnant, and postpartum individuals and their families.  Requires DOH to issue a request for proposals.  Authorizes DOH to procure or otherwise contract for an existing mobile pregnancy application.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
