  "abstracts": [
    {
      "note": "description",
      "abstract": "Renames the Harbors Division of the Department of Transportation to the Commercial Ports Division and distinguishes between the terms \"harbor\" and \"commercial port\" throughout the Hawaii Revised Statutes.  Effective 7/1/3000.  (HD1)"
    }
  ],
