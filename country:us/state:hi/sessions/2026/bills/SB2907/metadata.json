  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Declares that the State is an ocean cluster.  Establishes the Office of Marine Affairs and Marine Affairs Governing Board within the Hawaii Technology Development Corporation.  Establishes the Marine Affairs Coordinator position.  Repeals the powers and duties of the Department of Business, Economic Development, and Tourism over marine affairs.  Transfers the employees and functions of the Governor's Advisory Committee on Marine Affairs to the Office of Marine Affairs.  (CD1)"
    }
  ],
