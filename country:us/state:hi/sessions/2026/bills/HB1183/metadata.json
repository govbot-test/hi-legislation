  "abstracts": [
    {
      "note": "description",
      "abstract": "Includes certain law enforcement administrators and employees of the Department of Law Enforcement as class A members of the pension and retirement systems and provides guidance for the computation of retirement benefits similar to police officers.  Effective 7/1/3000.  (HD3)"
    }
