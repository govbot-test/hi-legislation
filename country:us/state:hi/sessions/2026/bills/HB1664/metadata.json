  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows impasses and disputes relating to the amounts of State and county contributions to the Hawaii Employer-Union Health Benefits Trust Fund (EUTF) to be resolved by arbitration.  Repeals the prohibition against strikes by members of bargaining units on the issue of the amounts of State and county contributions to the EUTF.  Effective 3/22/2075.  (SD1)"
    }
  ],
