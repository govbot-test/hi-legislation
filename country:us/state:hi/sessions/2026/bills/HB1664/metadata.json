{
  "legislative_session": "2026",
  "identifier": "HB1664",
  "title": "RELATING TO THE HAWAII EMPLOYER-UNION HEALTH BENEFITS TRUST FUND.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Arbitration",
    "Collective Bargaining",
    "Contributions",
    "Disputes",
    "EUTF",
