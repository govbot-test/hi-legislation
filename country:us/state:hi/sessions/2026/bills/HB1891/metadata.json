  ],
  "subject": [
    "DOE",
    "Dyslexia Screening",
    "Evidence-Based Interventions",
    "Teacher Professional Development ($)",
    "Universal Screening"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Education to implement dyslexia sensitive linguistically appropriate universal screenings and evidence-based interventions, offer professional development on structured literacy and evidenced-based interventions, and support pre-teacher programs in training candidates in structured literacy instruction.  (CD1)"
    }
  ],
