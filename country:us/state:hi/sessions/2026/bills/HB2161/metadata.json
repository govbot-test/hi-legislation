  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Daniel K. Inouye College of Pharmacy Special Fund to support pharmacist workforce assessment and planning efforts.  Establishes the pharmacist workforce assessment fee.  Appropriates funds.  Effective 7/31/2055.  (SD1)"
    }
