  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Agriculture and Biosecurity to establish rules allowing the sale and distribution of fine mesh nets, including monofilament netting, in the State to protect plants from the coconut rhinoceros beetle."
