  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Mapping of Arts Data for Education Task Force to conduct a study and develop a comprehensive, publicly available statewide database and geographic information systems map of arts entities and programs engaged in arts and arts education.  Requires interim and final reports to the Legislature.  Task Force sunsets upon submission of final report to the Legislature.  Effective 7/1/3000.  (SD1)"
    }
  ],
