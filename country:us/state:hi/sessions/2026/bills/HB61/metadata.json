  ],
  "subject": [
    "Appropriations ($)",
    "County Coroners",
    "Medical Examiners"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the mayor of each county to appoint, and the county council or city council to confirm, a county medical examiner.  Provides that the medical examiner for each county shall serve as the county's coroner.  Makes conforming amendments.  Appropriates moneys to the counties of Maui, Hawaii, and Kauai, for the establishment of county medical examiner positions."
    }
  ],
