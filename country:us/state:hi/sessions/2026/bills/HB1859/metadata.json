  ],
  "subject": [
    "Comprehensive Statewide Workforce Strategy",
    "Facilitation",
    "Interagency Alignment",
    "WDC",
    "Workforce Development"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Workforce Development Council to recommend to the Governor, a comprehensive Statewide Workforce Strategy to inclusion in the State Unified Plan and be responsible for facilitating the alignment of workforce development efforts and programs conducted by state departments and agencies to achieve the State Unified Plan and the Comprehensive Statewide Workforce Strategy.  Effective 7/1/3000.  (HD1)"
    }
  ],
