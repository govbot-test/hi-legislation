  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Land and Natural Resources' Division of Aquatic Resources to begin the Holomua Marine Initiative process no later than 7/1/2027 to address coral reef restoration on Oahu.  Effective 7/1/3000.  (HD2)"
    }
  ],
