  "identifier": "HB2490",
  "title": "RELATING TO COASTAL RESILIENCE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Coastal Resilience Pilot Program",
    "DBEDT",
    "Historic Preservation Review",
