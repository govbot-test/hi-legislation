{
  "legislative_session": "2026",
  "identifier": "SB3063",
  "title": "RELATING TO DEPARTMENT OF EDUCATION PROCUREMENT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOE",
    "Exemption",
    "Food",
    "Local",
    "Procurement"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Exempts from the Hawaii Public Procurement Code procurements by the Department of Education of any amount of local edible produce and packaged food products that do not cost more than five per cent of non-local alternatives.  Effective 7/1/3000.  (HD1)"
    }
  ],
