  "abstracts": [
    {
      "note": "description",
      "abstract": "Permits the Department of Hawaiian Home Lands to conduct a review of the effect of a proposed project on lands under its jurisdiction on historical properties and burial sites, subject to certain requirements.  Appropriates funds.  Effective 7/1/3000.  (HD2)"
    }
