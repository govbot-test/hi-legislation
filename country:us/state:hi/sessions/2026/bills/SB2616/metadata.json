  "abstracts": [
    {
      "note": "description",
      "abstract": "Permits the Department of Education and charter schools to hire unlicensed individuals as teachers on an emergency basis for five, rather than three, years.  Requires the Hawaii Teacher Standards Board to adopt rules."
    }
