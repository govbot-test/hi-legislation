{
  "legislative_session": "2026",
  "identifier": "SB2109",
  "title": "RELATING TO EMERGENCY PREPAREDNESS COMMUNICATIONS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "American Sign Language",
    "Appropriations ($)",
    "Emergency Communications",
    "Emergency Preparedness",
    "HIEMA",
    "Language Access",
    "Limited English Proficiency",
    "Official Announcements",
    "Program",
    "Reports",
    "Sign Language Interpreter"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Hawaii Emergency Management Agency to develop and implement a statewide public education and communications program to promote household emergency preparedness consistent with the Agency's 14-day essential supplies recommendation.  Requires the Governor or mayor of a county to provide an American Sign Language interpreter during each official live broadcast during a state of emergency.  Requires the Governor or mayor of a county to ensure, to the fullest extent possible, that the American Sign Language interpreter's face, body, arms, and hands are visible during the broadcast.  Requires the Governor or mayor of a county to provide a primary pool feed that includes the American Sign Language interpreter in a picture\u2011in\u2011picture window.  Requires reports to the Legislature prior to the Regular Sessions of 2027, 2028, 2029, and 2030.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
