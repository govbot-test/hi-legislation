  "identifier": "SB2211",
  "title": "MAKING AN EMERGENCY APPROPRIATION TO THE DEPARTMENT OF HUMAN SERVICES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
