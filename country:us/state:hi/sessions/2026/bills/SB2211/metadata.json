    "Hawaii Emergency Food Assistance Program",
    "Health Insurance"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides an emergency appropriation to the Department of Human Services to replace general fund appropriations redirected to provide emergency food assistance during the 2025 federal government shutdown.  Appropriates funds to the Department of Human Services to help Hawaii residents obtain insurance available through the federal marketplace.  Effective 7/1/3000.  (HD1)"
    }
  ],
