  "abstracts": [
    {
      "note": "description",
      "abstract": "Declares that the State is an ocean cluster.  Establishes the Office of Marine Affairs under the Hawaii Technology Development Corporation for administrative purposes only.  Establishes the Marine Affairs Coordinator position.  Requires the Marine Affairs Coordinator to submit annual reports to the Governor and Legislature.  Transfers the employees and functions of the Governor's Advisory Committee on Marine Affairs to the Office of Marine Affairs.  Appropriates funds for one full-time equivalent (1.0 FTE) Marine Affairs Coordinator position."
    }
  ],
