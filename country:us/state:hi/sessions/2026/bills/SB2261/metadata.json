  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires Huli Au Ola to conduct a study on physician and dentist recruitment and retention to be located on and serve the island of Molokai.  Requires a report to the Legislature.  Appropriates funds.  Effective 7/1/3000.  (HD2)"
    }
