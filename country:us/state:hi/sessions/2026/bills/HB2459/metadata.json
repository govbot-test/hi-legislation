  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Food and Product Innovation Network to integrate a coordinated food safety and regulatory framework.  Requires the Agribusiness Development Corporation to establish performance indicators for the Food and Product Innovation Network, develop a market access strategy, align and harmonize state branding initiatives, and report certain data to the Legislature.  Appropriates funds.  Effective 7/1/3000.  (HD2)"
    }
  ],
