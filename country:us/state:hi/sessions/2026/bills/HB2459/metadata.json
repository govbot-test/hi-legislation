  "identifier": "HB2459",
  "title": "RELATING TO THE FOOD AND PRODUCT INNOVATION NETWORK.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agribusiness Development Corporation",
