  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a state oversight framework for material health care mergers, acquisitions, and other consolidation transactions. Requires advance notice and public interest review by the State Health Planning and Development Agency.  Requires legislative approval, by concurrent resolution, of certain vertically integrated health care transactions that meet specified market share and pricing impact thresholds."
    }
  ],
