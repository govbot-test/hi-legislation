  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 7/1/2027, prohibits counties from imposing minimum parking mandates for certain developments and limits the minimum parking requirements that may be imposed for other developments.  Effective 7/1/3000.  (HD3)"
    }
