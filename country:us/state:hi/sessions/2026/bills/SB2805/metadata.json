{
  "legislative_session": "2026",
  "identifier": "SB2805",
  "title": "RELATING TO AGRICULTURE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agricultural Investment Tax Credit"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a nonrefundable income tax credit to incentivize significant investment in agricultural production and support the expansion of agricultural crops that take longer to become productive.  Applies to taxable years beginning after 12/31/2026.  Sunsets 1/1/2031.  Effective 7/1/3000.  (HD1)"
    }
  ],
