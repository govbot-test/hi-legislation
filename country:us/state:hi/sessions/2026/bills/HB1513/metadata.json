  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the issuance of reimbursable general obligation bonds in four tranches to provide the necessary funds for the Condominium Loan Program.  Appropriates funds from the Hurricane Reserve Trust Fund to provide initial coverage of the bond payments.  Effective 7/1/3000.  (HD1)"
    }
  ],
