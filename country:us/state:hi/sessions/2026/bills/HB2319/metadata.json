{
  "legislative_session": "2026",
  "identifier": "HB2319",
  "title": "RELATING TO THE STATE HEALTH PLANNING AND DEVELOPMENT AGENCY.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Certificate of Need Exemption",
    "DOH",
    "Function and Responsibilities",
    "SHPDA"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the functions and responsibilities of the State Health Planning and Development Agency.  Adds a new definition of \"health care\" for the purposes of health planning and resource development and health care cost control.  Increase the certificate of need exemption threshold for bed changes to up to thirty per cent of existing licensed beds.  Exempts health care facilities or services operated by the Department of Health from certificate of need requirements.  (CD1)"
    }
  ],
