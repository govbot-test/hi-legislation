    "Hawaii Dementia Initiative Business Recognition Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Hawaii Dementia Initiative Business Recognition Program within the Department of Business, Economic Development, and Tourism.  Requires the Department of Business, Economic Development, and Tourism to collaborate with the Executive Office on Aging to implement the program.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
