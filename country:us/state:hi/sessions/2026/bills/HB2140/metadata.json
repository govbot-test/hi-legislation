  "identifier": "HB2140",
  "title": "RELATING TO ESSENTIAL PERMITTING POSITIONS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Counties",
