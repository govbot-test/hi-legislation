  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a four-year pilot program to improve the speed, accountability, and quality of permit processing through targeted staffing, performance incentives, and interdepartmental competition within participating counties.  Requires annual reports to the Legislature.  Effective 7/1/3000.  (HD2)"
    }
  ],
