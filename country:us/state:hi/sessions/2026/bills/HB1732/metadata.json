  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Kamaaina Homes Pilot Program within the Hawaii Housing Finance and Development Corporation to provide funding to a county, to be designated by the Corporation, to purchase voluntary deed restrictions from eligible homebuyers.  Sunsets 6/30/2032.  Effective 7/1/3000.  (SD1)"
    }
  ],
