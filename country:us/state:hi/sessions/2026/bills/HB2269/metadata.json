  "legislative_session": "2026",
  "identifier": "HB2269",
  "title": "RELATING TO THE MOTION PICTURE, DIGITAL MEDIA, AND FILM PRODUCTION INCOME TAX CREDIT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Department of Business",
    "Digital Media",
    "Economic Development",
    "Motion Picture",
    "Qualified Production",
    "and Film Production Income Tax Credit",
    "and Tourism"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases the qualified production credit from twenty-two per cent to twenty-seven per cent in any county of the State with a population of over seven hundred thousand and twenty-seven per cent to thirty-two per cent in any county of the State with a population of less than seven hundred thousand.  Lifts the per production cap of $17,000,000 for productions with qualified expenditures of $60,000,000 per project.  Increases the annual cap to $60,000,000 from $50,000,000 for the total amount of the motion picture, digital media, and film production income tax credit allowed under section 235-17, HRS, and extends the sunset date of the tax credit to January 1, 2038.  Clarifies and amends the requirement for an independent third-party certification and expands the definition of \"qualified production\" to include streaming platforms for the motion picture, digital media, and film production income tax credit.  Includes a definition of \"streaming platform\"."
    }
  ],
