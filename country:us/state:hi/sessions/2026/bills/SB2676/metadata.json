  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Hawaii Housing Finance and Development Corporation to approve and certify general excise tax exemptions, including for non-contracting costs, for certain housing development projects developed under county housing incentive programs.  Makes conforming amendments.  Sunsets 7/1/2031.  Effective 7/1/2050.  (SD1)"
    }
  ],
