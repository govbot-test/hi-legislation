  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Commerce and Consumer Affairs' Division of Financial Institutions and Hawaii Technology Development Corporation to conduct a two-year study to gather data on how to establish a state-level regulatory framework for stablecoin digital assets.  Requires a report to the Legislature.  Appropriates funds."
    }
  ],
