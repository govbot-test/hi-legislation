{
  "legislative_session": "2026",
  "identifier": "SB3110",
  "title": "RELATING TO THE HAWAII NATIONAL GUARD.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civil Service",
    "Civil-Military Program",
    "Collective Bargaining",
    "Exemption",
    "Hawaii National Guard Youth Challenge Program",
    "Na Kula Alaka\u02bbi"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that employees of the Hawaii National Guard youth and adult educational programs are excluded from collective bargaining.  Renames the \"Hawaii National Guard Youth Challenge Program\" to the \"Hawaii National Guard Civil-Military Program\" and codifies its Hawaiian name, \"Na Kula Alaka\u02bbi\".  Effective 7/1/3000.  (HD2)"
    }
  ],
