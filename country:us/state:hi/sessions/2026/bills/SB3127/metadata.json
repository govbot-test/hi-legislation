  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases the limit of the State's liability for moneys borrowed by the Department of Hawaiian Home Lands or loans made to lessees that are guaranteed by the Department from $100,000,000 to $500,000,000.  Effective 9/9/2129.  (SD1)"
    }
  ],
