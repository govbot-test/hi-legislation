  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits merchants from imposing credit card processing fees or convenience fees, under certain conditions.  Ensures that payment processing costs are reasonable and transparent.  Prohibits merchants from imposing surcharges on debit card transactions.  Effective 1/1/2027."
    }
  ],
