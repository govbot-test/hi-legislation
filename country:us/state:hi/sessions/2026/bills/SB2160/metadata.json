{
  "legislative_session": "2026",
  "identifier": "SB2160",
  "title": "RELATING TO BEEKEEPING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Apiary Program",
    "Appropriation ($)",
