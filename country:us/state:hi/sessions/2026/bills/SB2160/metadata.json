  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies the registration process for beekeepers with the Department of Agriculture and Biosecurity.  Requires the Department of Agriculture and Biosecurity to provide guidance and support to registered beekeepers to help beekeepers adhere to certain industry standards and best management practices.  Establishes a limitation on liability for any registered beekeeper who follows industry standards and best practices.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
