  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Transportation to enter into agreements with the United States Department of Defense for the provision of services at federal military installations, under certain conditions.  Authorizes charging an administrative fee.  Effective 7/1/3000.  (HD1)"
    }
