  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands free school meal coverage, beginning with the 2029-2030 school year, to all public school students, including public charter school students, regardless of whether the student participates in a federal school meals program.  Effective 7/1/3000.  (HD1)"
    }
  ],
