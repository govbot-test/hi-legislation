  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases designated income check-off amounts for the Hawaii Election Campaign Fund to $6 for taxpayers filing individual returns with $6 or more of state income tax liability and for spouses filing joint returns with $12 or more of state income tax liability."
    }
  ],
