  "abstracts": [
    {
      "note": "description",
      "abstract": "Makes emergency appropriations for collective bargaining cost items for the members of bargaining unit (11) and their excluded counterparts, including health premium payments and the cost of salary adjustments negotiated between the State and the bargaining unit representative for fiscal biennium 2025-2027."
    }
