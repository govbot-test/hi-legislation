  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that employees of the Hawaii National Guard youth and adult educational programs are excluded from collective bargaining.  Renames the \"Hawaii National Guard Youth Challenge Program\" to the \"Hawaii National Guard Civil-Military Program\" and codifies its Hawaiian name, \"N\u0101 Kula Alaka\u02bbi\".  Effective 7/1/3000.  (HD1)"
    }
  ],
