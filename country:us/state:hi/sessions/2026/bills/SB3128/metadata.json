  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends sections 208 and 209(a) of the Hawaiian Homes Commission Act, 1920, to include nieces and nephews who are at least one-quarter Native Hawaiian as qualifying relatives of lessees for the purposes of lease transfer and lease successorship."
    }
