  "abstracts": [
    {
      "note": "description",
      "abstract": "For taxable years beginning after 12/31/2026, applies the retail or higher general excise tax or use tax rate to purchases or imports of new motor vehicles by rental car companies.  Appropriates funds to establish a position in the Department of Taxation.  Effective 7/1/2050.  (SD1)"
    }
  ],
