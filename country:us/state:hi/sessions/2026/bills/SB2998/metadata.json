{
  "legislative_session": "2026",
  "identifier": "SB2998",
  "title": "RELATING TO MEDICAL CANNABIS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Discrimination",
    "Employee",
    "Employer",
    "Licensing Boards",
    "Medical Cannabis",
    "Potentially Dangerous Occupations",
    "Professional Licenses",
    "Qualifying Patients",
    "Vocational Licenses"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits an employer from discriminating against a person in hiring, termination, or any term or condition of employment based on the person's status as a medical cannabis registry card holder or lawful use of medical cannabis, under certain conditions.  Authorizes an employer to use a fit-for-duty test for medical cannabis qualifying patients in potentially dangerous occupations under certain conditions.  Prohibits a professional or vocational licensing board from revoking the license of medical cannabis qualifying patients, or otherwise subjecting them to discipline, for their lawful use of medical cannabis, under certain conditions."
    }
  ],
