  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires hosting platforms that earn service fees for providing booking services for transient accommodations to register with the Department of Taxation as tax collection agents and report, collect, and remit general excise and transient accommodations taxes on behalf of operators."
    }
