  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a three-year Tiny Home Grant Pilot Program within the Hawaii Housing Finance and Development Corporation.  Requires counties and nonprofit organizations that are awarded a grant to submit an annual report to the HHFDC.  Requires a report to the Legislature.  Appropriates funds and establishes a position.  Effective 7/1/2050.  (SD1)"
    }
  ],
