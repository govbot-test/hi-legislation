  "legislative_session": "2026",
  "identifier": "HB1769",
  "title": "RELATING TO CORRECTIONAL FACILITIES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Corrections",
    "Out-of-state Prisons",
    "Private",
    "Reports",
    "Return to In-state Correctional Facilities"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Director of Corrections and Rehabilitation to incrementally return committed felons incarcerated in private, out-of-state correctional institutions to in-state correctional facilities.  Requires reports to the Legislature.  Effective 7/1/3000.  (SD1)"
    }
  ],
