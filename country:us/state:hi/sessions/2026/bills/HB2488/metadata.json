  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Disability and Communication Access Board to study the health care communication needs of patients who are deaf, hard-of-hearing, or deaf-blind.  Requires a report to the Legislature.  Effective 7/1/3000.  (SD1)"
    }
  ],
