  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes consumer protections and insurer governance requirements for the use of artificial intelligence systems in certain insurance practices, including health insurance benefit determinations and residential property underwriting decisions.  Establishes review, monitoring, recordkeeping, disclosure, rebuttal, and cure requirements for the use of artificial intelligence systems in certain insurance practices.  Requires the Insurance Commissioner to adopt rules."
    }
  ],
