  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Director of Human Resources Development, in consultation with the Hawaii Climate Change Mitigation and Adaption Commission, State Energy Office, and Department of Accounting and General Services to develop a comprehensive Commuting Choice Benefit Program regardless of mode of transportation for all state employees in the executive branch and to recommend a similar program for state employees of the other branches.  Requires a report to the Legislature."
    }
  ],
