  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 1/1/2027, establishes mandatory handling and storage rules for commercial and residential coconut rhinoceros beetle host material to reduce the spread of CRB within infested zones and to prevent spread into non-infested zones.  Establishes penalties.  Effective 7/1/2050.  (SD1)"
    }
  ],
