  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Hawaiian Home Lands and Department of Land and Natural Resources, in consultation with the Department of Health, to submit to the Legislature a report on the plan for the transfer of powers and duties of Kalaupapa Settlement prior to the Regular Session of 2027.  (SD1)"
    }
