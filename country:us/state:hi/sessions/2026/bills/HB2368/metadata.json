  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a fifty-year duration limit for new private, noncharitable trusts.  Requires large private trusts to file annual reports with the Department of Commerce and Consumer Affairs.  Imposes limitations and reporting requirements on permitted transfers in trusts."
    }
  ],
