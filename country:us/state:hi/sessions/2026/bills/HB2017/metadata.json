  "legislative_session": "2026",
  "identifier": "HB2017",
  "title": "RELATING TO AGRICULTURE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Agricultural Investment Costs",
    "Hawaiian Home Lands",
    "Income Tax Credit"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a nonrefundable income tax credit for certain agricultural investment costs incurred for agricultural activities conducted on Hawaiian home lands.  Applies to costs incurred after 12/31/2026.  Effective 7/1/3000.  (SD1)"
    }
  ],
