  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates funds for the Department of Human Services to contract with one or more organizations specializing in domestic violence to provide training and consultation virtually or in-person to staff in Child Welfare Services Branch offices statewide.  (CD1)"
    }
