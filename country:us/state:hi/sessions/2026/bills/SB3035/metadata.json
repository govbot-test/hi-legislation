  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires a seller of real property adjacent to the shoreline, and the seller's agent, to disclose and include in all advertisements certain shoreline erosion issues related to the parcel.  Effective 7/1/2050.  (SD2)"
    }
  ],
