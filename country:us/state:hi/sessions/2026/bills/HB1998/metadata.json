  "title": "RELATING TO CIVIL RIGHTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Discrimination in Public Accommodations",
    "Discriminatory Practices",
    "Persons with Disabilities",
    "Places of Public Accommodation"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes it as an unlawful discriminatory practice for a place of public accommodation to deny a person with a disability full and equal enjoyment of information related to their services, facilities, privileges, advantages, or accommodations by requiring use of information and communication technology that is not accessible to the person.  Establishes exceptions."
    }
  ],
