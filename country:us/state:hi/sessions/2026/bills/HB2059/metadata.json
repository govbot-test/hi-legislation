  "subject": [
    "Authorized Emergency Vehicles",
    "City and County of Honolulu Mayor's Package",
    "Commercial Driver's License Exemption",
    "Emergency Medical Services Personnel"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Exempts emergency medical services personnel from commercial driver's license requirements.  Expands the definition of \"authorized emergency vehicle\" under the State Traffic Code to replace ambulances with emergency medical services vehicles, and include disaster response and recovery vehicles, Department of Health-approved vehicles, and vehicles designated as emergency vehicles by the State or an emergency management agency.  Effective 7/1/3000.  (HD1)"
    }
  ],
