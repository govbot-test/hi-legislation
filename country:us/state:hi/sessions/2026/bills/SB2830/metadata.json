  "identifier": "SB2830",
  "title": "RELATING TO MISCONDUCT BY A PUBLIC SERVANT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Misconduct in Office",
    "Penal Code",
    "Public Servants",
    "Statute of Limitations"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Extends the statute of limitations for offenses based on misconduct in office by a public servant to allow prosecution at any time during the defendant's period of public service and up to ten years thereafter.  Effective 3/22/2075.  (SD2)"
    }
  ],
