  ],
  "subject": [
    "Business Registration Data",
    "DBEDT",
    "DCCA",
    "Online Availability"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Director of Commerce and Consumer Affairs to make certain contact information for newly registered entities available online.  Requires the Director to transmit the contact information to the Department of Business, Economic Development, and Tourism's Business Development and Support Division.  Effective 7/1/3000.  (HD1)"
    }
  ],
