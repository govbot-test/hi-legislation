{
  "legislative_session": "2026",
  "identifier": "HB2361",
  "title": "RELATING TO THE KANEOHE BAY REGIONAL COUNCIL.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Support",
    "Chairperson",
    "DLNR",
    "Kaneohe Bay Regional Council",
    "Meeting Frequency"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Land and Natural Resources to provide administrative support to the Kaneohe Bay Regional Council.  Requires the chairperson of the Council to be selected by the voting members from among all voting and nonvoting members on an annual and rotating basis.  Requires the Council to meet quarterly.  (CD1)"
    }
  ],
