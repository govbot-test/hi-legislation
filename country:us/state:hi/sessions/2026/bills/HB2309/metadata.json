{
  "legislative_session": "2026",
  "identifier": "HB2309",
  "title": "RELATING TO THE HAWAIIAN HOMES COMMISSION ACT, 1920.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Department of Hawaiian Home Lands",
    "Eligible Transferees and Successors to Homestead Leases",
    "HHCA"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the Hawaiian Homes Commission Act, 1920, as amended, to include children of a sibling as qualifying relatives of lessees for the purposes of lease transfer and lease successorship, in the same manner currently allowed for spouses, children, grandchildren, and siblings.  (CD1)"
    }
  ],
