{
  "legislative_session": "2026",
  "identifier": "HB1872",
  "title": "RELATING TO AN EARLY LEARNING APPRENTICESHIP GRANT PROGRAM.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Child Care",
    "Early Learning Apprenticeship Grant Program",
    "Early Learning Opportunities",
    "Reports",
    "UH"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an Early Learning Apprenticeship Grant Program to be administered by the University of Hawaii to provide financial support for early learning program service providers in the State to participate in state- or federally-approved early learning apprenticeship programs.  Requires an annual report to the Legislature.  Appropriates funds.  Effective 7/31/2055.  (SD1)"
    }
  ],
