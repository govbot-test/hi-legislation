  "identifier": "SB2477",
  "title": "RELATING TO CULTURAL RECOGNITION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DLNR",
    "Hawaii Kai Towne Center",
    "Historical Markers",
    "Maunalua Island",
    "SFCA"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Land and Natural Resources to place historical markers acknowledging the landform on which the Hawaii Kai Towne Center is sited as Maunalua Island and to consult with the State Foundation on Culture and the Arts on the design standard of the historical markers.  Requires the State Foundation on Culture and the Arts to pay for any costs related to the placing of the historical markers.  Effective 7/1/2050.  (SD1)"
    }
  ],
