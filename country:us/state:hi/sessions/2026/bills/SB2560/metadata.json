  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires cardiovascular screening for students, including student athletes.  Requires the Department of Education, in collaboration with the Department of Health, to distribute educational and informational materials regarding sudden cardiac arrest.  Requires the Department of Health to implement policies, programs, training, and continuing education that increase health care provider knowledge of cardiovascular screening guidelines."
    }
  ],
