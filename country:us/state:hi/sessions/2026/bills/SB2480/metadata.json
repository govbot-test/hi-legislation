  "legislative_session": "2026",
  "identifier": "SB2480",
  "title": "RELATING TO ELECTIONS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Primary Elections",
    "Top Two Candidates"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows voters in a primary or special primary election to vote for any candidate for any office without regard to the voter or candidate's political party preference.  Advances the top two candidates in a primary or special primary election, regardless of political party, to the general election.  Effective 3/22/2075.  (SD1)"
    }
  ],
