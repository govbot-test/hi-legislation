{
  "legislative_session": "2026",
  "identifier": "HB2187",
  "title": "RELATING TO HEALTH CARE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Consumer Credit Reporting Agencies",
    "Emergency Medical Services",
    "Health Care Facilities",
    "Health Care Providers",
    "Medical Debt"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits health care facilities, health care providers, and emergency medical services from furnishing medical debt to a consumer credit reporting agency.  Prohibits consumer credit reporting agencies from reporting or maintaining medical debt information in the file on a consumer.  Effective 7/1/3000.  (HD1)"
    }
  ],
