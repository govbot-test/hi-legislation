  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the Hawaiian Homes Commission Act, 1920, as amended, to increase the State's liability limit for moneys borrowed by the Department of Hawaiian Home Lands, or loans made to lessees that are guaranteed by the Department, from $100,000,000 to $500,000,000.  Effective 7/1/3000.  (HD1)"
    }
  ],
