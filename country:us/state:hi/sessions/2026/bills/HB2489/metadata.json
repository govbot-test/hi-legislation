  "subject": [
    "ASL Interpreter Training Program",
    "Appropriation ($)",
    "University of Hawaii"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates moneys to establish a bachelor's degree program in American Sign Language interpretation at the University of Hawaii Manoa campus with a multi-year plan to include a master's degree program for interpreter training.  Effective 7/1/3000.  (HD1)"
    }
  ],
