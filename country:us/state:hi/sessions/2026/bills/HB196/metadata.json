  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Port Worker Advisory Committee to make recommendations to the Department of Transportation regarding management of state-owned and state-managed ports.  Requires the Department to conduct meetings to solicit input from port workers on methods to improve ports and problems faced by port workers."
    }
  ],
