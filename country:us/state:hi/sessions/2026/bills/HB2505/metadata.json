{
  "legislative_session": "2026",
  "identifier": "HB2505",
  "title": "RELATING TO ASSISTED COMMUNITY TREATMENT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Assisted Community Treatment",
    "Community Mental Health Outpatient Programs",
    "Involuntary Hospitalization",
    "Petitions"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that community mental health outpatient programs that have agreed to provide mental health services to a defendant as part of an assisted community treatment order may prepare a certificate for assisted community treatment and provide the certificate to a defendant and may file an assisted community treatment petition with the Family Court.  (CD1)"
    }
  ],
