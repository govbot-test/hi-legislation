  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits the use of algorithmic price-setting in Hawaii's rental market.  Requires the Department of the Attorney General to develop and undertake a public education program regarding the prohibition.  Establishes fines and penalties."
    }
