  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Office of Elections to prepare a questionnaire to which candidates may respond.  Requires the Office of Elections to publish any responses provided by a candidate on its website and in the digital voter information guide no later than eighteen days before a primary election.  Effective 1/1/2027.  (SD1)"
    }
  ],
