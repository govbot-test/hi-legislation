{
  "legislative_session": "2026",
  "identifier": "HB2078",
  "title": "RELATING TO HABITUAL VIOLENT CRIME.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "AG",
    "Criminal Justice Research Institute",
    "Habitual Violent Crime Offenders",
    "Hawaii Law Enforcement Coalition Package",
    "Reports"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Attorney General, in consultation with the Criminal Justice Research Institute, to submit ongoing annual reports to the Legislature on the effectiveness of the habitual violent crime offense in addressing repeat violent crime in the State.  Amends Act 213, SLH 2024, which established the offense of habitual violent crime, by requiring the Criminal Justice Research Institute to submit a one-time report to the Legislature on the effectiveness of the offense prior to the Regular Session of 2031 and extending its sunset date to 6/30/2031.  (CD1)"
    }
  ],
