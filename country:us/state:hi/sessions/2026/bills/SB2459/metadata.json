  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Agriculture and Biosecurity to use consistent units of measurement in its summary to the public on the amounts of restricted use pesticides applied.  Establishes a one-half mile buffer zone for pesticides around schools during normal school hours."
    }
  ],
