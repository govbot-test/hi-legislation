{
  "legislative_session": "2026",
  "identifier": "HB2346",
  "title": "RELATING TO CASH TRANSACTION ROUNDING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Cash Transactions",
    "Pennies",
    "Rounding",
    "Unfair and Deceptive Practices"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires cash transactions to be rounded up or down to the nearest 5 cents.  Requires cash transactions that total $0.01 or $0.02 to be rounded up to $0.05.  Exempts transactions in which payment is made by demand or negotiable instrument, electronic fund transfer, check, gift card, money order, credit card, or other like instrument or method."
    }
  ],
