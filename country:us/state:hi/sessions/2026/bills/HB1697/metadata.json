  ],
  "subject": [
    "Board of Barbering and Cosmetology",
    "Exemption from Licensure",
    "Natural Hair Braiding",
    "Registration"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires natural hair braiders to be registered, rather than licensed, under the Board of Barbering and Cosmetology.  By 11/1/2026, requires the Board to adopt rules prescribing the approved courses or programs on sanitation, health, and safety.  Effective 7/1/3000.  (HD1)"
    }
  ],
