  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the driver of a vehicle to stop for a pedestrian who is crossing the roadway within a crosswalk and not to proceed until the pedestrian has completely exited the crosswalk and the driver can safely proceed.  Effective 7/1/3000.  (HD1)"
    }
  ],
