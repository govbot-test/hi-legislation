  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires notification to the security forces of each branch of the military when a protective order is issued in a case involving a military-affiliated individual.  Requires the Judiciary, Department of Law Enforcement, and county police departments to establish certain policies and procedures.  (CD1)"
    }
  ],
