  "legislative_session": "2026",
  "identifier": "SB2660",
  "title": "RELATING TO SERVICE CHARGES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Limit",
    "Mandatory Gratuity Service Charge",
    "Notification",
    "Party Size",
    "Restaurants"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits restaurants from imposing a mandatory gratuity service charge for food or beverage services unless the party includes ten or more customers, the service charge does not exceed eighteen per cent, and the customer is notified of the service charge."
    }
  ],
