  "abstracts": [
    {
      "note": "description",
      "abstract": "Exempts from the general excise tax, gross receipts from the sale of hearing aids received by a hospital, infirmary, medical clinic, health care facility, pharmacy, or a practitioner licensed to administer drugs to an individual.  Effective 7/1/3000.  (HD1)"
    }
