  "legislative_session": "2026",
  "identifier": "HB1691",
  "title": "RELATING TO TRANSPORTATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Electronic Signature",
    "Indemnification",
    "Salvaged Motor Vehicles",
    "Supporting Documents",
    "Transfer"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes supporting documents used to transfer ownership of a motor vehicle to an insurance company after payment of damages from the result of a total loss insurance settlement to be signed electronically.  Requires insurance companies to indemnify and hold harmless the Director of Finance for any claims resulting from the issuance of motor vehicle titles utilizing documents signed electronically without a notary.  Effective 7/1/2027.  (SD1)"
    }
  ],
