  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Transportation to establish a Clean Transportation Alternatives Incentive Program that returns funds to eligible residents of the State who meet a certain income threshold or use a certain amount of gasoline as fuel for transportation."
    }
