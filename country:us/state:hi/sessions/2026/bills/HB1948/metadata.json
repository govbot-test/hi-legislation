  "legislative_session": "2026",
  "identifier": "HB1948",
  "title": "RELATING TO SINGLE-USE PLASTICS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Fines",
    "Lodging Establishments",
    "Personal Care Products",
    "Prohibition",
    "Small Plastic Containers"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits lodging establishments from providing personal care products in small plastic containers within sleeping room accommodations, any space within sleeping room accommodations, or bathrooms used by the public or guests.  Establishes civil penalties.  Effective 7/1/3000.  (HD2)"
    }
  ],
