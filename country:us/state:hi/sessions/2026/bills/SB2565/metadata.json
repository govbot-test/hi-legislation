  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a fixed disposition deadline requiring the Supreme Court to decide an application for certiorari within 60 days after the application is filed.  Applies prospectively to cases in which the judgment or dismissal order of the Intermediate Court of Appeals was filed on or after the effective date of this Act."
    }
  ],
