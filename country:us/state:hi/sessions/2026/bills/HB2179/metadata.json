  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires, rather than authorizes, the Department of Education to develop and administer a Traffic Safety Education Program.  Requires the Department of Education's Traffic Safety Education program to include electric bicycles.  Effective 7/1/3000.  (HD2)"
    }
