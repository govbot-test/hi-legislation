  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands the membership of the Hawaii State Lesbian, Gay, Bisexual, Transgender, Queer Plus Commission from eight voting members to eleven by adding one seat for a person under the age of twenty-nine and one seat each for the appointees of the Speaker of the House of Representatives and Senate President, respectively.  Effective 7/1/3000.  (HD1)"
    }
  ],
