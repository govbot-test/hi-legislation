{
  "legislative_session": "2026",
  "identifier": "SB2844",
  "title": "RELATING TO IMAGE-BASED SEXUAL ABUSE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Nonconsensual Disclosure of Intimate or Private Images"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the nonconsensual disclosure of intimate or private images as a criminal offense.  Amends the criteria for an extended term of imprisonment to include an offender whose act of attempting to commit or committing the nonconsensual disclosure of intimate or private images against a minor or vulnerable adult resulted in the victim's death."
    }
  ],
