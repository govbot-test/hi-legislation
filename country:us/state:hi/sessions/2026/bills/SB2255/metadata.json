  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Director of Business, Economic Development, and Tourism to adopt rules to require that diesel fuel sold in the State for use in on-highway diesel-powered motor vehicles contains no less than five per cent biodiesel by volume."
    }
