  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits the Department of Law Enforcement, Department of Land and Natural Resources, Department of Taxation, and Department of the Attorney General from appointing or employing certain former United States Immigration and Customs Enforcement or Border Patrol agents and employees as law enforcement officers.  Effective 7/1/3000.  (HD1)"
    }
  ],
