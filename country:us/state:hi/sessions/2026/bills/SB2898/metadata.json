  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates funds for the Department of Human Services to contract with one or more organizations specializing in domestic violence to provide training and on-site staff in Child Welfare Services Branch offices to support all aspects of screening for and addressing domestic violence within a case."
