  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies insurance requirements for single-family and multi-family housing projects to obtain expedited permitting from county agencies.  Clarifies that state or county inspectors shall inspect all projects with expedited permits.  Effective 7/1/2050.  (SD2)"
    }
  ],
