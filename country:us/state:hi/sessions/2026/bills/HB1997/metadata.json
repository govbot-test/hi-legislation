  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the inclusion of provisions addressing individualized accommodations and supports during emergency situations and evacuations in individualized education programs and section 504 plans for students with disabilities.  Requires support and guidance from the Department of Education.  Effective 7/1/3000.  (HD2)"
    }
  ],
