  ],
  "subject": [
    "Carbon Emissions",
    "DLNR",
    "Marine Ecosystem Restoration",
    "Nature-Based Carbon Sequestration",
    "Report"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a state goal to strengthen nature-based carbon emissions reduction solutions.  Directs certain state agencies to identify opportunities for investing in nature-based solutions that reduce carbon emissions.  Authorizes the Department of Land and Natural Resources to develop methodologies to quantify carbon emissions reductions through marine ecosystem restoration and nature-based solutions.  Requires a report to the Legislature.  Effective 7/1/2050.  (SD1)"
    }
  ],
