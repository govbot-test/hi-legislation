  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Affordable Housing Land Inventory Task Force within the Office of Planning and Sustainable Development to conduct a study, subject to legislative appropriation, on how to maximize housing development in transit-oriented development zones or other areas on state or county lands.  Requires a report to the Legislature.  Establishes a position.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
