  "subject": [
    "Digital Media",
    "Motion Picture",
    "Post-production",
    "Principal Photography",
    "Qualifications",
    "and Film Production Income Tax Credit"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the requirements for productions to qualify for the Motion Picture, Digital Media, and Film Production Income Tax to include completing at least fifteen per cent of the production's principal photography and post-production in the State within the same taxable year the production is qualifying for the Tax Credit."
    }
  ],
