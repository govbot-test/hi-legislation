  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Transportation to assist and enable a person to voluntarily purchase a verified carbon offset for greenhouse gas emissions resulting from the person's air travel to or from an airport in the State.  Effective 7/1/3000.  (HD1)"
    }
