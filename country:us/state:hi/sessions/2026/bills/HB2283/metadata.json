  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies the consulting role and responsibilities of the Department of Transportation in the Department of Commerce and Consumer Affairs' development and implementation of pilot licensure standards, requirements, and criteria.  Repeals the inclusion of Port Allen as part of the waters of the State that are regulated by statutory pilotage requirements.  Effective 7/1/3000.  (HD1)"
    }
  ],
