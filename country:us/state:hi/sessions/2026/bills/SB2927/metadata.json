  ],
  "subject": [
    "Competitive Sealed Proposals",
    "Disclosure of Competing Proposals",
    "Hawaii Public Procurement Code"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits a procurement officer from disclosing a competing offeror's proposal or evaluation score, except the summary of scores, to a non-selected offeror until after any protest is resolved and the contract is executed.  Effective 1/1/2525.  (SD1)"
    }
  ],
