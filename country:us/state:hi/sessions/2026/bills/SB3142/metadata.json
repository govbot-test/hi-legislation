{
  "legislative_session": "2026",
  "identifier": "SB3142",
  "title": "RELATING TO DANGEROUS INTOXICATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Dangerous Intoxication",
    "Habitual Dangerous Intoxication",
    "Offenses Against Public Order",
    "Penal Code"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the offenses of dangerous intoxication and habitual dangerous intoxication.  Provides for civil protective custody and transport for emergency examination in lieu of arrest for dangerous intoxication in specified circumstances, and bars prosecution when civil protective custody is used.  Requires probation with mandatory treatment for habitual dangerous intoxication, with incarceration only upon probation violation.  Makes conforming amendments to chapter 334, HRS, relating to admission to psychiatric facilities and assisted community treatment.  Delays implementation by one year.  Effective 7/1/3000.  (HD1)"
    }
  ],
