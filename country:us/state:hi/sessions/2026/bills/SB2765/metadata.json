{
  "legislative_session": "2026",
  "identifier": "SB2765",
  "title": "RELATING TO CONDOMINIUMS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Associations",
    "Condominiums",
    "Foreclosures",
    "Rental Income",
    "Third\u2011Party Commissioners"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that condominium associations that have obtained title to a unit through foreclosure may retain rental income received prior to the appointment of a commissioner in a subsequent foreclosure, but the association may be required by a court to remit rental income received after the appointment of a commissioner to be held until an order of distribution is entered by the court.  Effective 7/1/3000.  (HD1)"
    }
  ],
