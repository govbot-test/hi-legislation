{
  "legislative_session": "2026",
  "identifier": "SB2268",
  "title": "RELATING TO EQUITY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Equity",
    "Exemptions",
    "Public Accommodations",
    "Public Entity Construction",
    "Universal Changing Accommodations"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires all places of public accommodation and public entity construction projects planned and designed after 7/31/2027 to provide at least one universal changing accommodation within the building in a public restroom, with certain exceptions.  Makes conforming amendments to sections 489-6, 489-7.5, and 489-8, HRS, to prevent conflicts among the provisions.  (CD1)"
    }
  ],
