{
  "legislative_session": "2026",
  "identifier": "SB1432",
  "title": "RELATING TO CHANGES TO RESPONSIBILITIES OF THE DEPARTMENT OF HEALTH CONCERNING PATIENTS, THE COUNTY OF KALAWAO, AND THE KALAUPAPA SETTLEMENT.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Annual Report",
    "DOH",
    "Expenses",
    "Hansen's Disease",
    "Rules",
    "Transfer to the County of Maui"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Health to continue providing services statewide to Hansen's disease patients living in the community.  Repeals sections of Chapter 326, Hawaii Revised Statutes, upon the 1\u2011year anniversary of the passing of the last patient resident of Kalaupapa as affirmed in the Governor's proclamation.  Requires the Department of Health to include community organizations in the transition planning team.  (CD1)"
    }
  ],
