  "legislative_session": "2026",
  "identifier": "HB1524",
  "title": "RELATING TO PEDESTRIANS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Fines",
    "Limitation",
    "Pedestrian",
    "Violations"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes that fines for pedestrian violations under chapter 291C, Hawaii Revised Statutes, shall not exceed $25.  Requires state and county agencies to revise applicable schedules of fines, rules, and procedures to comply with the monetary limit.  Effective 3/22/2075.  (SD1)"
    }
  ],
