  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Local Agriculture Transportation Cost Reimbursement Pilot Program within the Department of Agriculture and Biosecurity to reimburse eligible ranchers and farmers a portion of their costs to transport livestock, livestock products, agricultural commodities, and certain necessary supplies, under certain conditions.  Establishes a position to administer the Program.  Appropriates funds.  Sunsets 6/30/2029.  (CD1)"
    }
  ],
