{
  "legislative_session": "2026",
  "identifier": "HB1963",
  "title": "RELATING TO IMAGE-BASED SEXUAL ABUSE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Felony Offense",
    "Minors",
    "Nonconsensual Disclosure of Intimate or Private Images",
    "Penal Code",
    "Vulnerable Adults"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the nonconsensual disclosure of intimate or private images as a criminal offense.  Amends the criteria for an extended term of imprisonment to include an offender whose act of attempting to commit or committing the nonconsensual disclosure of intimate images or private images against a minor or vulnerable adult was the proximate cause of the victim's death.  Effective 7/1/3000.  (HD2)"
    }
  ],
