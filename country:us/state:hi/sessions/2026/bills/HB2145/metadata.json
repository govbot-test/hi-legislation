  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning, 1/1/2027, requires health insurers, mutual benefit societies, and health maintenance organizations to provide coverage for medically necessary proton beam therapy for cancer treatment and prohibits imposing stricter clinical evidence standards on proton beam therapy than on other radiation treatments."
    }
  ],
