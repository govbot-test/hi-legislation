  "identifier": "SB2117",
  "title": "RELATING TO THE HAWAII EMPLOYER-UNION HEALTH BENEFITS TRUST FUND.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
