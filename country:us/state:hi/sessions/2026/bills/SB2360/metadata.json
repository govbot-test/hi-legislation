{
  "legislative_session": "2026",
  "identifier": "SB2360",
  "title": "RELATING TO STATE ENTERPRISE ZONES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Comprehensive Review",
    "DBEDT",
    "DOTAX",
    "Eligible Business Activities",
    "Exemption",
    "Extension",
    "General Excise Tax",
    "Hawaii Food and Production Innovation Network",
    "Health Care Services",
    "Innovation Enterprises",
    "Qualified Business",
    "Report",
    "Retail Sales",
    "State Business Tax Credit",
    "State Enterprise Zones",
    "Value-Added Agricultural Products"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the definition of \"eligible business activity\" for the purposes of the Enterprise Zone Program to include certain retail sales of tangible personal property; processing of certain value-added agricultural products; research development, sale, or production of all types of medical products and medical and health care services; activities of the Hawaii Food and Product Innovation Network; the provision of certain professional services by health care professionals; aerospace research and development activities; and information technology design and production services.  Authorizes the Department of Business, Economic Development, and Tourism to declare up to two census tracts on state land that contain an innovation enterprise to be designated as an enterprise zone, subject to the Governor's approval and notwithstanding certain conditions.  Requires DBEDT to conduct a comprehensive review, in consultation with the Department of Taxation, of the State Enterprise Zones Program and to submit a report to the Legislature.  For taxable years beginning after 12/31/2026, extends the eligibility period of the state business tax credit for qualified businesses within state enterprise zones.  Beginning 1/1/2028, extends the eligibility period of the general excise tax exemption for qualified businesses within state enterprise zones.  Applies to qualified businesses who join the Enterprise Zone Program on or after 7/1/2026.  (CD1)"
    }
  ],
