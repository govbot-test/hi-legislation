  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Transportation to administer the Safe Routes to School Program.  Amends the purposes for which funds of the Safe Routes to School Special Fund may be used for.  Establishes deadlines for when funds from Safe Routes to School Special Fund that are allocated to the counties should be obligated or expended by.  Effective 7/1/3000.  (HD2)"
    }
  ],
