  "identifier": "HB1669",
  "title": "RELATING TO LUNG CANCER SCREENING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Cigarettes",
    "DOH",
    "Educational Materials",
