{
  "legislative_session": "2026",
  "identifier": "HB1658",
  "title": "RELATING TO COLLECTIVE BARGAINING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Arbitration",
    "Collective Bargaining in Public Employment",
    "Impasse Procedures",
    "Negotiations",
    "Repricing of Classes"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Amends the collective bargaining negotiation procedure on the repricing of classes within a bargaining unit for public employees.  Establishes an impasse procedure to be applied when an employer fails to initiate the negotiation or the parties fail to reach an agreement within certain timeframes.  Repeals existing law that requires a different impasse procedure to apply in those situations.  Sunsets 6/30/2029.  Effective 7/1/2050.  (SD1)"
    }
  ],
