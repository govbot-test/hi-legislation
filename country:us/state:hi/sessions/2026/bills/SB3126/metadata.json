  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows the Department of Hawaiian Home Lands to assume historic preservation review of the effect of any proposed project for lands under its jurisdiction except for projects affecting properties listed or nominated for inclusion in the Hawaii register of historic places or the national register of historic places."
    }
