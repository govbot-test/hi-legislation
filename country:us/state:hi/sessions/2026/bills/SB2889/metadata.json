  "abstracts": [
    {
      "note": "description",
      "abstract": "Restricts commercial helicopter tour operations over sensitive areas designated by the Department of Transportation through public process.  Requires the Department of Transportation to enforce restrictions through a permit process, flight tracking, noise monitoring, complaint investigation, and the issuance of a civil penalty for each violation.  Requires an annual report to the Legislature by the Department of Transportation."
    }
  ],
