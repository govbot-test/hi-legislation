  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes administrative drivers license revocation hearings to be conducted using interactive conference technology, including teleconference, videoconference, and voice over internet protocol (VoIP) systems.  Clarifies that evidence in hearings conducted via interactive conference technology may be submitted and exchanged electronically.  (SD1)"
    }
  ],
