  "identifier": "SB2572",
  "title": "RELATING TO AGGRAVATED CIRCUMSTANCES IN CHILD PROTECTIVE PROCEEDINGS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Aggravated Circumstances Hearings",
    "Child Protective Proceedings",
    "Family Courts",
    "Judiciary Package"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands the authority of the family court in child protective proceedings to find that aggravated circumstances are present at any stage prior to the termination of parental rights, not only at the outset of the case or the return hearing.  Specifies what acts of torture against a child constitute aggravated circumstances."
    }
  ],
