{
  "legislative_session": "2026",
  "identifier": "SB3206",
  "title": "RELATING TO CANNABINOIDS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Cannabinoids",
    "Hemp Processors",
    "Manufactured Hemp Products",
    "Retail",
    "Tetrahydrocannabinol Concentration Limit"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Allows any hemp processor with a permit from the Department of Health to sell certain manufactured hemp products that contain a tetrahydrocannabinol concentration of not more than five milligrams per serving.  Prohibits the sale of certain manufactured hemp products to any person less than twenty-one years of age.  Includes processed floral materials as \"manufactured hemp products\".  Increases the maximum tetrahydrocannabinol concentration for tinctures to five milligrams per serving."
    }
  ],
