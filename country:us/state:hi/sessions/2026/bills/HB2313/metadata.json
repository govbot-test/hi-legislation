  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Hawaii Preventive Services Advisory Committee and authorizes the Department of Health to issue preventive service recommendations.  Requires health insurance coverage without cost-sharing for Department of Health-recommended clinical preventive services.  Provides immunity for healthcare providers' and facilities' provision of recommended clinical preventive services."
    }
  ],
