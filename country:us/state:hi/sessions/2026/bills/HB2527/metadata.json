  "abstracts": [
    {
      "note": "description",
      "abstract": "Repeals portions of the Hawaii Revised Statutes that confer special benefits, protections, privileges, or entitlements to members of the United States armed forces in the State in the event that the United States government or any agency or entity of the United States government commences condemnation proceedings of any land or interest in land owned or held by the State."
    }
