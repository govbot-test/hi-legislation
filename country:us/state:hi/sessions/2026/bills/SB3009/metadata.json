{
  "legislative_session": "2026",
  "identifier": "SB3009",
  "title": "RELATING TO ENERGY EQUITY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Medical Essential Needs Energy Program",
    "PUC",
    "Residential Electricity Rate Structures",
    "Rising-Block Tariff"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Public Utilities Commission to establish residential electricity rate structures that prioritize affordability and equity.  Requires the Public Utilities Commission to establish a lifeline baseline performance standard, a medical essential needs energy program, and a new tariff.  Requires electric utilities to file revised tariffs no later than twelve months after the Public Utilities Commission has issued a final decision and order under this Act.  Requires the Public Utilities Commission to convene a stakeholder process for developing and implementing this Act."
    }
  ],
