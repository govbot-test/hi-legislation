  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Banyan Drive-Makaok\u016b Community Development District as an entity within the Hawaii Community Development Authority.  Establishes the Banyan Drive-Makaok\u016b Community Development District Special Fund.  Specifies the powers and duties of the Authority as it relates to the new development district and amends the composition of the Authority to include representatives of the new development district.  Appropriates funds.  Effective 7/1/3000.  (HD2)"
    }
  ],
