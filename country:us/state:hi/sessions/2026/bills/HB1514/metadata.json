{
  "legislative_session": "2026",
  "identifier": "HB1514",
  "title": "RELATING TO WORKERS' COMPENSATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Automatic Approval",
    "Certified Providers",
    "Department of Labor and Industrial Relations",
    "Vocational Rehabilitation Services",
    "Workers' Compensation"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies the process for selecting a certified provider of vocational rehabilitation services.  Requires certified providers to automatically approve vocational rehabilitation services for an injured employee if those services will likely be required for suitable gainful employment and the initial evaluation report finds the injured employee feasible to participate.  Requires providers to file an employee's vocational rehabilitation plan no later than one hundred twenty days after submitting an initial evaluation report, unless extended by the Director of Labor and Industrial Relations.  Clarifies the process for an employer to object to a vocational rehabilitation plan.  (CD1)"
    }
  ],
