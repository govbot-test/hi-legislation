{
  "legislative_session": "2026",
  "identifier": "HB1728",
  "title": "RELATING TO RAINWATER CATCHMENT SYSTEMS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Counties",
    "Rainwater Catchment Systems"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the counties to allow for the installation and operation of rainwater catchment systems for potable and nonpotable uses on all properties.  Allows the counties to require registration, inspection, or notification of rainwater catchment systems.  (CD1)"
    }
  ],
