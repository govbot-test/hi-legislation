  "abstracts": [
    {
      "note": "description",
      "abstract": "Removes outdated requirements and formats for plans filed with the registrar's office.  Updates permissible drawing scales used in plans.  Clarifies that statutory filing fees are set pursuant to the rules adopted by the Department of Accounting and General Services.  Repeals obsolete terms such as \"blueprint.\"  Authorizes the Department of Accounting and General Services to approve the format of plans.  (CD1)"
    }
  ],
