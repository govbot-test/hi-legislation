  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands programming and training for the comprehensive offender reentry program under the department of corrections and rehabilitation to reduce the rate of recidivism and increase inmate marketability.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
