  "legislative_session": "2026",
  "identifier": "SB2665",
  "title": "RELATING TO RENEWAL OF DRIVER'S LICENSES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOT",
    "Driver's License",
    "Motor Vehicle Drivers",
    "Renewal",
    "Traffic Safety"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires applicants for driver's license renewal who have received two or more traffic citations within the preceding five years for violations involving the operation of a motor vehicle to complete an educational course that includes a road safety video developed by the Department of Transportation and a written road safety examination.  Effective 7/1/3000.  (HD1)"
    }
  ],
