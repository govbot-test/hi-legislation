  "identifier": "SB2725",
  "title": "RELATING TO FEMALE GENITAL MUTILATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Child Abuse and Neglect",
    "Civil Action",
    "Education and Outreach",
    "Female Genital Mutilation",
    "Harm",
    "Penalties"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the offense of prohibited acts related to female genital mutilation of a minor.  Authorizes a victim of female genital mutilation to bring a civil action for damages under certain conditions.  Amends the statutory definitions of \"child abuse or neglect\" and \"harm\" to include prohibited acts related to female genital mutilation of a minor."
    }
  ],
