  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Business, Economic Development, and Tourism to conduct a study of the potential economic benefits and costs of sports tourism in the State.  Requires a report to the Legislature.  Requires funds appropriated to the Hawaii Tourism Authority in the Supplemental Executive Budget to be expended by DBEDT for the study.  Effective 7/1/2050.  (HD1)"
    }
  ],
