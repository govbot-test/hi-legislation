  "identifier": "SB2577",
  "title": "RELATING TO SPORTS TOURISM.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Aloha Stadium",
    "Appropriation ($)",
