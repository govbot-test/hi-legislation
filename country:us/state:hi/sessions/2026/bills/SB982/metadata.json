  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Hawaii Tourism Authority and School of Travel Industry Management at the University of Hawaii at Manoa to collaborate to actively plan for the design, construction, and operations and management of a state hotel.  Requires reports to the Legislature.  Appropriates funds."
    }
