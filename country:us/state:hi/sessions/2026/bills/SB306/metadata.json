{
  "legislative_session": "2026",
  "identifier": "SB306",
  "title": "RELATING TO THE LANDLORD-TENANT CODE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Habitability",
    "Landlord-Tenant Code",
    "Retaliatory Evictions"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits a landlord from recovering possession of a dwelling unit from a tenant if the habitability of the premises is significantly impaired.  Caps a tenant's liability for rent if the habitability of the premises is significantly impaired.  Provides remedies for retaliatory evictions."
    }
  ],
