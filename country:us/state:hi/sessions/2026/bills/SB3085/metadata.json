  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides an exemption to dispositions of lands set aside for filming and film studio operation from prior approval of the Board of Land and Natural Resources.  Repeals 6/30/2030 if Hawaii Film Studio has not changed locations as of that date.  Effective 7/1/3000.  (HD1)"
    }
  ],
