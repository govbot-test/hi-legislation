  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Department of Land and Natural Resources to engage in certain capital improvement projects at state small boat harbors and state parks without prior approval from the Legislature and Governor for existing facilities.  Requires semiannual reports to the Legislature.  Sunsets five years after the effective date.  (CD1)"
    }
  ],
