{
  "legislative_session": "2026",
  "identifier": "SB411",
  "title": "RELATING TO CAPITAL IMPROVEMENT PROJECTS AT STATE SMALL BOAT HARBORS AND STATE PARKS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Capital Improvement Projects",
    "DLNR",
    "Exception",
