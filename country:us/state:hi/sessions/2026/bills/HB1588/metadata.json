  "subject": [
    "Appropriation ($)",
    "DOT",
    "Noise Detection Camera Program"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the Noise Detection Camera Program in the Department of Transportation for the installation of noise detection cameras for the enforcement of noise control laws.  Appropriates moneys.  Effective 7/1/2050.  (SD1)"
    }
  ],
