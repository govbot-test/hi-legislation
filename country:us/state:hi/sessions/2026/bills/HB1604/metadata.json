  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an Agricultural Workforce Housing Working Group within the Department of Agriculture and Biosecurity to address the shortage and challenges of agricultural workforce housing in the State.  Requires reports to the Legislature.  Appropriates funds.  Effective 7/1/2050.  (SD1)"
    }
  ],
