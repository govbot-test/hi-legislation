  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an independent Office of the Child Advocate within the Department of the Attorney General to oversee and evaluate the delivery of services to children and their families by various state agencies and entities, receive and investigate complaints, and make recommendations for improvement.  Requires annual reports to the Governor, Legislature, and public.  Appropriates funds.  Effective 7/1/3000.  (HD1)"
    }
  ],
