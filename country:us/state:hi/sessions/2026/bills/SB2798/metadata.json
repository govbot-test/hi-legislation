  "abstracts": [
    {
      "note": "description",
      "abstract": "Makes permanent the Agricultural Enforcement Pilot Program established pursuant to Act 235, SLH 2025.  Renames the program as the Agricultural Enforcement Program and expands the program statewide.  Effective 7/1/3000.  (HD1)"
    }
