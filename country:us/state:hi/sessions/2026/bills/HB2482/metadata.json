  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes the facilities relocation task force to identify and address the issue of the inequitable location of mental health facilities, clean and sober homes, homeless shelters, and supportive living homes across the island of Oahu, particularly on the Waianae Coast.  Appropriates funds."
    }
