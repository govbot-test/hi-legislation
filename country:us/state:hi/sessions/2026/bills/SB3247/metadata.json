  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Royal Mausoleum Commission within the Department of Land and Natural Resources to develop and implement policy for the preservation, operation, and outreach of Mauna \u02bbAla.  Requires the Royal Mausoleum Commission to report annually to the Legislature.  Effective 7/1/3000.  (HD3)"
    }
  ],
