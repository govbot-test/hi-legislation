  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires the Department of Health to provide public guidance on radiofrequency energy exposure and conduct statewide monitoring.  Prohibits the trimming, removal, or alteration of trees or vegetation by counties around cellular towers or antennas solely to improve wireless signal reception or network performance, except as necessary for safety or protection of the equipment.  Appropriates funds."
    }
  ],
