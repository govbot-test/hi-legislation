{
  "legislative_session": "2026",
  "identifier": "SB2823",
  "title": "RELATING TO THE OFFICE OF HAWAIIAN AFFAIRS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Internal reporting referral process",
    "Office of Hawaiian Affairs"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes an independent complaint and investigation process by requiring that all complaints brought by employees, officers, and trustees of the office of Hawaiian affairs be referred directly to an appropriate independent state agency, including the department of the attorney general, the state ethics commission, or the Hawaii civil rights commission. Establishes penalties."
    }
  ],
