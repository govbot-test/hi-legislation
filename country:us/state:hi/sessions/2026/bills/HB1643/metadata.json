  "abstracts": [
    {
      "note": "description",
      "abstract": "Specifies a framework for the administration of audits of records of registered pharmacists and pharmacies.  Amends the definition of \"pharmacy benefit manager\" under chapter 431S, HRS, to exclude certain health maintenance organizations.  (CD1)"
    }
  ],
