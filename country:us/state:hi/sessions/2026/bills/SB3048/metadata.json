  "identifier": "SB3048",
  "title": "RELATING TO THE STATE BUILDING CODE COUNCIL.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Data Reporting",
    "Modernization",
    "Permitting Transparency",
    "Plan",
