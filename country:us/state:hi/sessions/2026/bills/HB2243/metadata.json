  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires all electric utilities to provide transparent customer bill impact analyses that are accessible to the public in an electronic format reasonably usable by ratepayers.  Establishes requirements for bill impact analyses.  Requires electric utilities to submit annual reports to the Public Utilities Commission.  Effective 7/1/3000.  (HD1)"
    }
  ],
