  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes restrictions on the use of artificial intelligence, algorithms, or other software tools for purposes of decision-making in health insurance utilization reviews.  Requires a licensed health care provider to review all adverse actions by the health carrier."
    }
