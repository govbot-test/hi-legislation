  "identifier": "HB2201",
  "title": "RELATING TO STATE ENTERPRISE ZONES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Eligible Business Activity",
    "Film Production",
    "Film Studios",
    "Recycling Facilities",
    "State Enterprise Zones"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Increases the number of enterprise zones that may be nominated by each county.  Amends the definition of \"eligible business activity\" to include recycling facilities and film production or operation of a Film Studio.  Effective 7/1/3000.  (HD1)"
    }
  ],
