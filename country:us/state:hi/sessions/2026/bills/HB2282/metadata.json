  "identifier": "HB2282",
  "title": "RELATING TO INSURANCE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Adjuster",
    "Cancellation",
    "Disciplinary Licensing Action",
