  "legislative_session": "2026",
  "identifier": "SB2146",
  "title": "RELATING TO TRAFFIC INFRACTIONS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Appropriation ($)",
    "Establishment",
    "Traffic Fines Task Force"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Traffic Fines Task Force that will examine the Finnish tiered traffic fines system, determine whether a similar system could be implemented in the State, and provide recommendations as to how a system could best be implemented.  Appropriates funds.  Effective 7/1/3000.  (HD2)"
    }
  ],
