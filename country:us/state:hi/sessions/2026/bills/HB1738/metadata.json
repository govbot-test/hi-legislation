  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes counties to amend district boundaries involving land areas of greater than fifteen but no more than twenty-five acres for purposes of residential housing, agricultural workforce housing, long-term rental housing, or workforce fee simple ownership.  Effective 7/1/3000.  (HD2)"
    }
  ],
