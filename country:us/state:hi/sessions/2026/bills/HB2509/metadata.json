  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a three-year homelessness sanctuary pilot program to be administered by the Coordinator on Homelessness on designated land for the pilot program, which shall serve as a safe location for unhoused women and young children, under the age of ten, to reside and access services.  Requires the Coordinator on Homelessness and the Coordinator's partner agencies to provide certain facilities and services to the designated location.  Requires reporting to the Legislature.  Appropriates funds."
    }
  ],
