{
  "legislative_session": "2026",
  "identifier": "HB1688",
  "title": "RELATING TO A GENERAL EXCISE TAX EXEMPTION FOR AIRCRAFT MAINTENANCE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Aircraft Service and Maintenance",
    "General Excise Tax",
    "Taxation"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides a general excise tax exemption for the sale of material, parts, or tools used for aircraft service and maintenance or for the construction of an aircraft service and maintenance facility.  Effective 1/1/2027.  (CD1)"
    }
  ],
