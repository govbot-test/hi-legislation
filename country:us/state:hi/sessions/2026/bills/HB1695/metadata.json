{
  "legislative_session": "2026",
  "identifier": "HB1695",
  "title": "RELATING TO RENEWABLE FUEL.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Fuel Tax Credit",
    "Renewable Fuel",
    "Renewable Fuels Production Tax Credit",
    "Sustainable Aviation Fuel"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands the provisions of the Renewable Fuels Production Tax Credit.  Clarifies that the Renewable Fuels Production Tax Credit shall only be claimed by taxpayers for which qualified renewable fuels production costs are incurred within the State and sold for distribution within the State.  Applies to taxable years beginning after 12/31/2026.  Effective 7/1/3000.  (SD1)"
    }
  ],
