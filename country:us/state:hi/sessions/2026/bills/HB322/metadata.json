{
  "legislative_session": "2026",
  "identifier": "HB322",
  "title": "RELATING TO VOTER REGISTRATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Elections",
    "Identification Cards",
    "Motor Vehicle Permits and Licenses"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes state agencies to implement automatic voter registration if designated by the Office of Elections.  Requires eligible applicants for instruction permits, provisional licenses, driver's licenses, and identification cards to be automatically registered or preregistered to vote unless the applicant opts out.  Effective 7/1/3000.  (HD2)"
    }
  ],
