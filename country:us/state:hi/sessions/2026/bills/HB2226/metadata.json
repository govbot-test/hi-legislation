  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes the Attorney General to bring a civil action in the name of the people of the State as parens patriae against any responsible party to recover certain costs or obtain certain relief, including costs and losses incurred by the Hawaii Property Insurance Association, Hawaii Hurricane Relief Fund, or other state entities, resulting from climate attributable harm or costs for risk of future climate attributable harm.  Authorizes the Hawaii Property Insurance Association and Hawaii Hurricane Relief Fund, or any private insurer licensed in the State to bring a civil cause of action against a responsible party to recover its costs and losses resulting from climate attributable harm."
    }
  ],
