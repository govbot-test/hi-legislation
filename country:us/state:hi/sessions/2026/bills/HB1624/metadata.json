  "abstracts": [
    {
      "note": "description",
      "abstract": "Proposes a constitutional amendment to authorize individuals aged twenty-one and older to use and possess a personal-use amount of cannabis.  Requires the Legislature to enact laws governing the use, manufacture, distribution, sale, possession, regulation, and taxation of cannabis within the State."
    }
  ],
