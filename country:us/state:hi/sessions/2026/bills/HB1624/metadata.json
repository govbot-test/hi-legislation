  "identifier": "HB1624",
  "title": "PROPOSING AN AMENDMENT TO THE CONSTITUTION OF THE STATE OF HAWAII TO LEGALIZE THE ADULT USE OF CANNABIS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Adult Use (ConAm)",
    "Cannabis",
