  "identifier": "SB2333",
  "title": "RELATING TO NEONICOTINOIDS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Department of Agriculture and Biosecurity",
    "Evaluations",
    "Neonicotinoid Pesticides",
    "Prohibition"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Beginning 1/1/2027, prohibits the sale, possession, or use of a pesticide containing one or more neonicotinoid pesticides, under certain conditions.  Requires the Department of Agriculture and Biosecurity to evaluate the potential impacts of and adopt any necessary control measures for neonicotinoid pesticide use on pollinating insects, native migratory and resident birds, aquatic organisms, and human health.  Effective 7/1/2050.  (SD1)"
    }
  ],
