  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates moneys to the Department of Health for the development and implementation of the Comprehensive Watershed-based Water Quality Monitoring Pilot Program for the Waikele Watershed.  Requires report to the Legislature.  Appropriates moneys to the Division of Aquatic Resources of the Department of Land and Natural Resources for mangrove removal and shoreline and stream maintenance in the Nineteenth Senatorial District and nearby areas, including the West Loch and Middle Loch shorelines.  Effective 7/1/3000.  (HD1)"
    }
  ],
