  "abstracts": [
    {
      "note": "description",
      "abstract": "Appropriates funds to support educational training programs to expand the State's health care workforce.  Allocates funds to the Department of Education for health care certificate programs and classroom renovations for health care training in public high schools.  Allocates funds to the University of Hawaii for education programs that support certified nurse assistants in becoming licensed practical nurses."
    }
  ],
