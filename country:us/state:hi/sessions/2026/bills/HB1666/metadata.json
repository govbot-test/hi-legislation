{
  "legislative_session": "2026",
  "identifier": "HB1666",
  "title": "RELATING TO MOTOR VEHICLES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Direct Financing",
    "Documents",
    "Markups",
    "Maximum",
    "New Motor Vehicles",
    "State of Emergency"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits, for sales or offers for sale of new motor vehicles, markups in excess of five per cent of the manufacturer's suggested retail price, markups in excess of $0 when specified in a proclamation declaring a state of emergency, and charges added to rates not based on the underwriting risk or credit characteristics of the consumer when dealers directly finance motor vehicle purchases.  Requires dealers to retain records for markups for a period of no less than three years."
    }
  ],
