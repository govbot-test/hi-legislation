  "subject": [
    "Appropriation ($)",
    "City and County of Honolulu",
    "Maintenance Standards",
    "Parks and Recreation"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires a county with a population of 500,000 or more to adopt ordinances to implement park maintenance standard prioritization.  Imposes a fine for incompliant parks after three months.  Authorizes DLNR to take action and be reimbursed by the county for costs incurred.  Appropriates funds."
    }
  ],
