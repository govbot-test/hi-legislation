  "identifier": "SB3021",
  "title": "RELATING TO CONSUMER PROTECTION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advertising",
    "Consumer Protection",
    "DCCA",
