  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies insurance, indemnification, and certain certificate of occupancy requirements for purposes of expedited permits.  Requires state or county inspectors to inspect all projects with expedited permits.  Repeals 6/30/2031.  (CD1)"
    }
