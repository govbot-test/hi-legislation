  "identifier": "SB3084",
  "title": "RELATING TO THE HAWAII TECHNOLOGY DEVELOPMENT CORPORATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Hawaii Technology Development Corporation",
    "Matching Funds",
    "Research and Development Grants"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Expands the allowable uses of Hawaii Technology Development Corporation grant funds to include providing grants to any business that applies for a federal research and development grant or receives a federal research and development award or contract that requires non-federal funding match, with certain exceptions.  Effective 7/1/2050.  (HD1)"
    }
  ],
