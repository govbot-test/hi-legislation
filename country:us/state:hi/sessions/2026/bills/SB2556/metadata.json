  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits any person from operating a motor vehicle equipped with an engine brake in certain areas.  Prohibits motor vehicles that tow a vehicle or trailer from driving in the far left lane on any roadway that has three or more lanes for traffic moving in the same direction in a county with a population of five hundred thousand or more, with certain exceptions.  Establishes penalties."
    }
  ],
