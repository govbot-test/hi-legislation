  "abstracts": [
    {
      "note": "description",
      "abstract": "Provides that the period of limitations for criminal prosecutions under campaign finance laws commences upon discovery of the offense by the Campaign Spending Commission, rather than being limited to five years from the violation date or report filing date."
    }
  ],
