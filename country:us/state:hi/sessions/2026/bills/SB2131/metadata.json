  "abstracts": [
    {
      "note": "description",
      "abstract": "Subjects the Hawaii Tourism Authority's updating of the Tourism Functional Plan to availability of funding.  Requires the Governor to submit an approved updated plan to the Legislature before the Regular Session following an update, rather than before the Regular Session of 2025."
    }
