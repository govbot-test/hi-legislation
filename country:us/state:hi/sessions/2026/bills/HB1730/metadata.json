  "legislative_session": "2026",
  "identifier": "HB1730",
  "title": "RELATING TO WASTEWATER SYSTEMS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Administrative Rules",
    "Appropriations ($)",
    "Cesspool Conversion Implementation Working Group",
    "Cesspools",
    "DOH"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Establishes a Cesspool Conversion Implementation Working Group to assist the Department of Health in a review of the Department's administrative rules and practices regarding wastewater systems and cesspools and in the development of proposed changes to make cesspool conversions more affordable.  Requires a report to the Legislature.  Appropriates funds for positions and hiring of a consultant to assist the Cesspool Conversion Implementation Working Group.  Effective 7/1/3000.  (SD1)"
    }
  ],
