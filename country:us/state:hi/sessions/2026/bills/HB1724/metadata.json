{
  "legislative_session": "2026",
  "identifier": "HB1724",
  "title": "RELATING TO THE HAWAII HOUSING FINANCE AND DEVELOPMENT CORPORATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Affordable Homeownership Revolving Fund",
    "Computation of Interest",
    "Dwelling Unit Revolving Fund",
    "Dwelling Unit Revolving Fund Equity Program",
    "HHFDC"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Makes the Dwelling Unit Revolving Fund Equity Pilot Program permanent, with modifications that include changing the method for computation of interest for purchasers of certain real property.  Expands the use of proceeds in the Dwelling Unit Revolving Fund to include purchasing equity in for-sale housing development projects and interim primary or secondary financing.  Exempts disbursements from the Affordable Homeownership Revolving Fund from appropriation and allotment requirements.  Effective 7/1/2050.  (SD1)"
    }
  ],
