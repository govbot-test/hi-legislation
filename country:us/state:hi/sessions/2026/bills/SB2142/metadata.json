  "identifier": "SB2142",
  "title": "RELATING TO ENERGY EFFICIENCY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DAGS",
    "Energy Efficiency",
    "First Responder Facilities",
    "HSEO",
    "Lighting",
    "Report",
    "State Agencies"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Requires each state agency to expeditiously use energy efficient lighting.  Requires the Hawaii State Energy Office to provide technical assistance and survey state agencies for compliance, prioritizing first responder facilities.  Requires the Department of Accounting and General Services to assist the Hawaii State Energy Office in conducting the survey.  Requires a report of the survey to the Legislature."
    }
  ],
