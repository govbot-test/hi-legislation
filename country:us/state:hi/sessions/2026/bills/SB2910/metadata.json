  "abstracts": [
    {
      "note": "description",
      "abstract": "Implements certain recommendations of the SPEED Task Force.  Requires the State Building Code Council to provide annual training to state and county permitting agency employees.  Appropriates funds for the training, subject to a matching funds requirement from the counties."
    }
