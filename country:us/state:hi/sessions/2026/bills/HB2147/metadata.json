{
  "legislative_session": "2026",
  "identifier": "HB2147",
  "title": "PROPOSING AMENDMENTS TO ARTICLES VIII AND X OF THE CONSTITUTION OF THE STATE OF HAWAII TO AUTHORIZE THE LEGISLATURE TO ESTABLISH A SURCHARGE ON RESIDENTIAL INVESTMENT PROPERTY TO INCREASE FUNDING FOR PUBLIC EDUCATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Constitutional Amendment",
    "Public Education",
    "Residential Investment Property Surcharge (ConAm)"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Proposes amendments to the Hawaii State Constitution to repeal the counties' exclusive power to tax real property, and to authorize the Legislature to establish a state surcharge on real property taxes levied by the counties on certain residential investment properties, for the purpose of helping to fund public education for all of Hawaii's children and adults.  Effective 7/1/3000.  (HD2)"
    }
  ],
