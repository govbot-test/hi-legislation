  "identifier": "HB2168",
  "title": "RELATING TO THE EDUCATION OF STUDENTS EXPERIENCING HOMELESSNESS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DOE",
    "Education",
