  "abstracts": [
    {
      "note": "description",
      "abstract": "Clarifies that the Department of Health is to presume both the recommendations by the American Academy of Pediatrics and the recommendations by the Advisory Committee on Immunization Practices of the United States Department of Health and Human Services constitute the prevailing medical standard for child health supervision services for purposes of health insurance coverage."
    }
