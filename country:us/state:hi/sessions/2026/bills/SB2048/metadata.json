  "abstracts": [
    {
      "note": "description",
      "abstract": "Prohibits the sale, barter, or donation of any pest-infested item or material.  Authorizes the Department of Agriculture and Biosecurity to quarantine, treat, or destroy pest-infested items or materials.  Imposes penalties on individuals who sell, barter, or donate a pest-infested items or materials.  Effective 7/1/2050.  (SD1)"
    }
  ],
