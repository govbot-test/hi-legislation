{
  "legislative_session": "2026",
  "identifier": "SB2192",
  "title": "RELATING TO HOUSING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Aggregate Zoned Residential Capacity",
    "Counties",
    "Reduction"
  ],
  "abstracts": [
    {
      "note": "description",
      "abstract": "Authorizes a county to reduce the aggregate zoned residential capacity within the county only if the county offsets that reduction by increasing zoned residential capacity elsewhere in the county, such that there is no net loss in residential capacity in the county.  Effective 7/1/3000.  (HD1)"
    }
  ],
